# Database
DB_CONNECTION_STRING=Server=localhost\\SQLEXPRESS;Database=ShopDb;User Id=sa;Password=YOUR_PASSWORD;TrustServerCertificate=True

# Email SMTP
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-email@gmail.com
EMAIL_SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Furnish Shop

# VNPay (Payment)
VNPAY_TMNCODE=YOUR_TMNCODE
VNPAY_HASH_SECRET=YOUR_HASH_SECRET
VNPAY_CALLBACK_URL=https://your-domain.com/Payment/Callback

# MoMo (Payment)
MOMO_PARTNER_CODE=YOUR_PARTNER_CODE
MOMO_ACCESS_KEY=YOUR_ACCESS_KEY
MOMO_SECRET_KEY=YOUR_SECRET_KEY
MOMO_RETURN_URL=https://your-domain.com/Payment/MoMoCallback

# Admin Security
ADMIN_SECRET_CODE=YOUR_SECRET_CODE
