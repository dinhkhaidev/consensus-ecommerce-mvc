@{
    ViewData["Title"] = "Dashboard";
    var totalProducts = (int)(ViewData["TotalProducts"] ?? 0);
    var totalOrders = (int)(ViewData["TotalOrders"] ?? 0);
    var totalRevenue = (decimal)(ViewData["TotalRevenue"] ?? 0m);
    var pendingOrders = (int)(ViewData["PendingOrders"] ?? 0);
    var totalCustomers = (int)(ViewData["TotalCustomers"] ?? 0);
    var lowStockCount = (int)(ViewData["LowStockCount"] ?? 0);
    var recentOrders = ViewBag.RecentOrders as List<WebActionResults.Data.Entities.Order> ?? new();
    var topProducts = ViewBag.TopProducts as dynamic ?? new List<dynamic>();
}

<div class="row g-4 mb-4">
    <!-- Stats Cards -->
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 1rem;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background: linear-gradient(135deg, #d47f31 0%, #e8a05f 100%);">
                    <i class="bi bi-box-seam text-white fs-4"></i>
                </div>
                <div>
                    <p class="text-muted small mb-0 text-uppercase" style="font-size: 0.65rem; letter-spacing: .05em;">Total Products</p>
                    <h3 class="mb-0 fw-bold">@totalProducts</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 1rem;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background: linear-gradient(135deg, #ffc107 0%, #ffdd85 100%);">
                    <i class="bi bi-clock-history text-dark fs-4"></i>
                </div>
                <div>
                    <p class="text-muted small mb-0 text-uppercase" style="font-size: 0.65rem; letter-spacing: .05em;">Pending Orders</p>
                    <h3 class="mb-0 fw-bold">@pendingOrders</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 1rem;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background: linear-gradient(135deg, #198754 0%, #4fd98e 100%);">
                    <i class="bi bi-cart-check text-white fs-4"></i>
                </div>
                <div>
                    <p class="text-muted small mb-0 text-uppercase" style="font-size: 0.65rem; letter-spacing: .05em;">Total Orders</p>
                    <h3 class="mb-0 fw-bold">@totalOrders</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 1rem;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background: linear-gradient(135deg, #0dcaf0 0%, #7dd3fc 100%);">
                    <i class="bi bi-currency-dollar text-white fs-4"></i>
                </div>
                <div>
                    <p class="text-muted small mb-0 text-uppercase" style="font-size: 0.65rem; letter-spacing: .05em;">Revenue</p>
                    <h3 class="mb-0 fw-bold">@(((decimal)totalRevenue).ToString("N0"))</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <!-- Second Row Stats -->
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 1rem;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3" style="background: linear-gradient(135deg, #6f42c1 0%, #a78bfa 100%);">
                    <i class="bi bi-people text-white fs-4"></i>
                </div>
                <div>
                    <p class="text-muted small mb-0 text-uppercase" style="font-size: 0.65rem; letter-spacing: .05em;">Customers</p>
                    <h3 class="mb-0 fw-bold">@totalCustomers</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100" style="border-radius: 1rem;">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="rounded-3 p-3 @(lowStockCount > 0 ? "bg-danger" : "bg-success")" style="opacity: 0.9;">
                    <i class="bi bi-exclamation-triangle text-white fs-4"></i>
                </div>
                <div>
                    <p class="text-muted small mb-0 text-uppercase" style="font-size: 0.65rem; letter-spacing: .05em;">Low Stock Alert</p>
                    <h3 class="mb-0 fw-bold">@lowStockCount</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Recent Orders -->
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-clock-history me-2 text-primary"></i>Recent Orders</h5>
                <a asp-area="Admin" asp-controller="AdminOrder" asp-action="Index" class="btn btn-sm btn-outline-primary">
                    View All <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="card-body p-0">
                @if (recentOrders != null && recentOrders.Count > 0)
                {
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="border-0 py-3 ps-4 text-uppercase" style="font-size: 0.7rem;">Order</th>
                                    <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Customer</th>
                                    <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Date</th>
                                    <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Total</th>
                                    <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Status</th>
                                    <th class="border-0 py-3 pe-4 text-uppercase" style="font-size: 0.7rem;">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in recentOrders)
                                {
                                    <tr class="border-bottom">
                                        <td class="py-3 ps-4">
                                            <span class="fw-semibold text-primary">#@order.Id</span>
                                        </td>
                                        <td class="py-3">@order.User?.UserName</td>
                                        <td class="py-3 text-muted small">@order.CreatedAt.ToString("MMM dd, yyyy")</td>
                                        <td class="py-3 fw-semibold">@order.TotalAmount.ToString("N0") VND</td>
                                        <td class="py-3">
                                            <span class="badge rounded-pill bg-@GetStatusBadge(order.Status)">@order.Status</span>
                                        </td>
                                        <td class="py-3 pe-4">
                                            <a asp-area="Admin" asp-controller="AdminOrder" asp-action="Details" asp-route-id="@order.Id"
                                               class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-receipt text-muted" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-2 mb-0">No orders yet</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Top Products -->
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0"><i class="bi bi-trophy me-2 text-warning"></i>Top Products</h5>
            </div>
            <div class="card-body p-0">
                @if (topProducts != null && topProducts.Count > 0)
                {
                    <ul class="list-group list-group-flush">
                        @{
                            int rank = 1;
                        }
                        @foreach (dynamic tp in topProducts)
                        {
                            <li class="list-group-item d-flex align-items-center gap-3 py-3 px-3">
                                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                                     style="width: 32px; height: 32px; font-size: 0.8rem; font-weight: 600;">
                                    @(rank++)
                                </div>
                                <div class="flex-grow-1">
                                    <p class="mb-0 fw-semibold" style="font-size: 0.85rem;">@tp.ProductName</p>
                                    <small class="text-muted">@tp.TotalSold sold</small>
                                </div>
                                <span class="fw-bold text-primary">@(((decimal)tp.TotalRevenue).ToString("N0")) VND</span>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-bar-chart text-muted" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-2 mb-0">No sales data yet</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@{
    string GetStatusBadge(WebActionResults.Data.Entities.OrderStatus status) => status switch
    {
        WebActionResults.Data.Entities.OrderStatus.Pending => "warning text-dark",
        WebActionResults.Data.Entities.OrderStatus.Confirmed => "info",
        WebActionResults.Data.Entities.OrderStatus.Processing => "primary",
        WebActionResults.Data.Entities.OrderStatus.Shipped => "info",
        WebActionResults.Data.Entities.OrderStatus.Delivered => "success",
        WebActionResults.Data.Entities.OrderStatus.Cancelled => "danger",
        _ => "secondary"
    };
}

<style>
    .card {
        transition: all 0.3s ease;
    }

    .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(0,0,0,0.1) !important;
    }

    .rounded-3 {
        border-radius: 0.75rem !important;
    }

    .badge.rounded-pill {
        padding: 0.35em 0.8em;
    }

    .list-group-item {
        border-color: #f0f0f0;
    }
</style>