@model WebActionResults.Models.Category
@{
    ViewData["Title"] = "Edit Category";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-controller="AdminCategory" asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="mb-0">Edit Category</h4>
        <small class="text-muted">Update category information</small>
    </div>
</div>

<form asp-area="Admin" asp-controller="AdminCategory" asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="row">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">Category Information</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="CategoryName" class="form-label fw-semibold">Category Name</label>
                        <input asp-for="CategoryName" class="form-control form-control-lg" />
                        <span asp-validation-for="CategoryName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold">Description</label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg me-2"></i>Save Changes
                        </button>
                        <a asp-area="Admin" asp-controller="AdminCategory" asp-action="Index" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

<style>
    .card {
        border-radius: 1rem;
    }
</style>