@*
    Admin Dynamic Toast Notifications
    Usage: TempData["ToastSuccess"], TempData["ToastError"], TempData["ToastWarning"], TempData["ToastInfo"]
*@

@if (TempData["ToastSuccess"] is string toastSuccess)
{
    <div class="admin-toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;">
        <div class="toast show" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="4000">
            <div class="toast-header" style="background: linear-gradient(135deg, #2ecc71 0%, #27ae60 100%); color: white; border: none;">
                <i class="bi bi-check-circle-fill me-2"></i>
                <strong class="me-auto">Thành công</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body" style="background: #f8f9fa;">
                @toastSuccess
            </div>
        </div>
    </div>
}

@if (TempData["ToastError"] is string toastError)
{
    <div class="admin-toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;">
        <div class="toast show" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="5000">
            <div class="toast-header" style="background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%); color: white; border: none;">
                <i class="bi bi-x-circle-fill me-2"></i>
                <strong class="me-auto">Lỗi</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body" style="background: #fff5f5;">
                @toastError
            </div>
        </div>
    </div>
}

@if (TempData["ToastWarning"] is string toastWarning)
{
    <div class="admin-toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;">
        <div class="toast show" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="4500">
            <div class="toast-header" style="background: linear-gradient(135deg, #f39c12 0%, #e67e22 100%); color: white; border: none;">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <strong class="me-auto">Cảnh báo</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body" style="background: #fef9f0;">
                @toastWarning
            </div>
        </div>
    </div>
}

@if (TempData["ToastInfo"] is string toastInfo)
{
    <div class="admin-toast-container position-fixed top-0 end-0 p-3" style="z-index: 9999;">
        <div class="toast show" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="4000">
            <div class="toast-header" style="background: linear-gradient(135deg, #3498db 0%, #2980b9 100%); color: white; border: none;">
                <i class="bi bi-info-circle-fill me-2"></i>
                <strong class="me-auto">Thông tin</strong>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast" aria-label="Close"></button>
            </div>
            <div class="toast-body" style="background: #f0f8ff;">
                @toastInfo
            </div>
        </div>
    </div>
}

<style>
    .admin-toast-container {
        pointer-events: none;
        margin-top: 80px;
        margin-right: 20px;
    }
    .admin-toast-container .toast {
        pointer-events: auto;
        animation: adminSlideIn 0.3s ease-out;
        min-width: 320px;
        max-width: 420px;
        border: none;
        box-shadow: 0 8px 32px rgba(0,0,0,0.15);
        border-radius: 0.5rem;
        overflow: hidden;
    }
    .admin-toast-container .toast-header {
        padding: 0.875rem 1rem;
        border-radius: 0.5rem 0.5rem 0 0;
        font-weight: 600;
    }
    .admin-toast-container .toast-body {
        padding: 1rem;
        font-size: 0.95rem;
        color: #333;
        border-radius: 0 0 0.5rem 0.5rem;
    }
    @@keyframes adminSlideIn {
        from {
            transform: translateX(100%) translateY(-10px);
            opacity: 0;
        }
        to {
            transform: translateX(0) translateY(0);
            opacity: 1;
        }
    }
    .admin-toast-container .toast-header i {
        font-size: 1.1rem;
    }
</style>