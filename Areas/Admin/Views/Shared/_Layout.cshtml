<!DOCTYPE html>
@{
    var settings = ViewData["WebSettings"] as Dictionary<string, string> ?? new();
    var currentLanguage = localizer.CurrentLanguage;
    var languageClass = currentLanguage == "vi" ? "lang-vi" : "lang-en";
    var storeName = settings.GetValueOrDefault("StoreName", "Furnish");
    var adminConsoleTitle = settings.GetValueOrDefault("AdminConsoleTitle", $"{storeName} Admin");
    var adminMetaDescription = settings.GetValueOrDefault("SiteDescription", localizer.Get("AdminLayout.MetaDescription"));
    var faviconUrl = settings.GetValueOrDefault("FaviconUrl", "");
    var primaryColor = settings.GetValueOrDefault("PrimaryColor", "#d47f31");
}
<html lang="@currentLanguage">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@adminMetaDescription" />
    <title>@ViewData["Title"] - @adminConsoleTitle</title>
    @if (!string.IsNullOrWhiteSpace(faviconUrl))
    {
        <link rel="icon" href="@faviconUrl" />
    }
    <meta name="theme-color" content="@primaryColor" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    @RenderSection("Head", required: false)
</head>
<body class="admin-shell @languageClass">
    @{
        var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
        var action = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
        string Active(string controllerName, string? actionName = null)
            => controller == controllerName && (actionName == null || action == actionName) ? "active" : string.Empty;
    }

    <aside class="admin-sidebar">
        <a class="admin-brand" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
            <span class="admin-brand-mark"><i class="bi bi-house-heart-fill"></i></span>
            <span>
                <strong>@storeName</strong>
                <small>@adminConsoleTitle</small>
            </span>
        </a>

        <nav class="admin-nav">
            <div class="admin-nav-group">
                <div class="admin-nav-title">@localizer.Get("AdminLayout.Overview")</div>
                <a class="admin-nav-link @Active("Dashboard")" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-speedometer2"></i><span>@localizer.Get("Dashboard")</span>
                </a>
            </div>

            <div class="admin-nav-group">
                <div class="admin-nav-title">@localizer.Get("AdminLayout.Commerce")</div>
                <a class="admin-nav-link @Active("AdminOrder")" asp-area="Admin" asp-controller="AdminOrder" asp-action="Index">
                    <i class="bi bi-receipt"></i><span>@localizer.Get("Orders")</span>
                </a>
                <a class="admin-nav-link @Active("AdminProduct")" asp-area="Admin" asp-controller="AdminProduct" asp-action="Index">
                    <i class="bi bi-box-seam"></i><span>@localizer.Get("Products")</span>
                </a>
                <a class="admin-nav-link @Active("AdminCategory")" asp-area="Admin" asp-controller="AdminCategory" asp-action="Index">
                    <i class="bi bi-grid-3x3-gap"></i><span>@localizer.Get("Categories")</span>
                </a>
                <a class="admin-nav-link @Active("AdminCoupon")" asp-area="Admin" asp-controller="AdminCoupon" asp-action="Index">
                    <i class="bi bi-ticket-perforated"></i><span>@localizer.Get("Coupons")</span>
                </a>
            </div>

            <div class="admin-nav-group">
                <div class="admin-nav-title">@localizer.Get("AdminLayout.Community")</div>
                <a class="admin-nav-link @Active("AdminAccount")" asp-area="Admin" asp-controller="AdminAccount" asp-action="Index">
                    <i class="bi bi-people"></i><span>@localizer.Get("Accounts")</span>
                </a>
                <a class="admin-nav-link @Active("AdminReview")" asp-area="Admin" asp-controller="AdminReview" asp-action="Index">
                    <i class="bi bi-star"></i><span>@localizer.Get("Reviews")</span>
                </a>
            </div>

            <div class="admin-nav-group">
                <div class="admin-nav-title">@localizer.Get("AdminLayout.Configuration")</div>
                <a class="admin-nav-link @Active("AdminSettings", "Index")" asp-area="Admin" asp-controller="AdminSettings" asp-action="Index">
                    <i class="bi bi-sliders2"></i><span>@localizer.Get("AdminSettings.Title")</span>
                </a>
                <a class="admin-nav-link @Active("AdminSettings", "Payment")" asp-area="Admin" asp-controller="AdminSettings" asp-action="Payment">
                    <i class="bi bi-credit-card"></i><span>@localizer.Get("PaymentMethod")</span>
                </a>
            </div>
        </nav>
    </aside>

    <div class="admin-main">
        <header class="admin-topbar">
            <div>
                <p class="text-muted small mb-1">@localizer.Get("Admin")</p>
                <h1 class="h5 fw-bold mb-0">@ViewData["Title"]</h1>
            </div>
            <div class="admin-topbar-actions">
                <a class="btn btn-outline-secondary btn-sm" asp-area="" asp-controller="Home" asp-action="Index" target="_blank">
                    <i class="bi bi-box-arrow-up-right me-1"></i>@localizer.Get("AdminSettings.ViewSite")
                </a>
                @await Component.InvokeAsync("LanguageSelector")
                <div class="admin-user-pill">
                    <i class="bi bi-person-circle"></i>
                    <span>@Context.Session.GetString("USER_NAME")</span>
                </div>
                <form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
                    <button type="submit" class="btn btn-danger btn-sm">
                        <i class="bi bi-box-arrow-right me-1"></i>@localizer.Get("Logout")
                    </button>
                </form>
            </div>
        </header>

        <main class="admin-content">
            @await Html.PartialAsync("_AdminToastNotifications")
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
