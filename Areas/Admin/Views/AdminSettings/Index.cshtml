@model Dictionary<string, string>
@{
    ViewData["Title"] = "Web Settings";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <!-- Page Heading -->
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="bi bi-gear me-2"></i>Web Settings
        </h1>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form method="post" action="@Url.Action("Update", "AdminSettings", new { area = "Admin" })">
        @Html.AntiForgeryToken()

        <div class="row">
            <!-- General Settings -->
            <div class="col-lg-6">
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="bi bi-globe me-2"></i>General Settings
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Site Title</label>
                            <input type="text" name="settings[SiteTitle]" class="form-control"
                                   value="@Model.GetValueOrDefault("SiteTitle", "")" />
                            <small class="text-muted">The title shown in browser tab and SEO</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Site Description</label>
                            <textarea name="settings[SiteDescription]" class="form-control" rows="3">@Model.GetValueOrDefault("SiteDescription", "")</textarea>
                            <small class="text-muted">Meta description for SEO</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Logo URL</label>
                            <input type="text" name="settings[LogoUrl]" class="form-control"
                                   value="@Model.GetValueOrDefault("LogoUrl", "")" />
                            <small class="text-muted">Path to your logo image</small>
                        </div>
                    </div>
                </div>

                <!-- Contact Information -->
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="bi bi-telephone me-2"></i>Contact Information
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Contact Email</label>
                            <input type="email" name="settings[ContactEmail]" class="form-control"
                                   value="@Model.GetValueOrDefault("ContactEmail", "")" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Contact Phone</label>
                            <input type="text" name="settings[ContactPhone]" class="form-control"
                                   value="@Model.GetValueOrDefault("ContactPhone", "")" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Address</label>
                            <textarea name="settings[Address]" class="form-control" rows="2">@Model.GetValueOrDefault("Address", "")</textarea>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Social & Footer Settings -->
            <div class="col-lg-6">
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="bi bi-share me-2"></i>Social Media Links
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Facebook URL</label>
                            <input type="url" name="settings[FacebookUrl]" class="form-control"
                                   value="@Model.GetValueOrDefault("FacebookUrl", "")" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Instagram URL</label>
                            <input type="url" name="settings[InstagramUrl]" class="form-control"
                                   value="@Model.GetValueOrDefault("InstagramUrl", "")" />
                        </div>
                    </div>
                </div>

                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="bi bi-c-circle me-2"></i>Footer Settings
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Copyright Text</label>
                            <input type="text" name="settings[FooterCopyright]" class="form-control"
                                   value="@Model.GetValueOrDefault("FooterCopyright", "")" />
                        </div>
                    </div>
                </div>

                <!-- Payment Settings -->
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">
                            <i class="bi bi-credit-card me-2"></i>Payment Settings
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label fw-semibold">VNPay URL</label>
                            <input type="text" name="settings[VNPayUrl]" class="form-control"
                                   placeholder="https://sandbox.vnpayment.vn/..." />
                            <small class="text-muted">VNPay sandbox or production URL</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">MoMo URL</label>
                            <input type="text" name="settings[MoMoUrl]" class="form-control"
                                   placeholder="https://momo.vn/..." />
                            <small class="text-muted">MoMo payment URL</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-check">
                                <input type="checkbox" class="form-check-input" name="settings[EnableCOD]" value="true"
                                       @(Model.GetValueOrDefault("EnableCOD") == "true" ? "checked" : "") />
                                <label class="form-check-label">Enable Cash on Delivery (COD)</label>
                            </label>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Min Order Amount for Free Shipping (VND)</label>
                            <input type="number" name="settings[FreeShippingThreshold]" class="form-control"
                                   value="@Model.GetValueOrDefault("FreeShippingThreshold", "500000")" />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-3">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary btn-lg px-5">
                <i class="bi bi-x-lg me-2"></i>Cancel
            </a>
            <button type="submit" class="btn btn-primary btn-lg px-5">
                <i class="bi bi-check-lg me-2"></i>Save All Changes
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Auto-focus on inputs when card is clicked
        document.querySelectorAll('.card-body').forEach(card => {
            card.addEventListener('click', function(e) {
                if (e.target === this) {
                    this.querySelector('input, textarea')?.focus();
                }
            });
        });
    </script>
}

<style>
    .card {
        border-radius: 1rem;
    }

    .form-control:focus {
        border-color: #d47f31;
        box-shadow: 0 0 0 0.2rem rgba(212, 127, 49, 0.25);
    }

    .btn-primary {
        background-color: #d47f31;
        border-color: #d47f31;
    }

    .btn-primary:hover {
        background-color: #b86d26;
        border-color: #b86d26;
    }

    .card-header {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    }
</style>