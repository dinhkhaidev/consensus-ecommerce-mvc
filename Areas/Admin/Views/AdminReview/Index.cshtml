@model IEnumerable<WebActionResults.Data.Entities.Review>
@{
    ViewData["Title"] = "Reviews";
    var filter = ViewData["Filter"] as string;
    var currentPage = ViewData["CurrentPage"] is int currentPageValue ? currentPageValue : 1;
    var totalPages = ViewData["TotalPages"] is int totalPagesValue ? totalPagesValue : 1;
    var totalCount = ViewData["TotalCount"] is int totalCountValue ? totalCountValue : 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Reviews</h4>
        <p class="text-muted mb-0">@totalCount reviews (@((filter == "pending") ? "pending" : (filter == "approved") ? "approved" : "all"))</p>
    </div>
</div>

<div class="card border-0 shadow-sm mb-4" style="border-radius: 1rem;">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label small text-muted text-uppercase">Filter by Status</label>
                <select name="filter" class="form-select form-control-lg">
                    <option value="">All Reviews</option>
                    <option value="pending" selected="@(filter == "pending")">Pending Approval</option>
                    <option value="approved" selected="@(filter == "approved")">Approved</option>
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100 rounded-pill">
                    <i class="bi bi-filter me-2"></i>Apply Filter
                </button>
            </div>
        </form>
    </div>
</div>

<form asp-area="Admin" asp-controller="AdminReview" asp-action="BulkAction" method="post" id="bulkForm">
    <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
        <div class="card-body p-0">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="border-0 py-3 ps-4">
                                    <input type="checkbox" id="selectAll" />
                                </th>
                                <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Product</th>
                                <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Customer</th>
                                <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Rating</th>
                                <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Comment</th>
                                <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Date</th>
                                <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Status</th>
                                <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var review in Model)
                            {
                                <tr class="border-bottom">
                                    <td class="py-3 ps-4">
                                        <input type="checkbox" name="reviewIds" value="@review.Id" class="review-checkbox" />
                                    </td>
                                    <td class="py-3">
                                        <a asp-area="Admin" asp-controller="AdminProduct" asp-action="Details" asp-route-id="@review.ProductId"
                                           class="text-decoration-none fw-semibold">@review.Product?.ProductName</a>
                                    </td>
                                    <td class="py-3">@review.User?.UserName</td>
                                    <td class="py-3">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="bi bi-star@(i <= review.Rating ? "-fill" : "") text-warning"></i>
                                        }
                                    </td>
                                    <td class="py-3" style="max-width: 200px;">
                                        <p class="mb-0 text-truncate" style="max-width: 200px;">@review.Comment</p>
                                    </td>
                                    <td class="py-3 text-muted small">@review.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    <td class="py-3">
                                        @if (review.IsApproved)
                                        {
                                            <span class="badge bg-success rounded-pill">Approved</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark rounded-pill">Pending</span>
                                        }
                                    </td>
                                    <td class="py-3">
                                        <div class="d-flex gap-1">
                                            @if (!review.IsApproved)
                                            {
                                                <form asp-area="Admin" asp-controller="AdminReview" asp-action="Approve" asp-route-id="@review.Id" method="post" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-success rounded-pill px-2" title="Approve">
                                                        <i class="bi bi-check"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-area="Admin" asp-controller="AdminReview" asp-action="Reject" asp-route-id="@review.Id" method="post" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-warning rounded-pill px-2" title="Reject">
                                                        <i class="bi bi-x"></i>
                                                    </button>
                                                </form>
                                            }
                                            <form asp-area="Admin" asp-controller="AdminReview" asp-action="Delete" asp-route-id="@review.Id" method="post" class="d-inline"
                                                  onsubmit="return confirm('Delete this review?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-2" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="card-footer bg-white py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="d-flex gap-2 align-items-center">
                            <select name="action" class="form-select form-select-sm" style="width: auto;">
                                <option value="">Bulk Actions</option>
                                <option value="approve">Approve Selected</option>
                                <option value="reject">Reject Selected</option>
                                <option value="delete">Delete Selected</option>
                            </select>
                            <button type="submit" class="btn btn-sm btn-primary rounded-pill px-3"
                                    onclick="return confirm('Apply bulk action to selected reviews?')">
                                Apply
                            </button>
                        </div>
                        @if (totalPages > 1)
                        {
                            <nav>
                                <ul class="pagination justify-content-center mb-0">
                                    <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                        <a class="page-link" asp-area="Admin" asp-controller="AdminReview" asp-action="Index"
                                           asp-route-page="@(currentPage - 1)" asp-route-filter="@filter">Previous</a>
                                    </li>
                                    @for (int i = 1; i <= totalPages; i++)
                                    {
                                        <li class="page-item @(currentPage == i ? "active" : "")">
                                            <a class="page-link" asp-area="Admin" asp-controller="AdminReview" asp-action="Index"
                                               asp-route-page="@i" asp-route-filter="@filter">@i</a>
                                        </li>
                                    }
                                    <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                        <a class="page-link" asp-area="Admin" asp-controller="AdminReview" asp-action="Index"
                                           asp-route-page="@(currentPage + 1)" asp-route-filter="@filter">Next</a>
                                    </li>
                                </ul>
                            </nav>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-chat-square-text text-muted" style="font-size: 4rem;"></i>
                    <h4 class="mt-3 mb-2">No reviews found</h4>
                    <p class="text-muted">@(filter == "pending" ? "No pending reviews" : filter == "approved" ? "No approved reviews yet" : "No reviews submitted")</p>
                </div>
            }
        </div>
    </div>
</form>

@section Scripts {
    <script>
        document.getElementById('selectAll').addEventListener('change', function() {
            document.querySelectorAll('.review-checkbox').forEach(cb => cb.checked = this.checked);
        });
    </script>
}

<style>
    .btn.rounded-pill { padding-left: 1.25rem; padding-right: 1.25rem; }
    .page-link { border-radius: 50% !important; margin: 0 3px; min-width: 36px; text-align: center; }
    .page-item.active .page-link { background-color: #d47f31; border-color: #d47f31; }
</style>
