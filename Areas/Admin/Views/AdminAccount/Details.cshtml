@model WebActionResults.Models.Account
@{
    ViewData["Title"] = "Account Details";
    var isAdmin = Model.UserName?.ToLower() == "admin";
}

<div class="mb-4">
    <a asp-area="Admin" asp-controller="AdminAccount" asp-action="Index" class="btn btn-outline-secondary rounded-pill">
        <i class="bi bi-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 1rem;">
    <div class="card-header bg-white py-4">
        <div class="d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Account Details</h4>
            @if (!isAdmin)
            {
                <form asp-area="Admin" asp-controller="AdminAccount" asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline"
                      onsubmit="return confirm('Delete this account?');">
                    <button type="submit" class="btn btn-outline-danger rounded-pill">
                        <i class="bi bi-trash me-2"></i>Delete
                    </button>
                </form>
            }
        </div>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-4 text-center mb-4">
                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center mx-auto"
                     style="width: 100px; height: 100px; font-size: 2.5rem;">
                    @(Model.FullName?.FirstOrDefault() ?? 'U')
                </div>
                <h4 class="mt-3 mb-1">@@@Model.UserName</h4>
                <span class="badge rounded-pill bg-@(isAdmin ? "danger" : "primary") px-3 py-2">
                    @(isAdmin ? "Admin" : "Customer")
                </span>
            </div>
            <div class="col-md-8">
                <table class="table table-borderless">
                    <tr>
                        <th class="text-muted small text-uppercase w-25">Full Name</th>
                        <td>@Model.FullName</td>
                    </tr>
                    <tr>
                        <th class="text-muted small text-uppercase">Email</th>
                        <td>@Model.Email</td>
                    </tr>
                    <tr>
                        <th class="text-muted small text-uppercase">Phone</th>
                        <td>@Model.Phone</td>
                    </tr>
                    <tr>
                        <th class="text-muted small text-uppercase">Status</th>
                        <td>
                            <span class="badge rounded-pill bg-@(Model.Status == 1 ? "success" : "secondary")">
                                @(Model.Status == 1 ? "Active" : "Inactive")
                            </span>
                        </td>
                    </tr>
                    <tr>
                        <th class="text-muted small text-uppercase">Email Verified</th>
                        <td>
                            <i class="bi bi-@(Model.IsEmailVerified == true ? "check-circle text-success" : "x-circle text-danger")"></i>
                            @(Model.IsEmailVerified == true ? "Yes" : "No")
                        </td>
                    </tr>
                    <tr>
                        <th class="text-muted small text-uppercase">Created</th>
                        <td>@Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                    </tr>
                </table>
                <a asp-area="Admin" asp-controller="AdminAccount" asp-action="Edit" asp-route-id="@Model.Id"
                   class="btn btn-primary rounded-pill">
                    <i class="bi bi-pencil me-2"></i>Edit Account
                </a>
            </div>
        </div>
    </div>
</div>

@if (Model.Addresses != null && Model.Addresses.Any())
{
    <div class="card border-0 shadow-sm mt-4" style="border-radius: 1rem;">
        <div class="card-header bg-white py-4">
            <h5 class="mb-0">Addresses</h5>
        </div>
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="border-0 py-3 ps-4 text-uppercase" style="font-size: 0.7rem;">Name</th>
                        <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Address</th>
                        <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Phone</th>
                        <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Default</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var addr in Model.Addresses)
                    {
                        <tr class="border-bottom">
                            <td class="py-3 ps-4">@addr.FullName</td>
                            <td class="py-3">@addr.AddressLine, @addr.Ward, @addr.District, @addr.City</td>
                            <td class="py-3">@addr.Phone</td>
                            <td class="py-3">
                                @if (addr.IsDefault)
                                {
                                    <span class="badge bg-primary rounded-pill">Default</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
