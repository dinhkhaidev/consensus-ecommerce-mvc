@model WebActionResults.Models.Account
@{
    ViewData["Title"] = "Edit Account";
}

<div class="mb-4">
    <a asp-area="Admin" asp-controller="AdminAccount" asp-action="Index" class="btn btn-outline-secondary rounded-pill">
        <i class="bi bi-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 1rem;">
    <div class="card-header bg-white py-4">
        <h4 class="mb-0">Edit Account - @@@Model.UserName</h4>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="UserName" />
            <input type="hidden" asp-for="Password" />
            <input type="hidden" asp-for="CreatedAt" />

            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label small text-muted text-uppercase">Username</label>
                    <input value="@Model.UserName" class="form-control form-control-lg" disabled />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label small text-muted text-uppercase">New Password (leave blank to keep current)</label>
                    <input type="password" name="password" class="form-control form-control-lg" placeholder="Enter new password" />
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label small text-muted text-uppercase">Full Name</label>
                    <input asp-for="FullName" class="form-control form-control-lg" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label small text-muted text-uppercase">Email</label>
                    <input asp-for="Email" class="form-control form-control-lg" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label small text-muted text-uppercase">Phone</label>
                    <input asp-for="Phone" class="form-control form-control-lg" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label small text-muted text-uppercase">Email Verified</label>
                    <select asp-for="IsEmailVerified" class="form-select form-control-lg">
                        <option value="true">Verified</option>
                        <option value="false">Pending</option>
                    </select>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label small text-muted text-uppercase">Status</label>
                    <select asp-for="Status" class="form-select form-control-lg">
                        <option value="1">Active</option>
                        <option value="0">Inactive</option>
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label small text-muted text-uppercase">Role</label>
                    <select asp-for="Role" class="form-select form-control-lg" id="roleSelect">
                        <option value="Customer">Customer</option>
                        <option value="Admin">Admin</option>
                    </select>
                </div>
            </div>

            <div class="row" id="adminVerifySection" style="display: @(Model.Role == "Admin" ? "" : "none");">
                <div class="col-md-6 mb-3">
                    <label class="form-label small text-muted text-uppercase">
                        <i class="bi bi-shield-lock me-1"></i>Your Admin Password (to confirm)
                    </label>
                    <input type="password" name="adminConfirmPassword" class="form-control form-control-lg"
                           placeholder="Enter your admin password" id="adminConfirmInput" />
                    <small class="text-muted">Required when assigning Admin role</small>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label small text-muted text-uppercase">
                        <i class="bi bi-key me-1"></i>Security Code
                    </label>
                    <input type="password" name="adminSecretCode" class="form-control form-control-lg"
                           placeholder="Enter security code" id="adminSecretInput" />
                    <small class="text-muted">Secret code from server configuration</small>
                </div>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5">
                    <i class="bi bi-check-lg me-2"></i>Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<script>
    document.getElementById('roleSelect').addEventListener('change', function () {
        var section = document.getElementById('adminVerifySection');
        var pwdInput = document.getElementById('adminConfirmInput');
        var codeInput = document.getElementById('adminSecretInput');
        if (this.value === 'Admin') {
            section.style.display = '';
            pwdInput.required = true;
            codeInput.required = true;
        } else {
            section.style.display = 'none';
            pwdInput.required = false;
            codeInput.required = false;
            pwdInput.value = '';
            codeInput.value = '';
        }
    });
</script>
