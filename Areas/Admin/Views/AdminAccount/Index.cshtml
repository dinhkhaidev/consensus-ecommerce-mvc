@model IEnumerable<WebActionResults.Models.Account>
@{
    ViewData["Title"] = "Accounts";
    var searchTerm = ViewData["SearchTerm"] as string;
    var currentPage = ViewData["CurrentPage"] != null ? (int)ViewData["CurrentPage"] : 1;
    var totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
    var totalCount = ViewData["TotalCount"] != null ? (int)ViewData["TotalCount"] : 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Accounts</h4>
        <p class="text-muted mb-0">@totalCount accounts in system</p>
    </div>
    <a asp-area="Admin" asp-controller="AdminAccount" asp-action="Create" class="btn btn-primary rounded-pill px-4">
        <i class="bi bi-plus-lg me-2"></i>Add Account
    </a>
</div>

<div class="card border-0 shadow-sm mb-4" style="border-radius: 1rem;">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-8">
                <label class="form-label small text-muted text-uppercase">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" value="@searchTerm" class="form-control border-start-0 ps-0"
                           placeholder="Search by name, username or email...">
                </div>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100 rounded-pill">
                    <i class="bi bi-search me-2"></i>Search
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 1rem;">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="border-0 py-3 ps-4 text-uppercase" style="font-size: 0.7rem;">User</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Email</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Phone</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Verified</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Status</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Role</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var account in Model)
                        {
                            var isAdmin = account.UserName?.ToLower() == "admin";
                            <tr class="border-bottom">
                                <td class="py-3 ps-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center"
                                             style="width: 40px; height: 40px; font-size: 0.9rem;">
                                            @(account.FullName?.FirstOrDefault() ?? 'U')
                                        </div>
                                        <div>
                                            <p class="mb-0 fw-semibold">@account.FullName</p>
                                            <small class="text-muted">@@@account.UserName</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3">@account.Email</td>
                                <td class="py-3">@account.Phone</td>
                                <td class="py-3">
                                    @if (account.IsEmailVerified == true)
                                    {
                                        <span class="badge rounded-pill bg-success"><i class="bi bi-check-circle me-1"></i>Verified</span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-warning text-dark"><i class="bi bi-clock me-1"></i>Pending</span>
                                    }
                                </td>
                                <td class="py-3">
                                    <span class="badge rounded-pill bg-@(account.Status == 1 ? "success" : "secondary")">
                                        @(account.Status == 1 ? "Active" : "Inactive")
                                    </span>
                                </td>
                                <td class="py-3">
                                    <span class="badge rounded-pill bg-@(isAdmin ? "danger" : "primary")">
                                        @(isAdmin ? "Admin" : "Customer")
                                    </span>
                                </td>
                                <td class="py-3">
                                    <div class="d-flex gap-2">
                                        <a asp-area="Admin" asp-controller="AdminAccount" asp-action="Details" asp-route-id="@account.Id"
                                           class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-area="Admin" asp-controller="AdminAccount" asp-action="Edit" asp-route-id="@account.Id"
                                           class="btn btn-sm btn-primary rounded-pill px-3">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (!isAdmin)
                                        {
                                            <form asp-area="Admin" asp-controller="AdminAccount" asp-action="Delete" asp-route-id="@account.Id"
                                                  method="post" class="d-inline" onsubmit="return confirm('Delete this account?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <div class="card-footer bg-white py-3">
                    <nav>
                        <ul class="pagination justify-content-center mb-0">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-area="Admin" asp-controller="AdminAccount" asp-action="Index"
                                   asp-route-page="@(currentPage - 1)" asp-route-search="@searchTerm">Previous</a>
                            </li>
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(currentPage == i ? "active" : "")">
                                    <a class="page-link" asp-area="Admin" asp-controller="AdminAccount" asp-action="Index"
                                       asp-route-page="@i" asp-route-search="@searchTerm">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-area="Admin" asp-controller="AdminAccount" asp-action="Index"
                                   asp-route-page="@(currentPage + 1)" asp-route-search="@searchTerm">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-people text-muted" style="font-size: 4rem;"></i>
                <h4 class="mt-3 mb-2">No accounts found</h4>
                <p class="text-muted mb-4">Start creating accounts for your system</p>
                <a asp-area="Admin" asp-controller="AdminAccount" asp-action="Create" class="btn btn-primary rounded-pill">
                    <i class="bi bi-plus-lg me-2"></i>Add First Account
                </a>
            </div>
        }
    </div>
</div>

<style>
    .btn.rounded-pill {
        padding-left: 1.25rem;
        padding-right: 1.25rem;
    }
    .page-link {
        border-radius: 50% !important;
        margin: 0 3px;
        min-width: 36px;
        text-align: center;
    }
    .page-item.active .page-link {
        background-color: #d47f31;
        border-color: #d47f31;
    }
</style>
