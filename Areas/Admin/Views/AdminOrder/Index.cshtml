@model IEnumerable<WebActionResults.Data.Entities.Order>
@{
    ViewData["Title"] = "Orders";
    var statusParam = Context.Request.Query["status"].ToString();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <p class="text-muted mb-0">Manage and track customer orders</p>
    </div>
</div>

<!-- Status Filter -->
<div class="d-flex gap-2 mb-4 flex-wrap">
    <a asp-area="Admin" asp-controller="AdminOrder" asp-action="Index"
       class="btn btn-sm @(string.IsNullOrEmpty(statusParam) ? "btn-primary" : "btn-outline-secondary")">
        All Orders
    </a>
    <a asp-area="Admin" asp-controller="AdminOrder" asp-action="Index" asp-route-status="Pending"
       class="btn btn-sm @(statusParam == "Pending" ? "btn-primary" : "btn-outline-secondary")">
        <i class="bi bi-clock me-1"></i>Pending
    </a>
    <a asp-area="Admin" asp-controller="AdminOrder" asp-action="Index" asp-route-status="Confirmed"
       class="btn btn-sm @(statusParam == "Confirmed" ? "btn-primary" : "btn-outline-secondary")">
        <i class="bi bi-check-circle me-1"></i>Confirmed
    </a>
    <a asp-area="Admin" asp-controller="AdminOrder" asp-action="Index" asp-route-status="Processing"
       class="btn btn-sm @(statusParam == "Processing" ? "btn-primary" : "btn-outline-secondary")">
        <i class="bi bi-gear me-1"></i>Processing
    </a>
    <a asp-area="Admin" asp-controller="AdminOrder" asp-action="Index" asp-route-status="Shipped"
       class="btn btn-sm @(statusParam == "Shipped" ? "btn-primary" : "btn-outline-secondary")">
        <i class="bi bi-truck me-1"></i>Shipped
    </a>
    <a asp-area="Admin" asp-controller="AdminOrder" asp-action="Index" asp-route-status="Delivered"
       class="btn btn-sm @(statusParam == "Delivered" ? "btn-primary" : "btn-outline-secondary")">
        <i class="bi bi-bag-check me-1"></i>Delivered
    </a>
    <a asp-area="Admin" asp-controller="AdminOrder" asp-action="Index" asp-route-status="Cancelled"
       class="btn btn-sm @(statusParam == "Cancelled" ? "btn-primary" : "btn-outline-secondary")">
        <i class="bi bi-x-circle me-1"></i>Cancelled
    </a>
    <a asp-area="Admin" asp-controller="AdminOrder" asp-action="Index" asp-route-status="CancellationRequested"
       class="btn btn-sm @(statusParam == "CancellationRequested" ? "btn-primary" : "btn-outline-secondary")">
        <i class="bi bi-exclamation-circle me-1"></i>Cancel Requests
    </a>
    <a asp-area="Admin" asp-controller="AdminOrder" asp-action="Index" asp-route-status="ReturnRequested"
       class="btn btn-sm @(statusParam == "ReturnRequested" ? "btn-primary" : "btn-outline-secondary")">
        <i class="bi bi-arrow-counterclockwise me-1"></i>Return Requests
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="border-0 py-3 ps-4">Order #</th>
                        <th class="border-0 py-3">Customer</th>
                        <th class="border-0 py-3">Date</th>
                        <th class="border-0 py-3">Items</th>
                        <th class="border-0 py-3">Total</th>
                        <th class="border-0 py-3">Payment</th>
                        <th class="border-0 py-3">Status</th>
                        <th class="border-0 py-3 pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr class="border-bottom">
                            <td class="py-3 ps-4">
                                <a asp-area="Admin" asp-controller="AdminOrder" asp-action="Details" asp-route-id="@order.Id"
                                   class="fw-semibold text-primary text-decoration-none">#@order.Id</a>
                            </td>
                            <td class="py-3">@order.User?.UserName</td>
                            <td class="py-3">@order.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td class="py-3">@order.OrderItems?.Count() items</td>
                            <td class="py-3 fw-semibold">@order.TotalAmount.ToString("N0") VND</td>
                            <td class="py-3">
                                <span class="badge bg-@GetPaymentBadge(order.PaymentStatus)">
                                    @order.PaymentStatus
                                </span>
                            </td>
                            <td class="py-3">
                                <span class="badge bg-@GetStatusBadge(order.Status)">
                                    @order.Status
                                </span>
                            </td>
                            <td class="py-3 pe-4">
                                <a asp-area="Admin" asp-controller="AdminOrder" asp-action="Details" asp-route-id="@order.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-receipt text-muted" style="font-size: 4rem;"></i>
        <h4 class="mt-3 mb-2">No orders found</h4>
        <p class="text-muted">No orders match the selected filter</p>
    </div>
}

@{
    string GetStatusBadge(WebActionResults.Data.Entities.OrderStatus status) => status switch
    {
        WebActionResults.Data.Entities.OrderStatus.Pending => "warning text-dark",
        WebActionResults.Data.Entities.OrderStatus.Confirmed => "info",
        WebActionResults.Data.Entities.OrderStatus.Processing => "primary",
        WebActionResults.Data.Entities.OrderStatus.Shipped => "info",
        WebActionResults.Data.Entities.OrderStatus.Delivered => "success",
        WebActionResults.Data.Entities.OrderStatus.Cancelled => "danger",
        WebActionResults.Data.Entities.OrderStatus.CancellationRequested => "warning text-dark",
        WebActionResults.Data.Entities.OrderStatus.ReturnRequested => "warning text-dark",
        WebActionResults.Data.Entities.OrderStatus.ReturnApproved => "success",
        WebActionResults.Data.Entities.OrderStatus.ReturnRejected => "danger",
        _ => "secondary"
    };

    string GetPaymentBadge(WebActionResults.Data.Entities.PaymentStatus status) => status switch
    {
        WebActionResults.Data.Entities.PaymentStatus.Pending => "warning text-dark",
        WebActionResults.Data.Entities.PaymentStatus.Paid => "success",
        WebActionResults.Data.Entities.PaymentStatus.Failed => "danger",
        WebActionResults.Data.Entities.PaymentStatus.Refunded => "info",
        _ => "secondary"
    };
}

<style>
    .card {
        border-radius: 1rem;
    }
</style>
