@{
    ViewData["Title"] = "Create Product";
    var categories = ViewBag.Categories as IEnumerable<WebActionResults.Models.Category>;
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-controller="AdminProduct" asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="mb-0">Create New Product</h4>
        <small class="text-muted">Add a new product to your catalog</small>
    </div>
</div>

<form asp-area="Admin" asp-controller="AdminProduct" asp-action="Create" method="post">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">Basic Information</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Product Name</label>
                        <input name="ProductName" class="form-control form-control-lg" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea name="QuantityPerUnit" class="form-control" rows="4"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Price (VND)</label>
                            <input name="UnitPrice" class="form-control form-control-lg" type="number" step="1000" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Category</label>
                            <select name="CategoryId" class="form-select form-select-lg">
                                @if (categories != null)
                                {
                                    foreach (var cat in categories)
                                    {
                                        <option value="@cat.Id">@cat.CategoryName</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Units In Stock</label>
                            <input name="UnitsInStock" class="form-control form-control-lg" type="number" value="0" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Discontinued</label>
                            <select name="Discontinued" class="form-select form-select-lg">
                                <option value="false">No</option>
                                <option value="true">Yes</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">Product Images</h5>
                </div>
                <div class="card-body text-center">
                    <div class="bg-light rounded p-5 mb-3">
                        <i class="bi bi-cloud-upload text-secondary" style="font-size: 3rem;"></i>
                        <p class="text-muted small mt-2 mb-0">Images can be added after creation</p>
                    </div>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                    <i class="bi bi-plus-lg me-2"></i>Create Product
                </button>
                <a asp-area="Admin" asp-controller="AdminProduct" asp-action="Index" class="btn btn-outline-secondary btn-lg">
                    Cancel
                </a>
            </div>
        </div>
    </div>
</form>

<style>
    .card {
        border-radius: 1rem;
    }
</style>