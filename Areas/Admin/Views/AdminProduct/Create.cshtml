@model WebActionResults.Models.Product
@{
    ViewData["Title"] = "Create Product";
    var categories = ViewBag.Categories as IEnumerable<WebActionResults.Models.Category>;
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-controller="AdminProduct" asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="mb-0">Create New Product</h4>
        <small class="text-muted">Add a new product to your catalog</small>
    </div>
</div>

<form action="/Admin/AdminProduct/Create" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">Basic Information</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <label asp-for="ProductName" class="form-label fw-semibold">Product Name</label>
                        <input asp-for="ProductName" class="form-control form-control-lg" required />
                        <span asp-validation-for="ProductName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="QuantityPerUnit" class="form-label fw-semibold">Description</label>
                        <textarea asp-for="QuantityPerUnit" class="form-control" rows="4" maxlength="100"></textarea>
                        <span asp-validation-for="QuantityPerUnit" class="text-danger"></span>
                        <div class="form-text">Maximum 100 characters.</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="UnitPrice" class="form-label fw-semibold">Price (VND)</label>
                            <input asp-for="UnitPrice" class="form-control form-control-lg" type="number" step="1" min="0" inputmode="numeric" required />
                            <span asp-validation-for="UnitPrice" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Category</label>
                            <select asp-for="CategoryID" class="form-select form-select-lg" required>
                                @if (categories != null)
                                {
                                    foreach (var cat in categories)
                                    {
                                        <option value="@cat.Id">@cat.CategoryName</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="CategoryID" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Units In Stock</label>
                            <input name="UnitsInStock" class="form-control form-control-lg" type="number" value="0" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-semibold">Discontinued</label>
                            <select name="Discontinued" class="form-select form-select-lg">
                                <option value="false">No</option>
                                <option value="true">Yes</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Variants</h5>
                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="addVariantRow()">
                        <i class="bi bi-plus-lg me-1"></i>Add Variant
                    </button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table mb-0 align-middle" id="variantTable">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-3">Color</th>
                                    <th>Size</th>
                                    <th>SKU</th>
                                    <th>Price Adj.</th>
                                    <th>Stock</th>
                                    <th>Active</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody id="variantRows">
                                <tr>
                                    <td class="ps-3"><input name="variants[0].Color" class="form-control" placeholder="Brown" /></td>
                                    <td><input name="variants[0].Size" class="form-control" placeholder="Large" /></td>
                                    <td><input name="variants[0].SKU" class="form-control" placeholder="SOFA-BR-L" /></td>
                                    <td><input name="variants[0].PriceAdjustment" class="form-control" type="number" step="1" value="0" /></td>
                                    <td><input name="variants[0].StockQuantity" class="form-control" type="number" min="0" value="0" /></td>
                                    <td>
                                        <input name="variants[0].IsActive" class="form-check-input" type="checkbox" value="true" checked />
                                        <input type="hidden" name="variants[0].IsActive" value="false" />
                                    </td>
                                    <td class="text-end pe-3">
                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeVariantRow(this)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <p class="text-muted small px-3 py-2 mb-0">Leave the row empty if the product does not need variants.</p>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">Product Images</h5>
                </div>
                <div class="card-body text-center">
                    <div class="bg-light rounded p-4 mb-3">
                        <i class="bi bi-cloud-upload text-secondary" style="font-size: 3rem;"></i>
                        <p class="text-muted small mt-2 mb-0">Upload product photos now. The first image will be used as main.</p>
                    </div>
                    <input type="file"
                           name="imageFiles"
                           class="form-control"
                           accept="image/jpeg,image/png,image/webp,image/gif"
                           multiple />
                    <p class="text-muted small mt-2 mb-0">JPG, PNG, WEBP or GIF. Max 5MB per image.</p>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                    <i class="bi bi-plus-lg me-2"></i>Create Product
                </button>
                <a asp-area="Admin" asp-controller="AdminProduct" asp-action="Index" class="btn btn-outline-secondary btn-lg">
                    Cancel
                </a>
            </div>
        </div>
    </div>
</form>

<template id="variantRowTemplate">
    <tr>
        <td class="ps-3"><input data-name="Color" class="form-control" placeholder="Brown" /></td>
        <td><input data-name="Size" class="form-control" placeholder="Large" /></td>
        <td><input data-name="SKU" class="form-control" placeholder="SOFA-BR-L" /></td>
        <td><input data-name="PriceAdjustment" class="form-control" type="number" step="1" value="0" /></td>
        <td><input data-name="StockQuantity" class="form-control" type="number" min="0" value="0" /></td>
        <td>
            <input data-name="IsActive" class="form-check-input" type="checkbox" value="true" checked />
            <input data-name="IsActiveHidden" type="hidden" value="false" />
        </td>
        <td class="text-end pe-3">
            <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeVariantRow(this)">
                <i class="bi bi-trash"></i>
            </button>
        </td>
    </tr>
</template>

<script>
    let variantIndex = 1;

    function addVariantRow() {
        const template = document.getElementById('variantRowTemplate');
        const row = template.content.firstElementChild.cloneNode(true);

        row.querySelectorAll('[data-name]').forEach(input => {
            const field = input.dataset.name;
            if (field === 'IsActiveHidden') {
                input.name = `variants[${variantIndex}].IsActive`;
                return;
            }
            input.name = `variants[${variantIndex}].${field}`;
        });

        document.getElementById('variantRows').appendChild(row);
        variantIndex++;
    }

    function removeVariantRow(button) {
        button.closest('tr')?.remove();
    }
</script>

<style>
    .card {
        border-radius: 1rem;
    }

    #variantTable th {
        font-size: 0.72rem;
        text-transform: uppercase;
        color: #6c757d;
    }

    .validation-summary-valid {
        display: none;
    }
</style>
