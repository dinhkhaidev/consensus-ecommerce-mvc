@model IEnumerable<WebActionResults.Models.Product>
@{
    ViewData["Title"] = "Products";
    var searchTerm = ViewData["SearchTerm"] as string;
    var currentPage = ViewData["CurrentPage"] is int currentPageValue ? currentPageValue : 1;
    var totalPages = ViewData["TotalPages"] is int totalPagesValue ? totalPagesValue : 1;
    var totalCount = ViewData["TotalCount"] is int totalCountValue ? totalCountValue : 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Products</h4>
        <p class="text-muted mb-0">@totalCount products in catalog</p>
    </div>
    <a asp-area="Admin" asp-controller="AdminProduct" asp-action="Create" class="btn btn-primary rounded-pill px-4">
        <i class="bi bi-plus-lg me-2"></i>Add Product
    </a>
</div>

<!-- Search & Filters -->
<div class="card border-0 shadow-sm mb-4" style="border-radius: 1rem;">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-8">
                <label class="form-label small text-muted text-uppercase">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" value="@searchTerm" class="form-control border-start-0 ps-0"
                           placeholder="Search products by name...">
                </div>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100 rounded-pill">
                    <i class="bi bi-search me-2"></i>Search
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Products Table -->
<div class="card border-0 shadow-sm" style="border-radius: 1rem;">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="border-0 py-3 ps-4 text-uppercase" style="font-size: 0.7rem;">Image</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Product Name</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Category</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Price</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Stock</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in Model)
                        {
                            var totalStock = product.Variants?.Sum(v => v.StockQuantity) ?? 0;
                            <tr class="border-bottom">
                                <td class="py-3 ps-4">
                                    @if (product.Images?.Any() == true)
                                    {
                                        var mainImage = product.Images.FirstOrDefault(i => i.IsMain)?.ImageUrl ?? product.Images.First().ImageUrl;
                                        <img src="@mainImage" alt="@product.ProductName" class="rounded-3" style="width: 60px; height: 60px; object-fit: cover;">
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                                            <i class="bi bi-image text-secondary"></i>
                                        </div>
                                    }
                                </td>
                                <td class="py-3">
                                    <a asp-area="Admin" asp-controller="AdminProduct" asp-action="Details" asp-route-id="@product.Id"
                                       class="text-decoration-none fw-semibold">@product.ProductName</a>
                                    @if (!string.IsNullOrEmpty(product.QuantityPerUnit))
                                    {
                                        <p class="text-muted small mb-0">@product.QuantityPerUnit</p>
                                    }
                                </td>
                                <td class="py-3">
                                    <span class="badge bg-light text-dark">@product.Category?.CategoryName</span>
                                </td>
                                <td class="py-3 fw-semibold text-primary">@product.UnitPrice.ToString("N0") VND</td>
                                <td class="py-3">
                                    @if (product.Variants?.Any() == true)
                                    {
                                        var variantCount = product.Variants.Count();
                                        <span class="badge bg-@(totalStock > 0 ? "success" : "danger") rounded-pill">
                                            @totalStock in stock (@variantCount variants)
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary rounded-pill">N/A</span>
                                    }
                                </td>
                                <td class="py-3">
                                    <div class="d-flex gap-2">
                                        <a asp-area="Admin" asp-controller="AdminProduct" asp-action="Details" asp-route-id="@product.Id"
                                           class="btn btn-sm btn-outline-primary rounded-pill px-3">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a asp-area="Admin" asp-controller="AdminProduct" asp-action="Edit" asp-route-id="@product.Id"
                                           class="btn btn-sm btn-primary rounded-pill px-3">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-area="Admin" asp-controller="AdminProduct" asp-action="Delete" asp-route-id="@product.Id"
                                              method="post" class="d-inline" onsubmit="return confirm('Delete this product?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination -->
            @if (totalPages > 1)
            {
                <div class="card-footer bg-white py-3">
                    <nav>
                        <ul class="pagination justify-content-center mb-0">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-area="Admin" asp-controller="AdminProduct" asp-action="Index"
                                   asp-route-page="@(currentPage - 1)" asp-route-search="@searchTerm">Previous</a>
                            </li>
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(currentPage == i ? "active" : "")">
                                    <a class="page-link" asp-area="Admin" asp-controller="AdminProduct" asp-action="Index"
                                       asp-route-page="@i" asp-route-search="@searchTerm">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-area="Admin" asp-controller="AdminProduct" asp-action="Index"
                                   asp-route-page="@(currentPage + 1)" asp-route-search="@searchTerm">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-box-seam text-muted" style="font-size: 4rem;"></i>
                <h4 class="mt-3 mb-2">No products found</h4>
                <p class="text-muted mb-4">
                    @if (!string.IsNullOrEmpty(searchTerm))
                    {
                        <text>No results for "@searchTerm"</text>
                    }
                    else
                    {
                        <text>Start adding products to your catalog</text>
                    }
                </p>
                <a asp-area="Admin" asp-controller="AdminProduct" asp-action="Create" class="btn btn-primary rounded-pill">
                    <i class="bi bi-plus-lg me-2"></i>Add First Product
                </a>
            </div>
        }
    </div>
</div>

<style>
    .btn.rounded-pill {
        padding-left: 1.25rem;
        padding-right: 1.25rem;
    }

    .page-link {
        border-radius: 50% !important;
        margin: 0 3px;
        min-width: 36px;
        text-align: center;
    }

    .page-item.active .page-link {
        background-color: #d47f31;
        border-color: #d47f31;
    }

    .badge.rounded-pill {
        padding: 0.35em 0.75em;
    }
</style>
