@model WebActionResults.Models.Product
@{
    ViewData["Title"] = Model.ProductName;
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-area="Admin" asp-controller="AdminProduct" asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
        <i class="bi bi-arrow-left"></i>
    </a>
    <div>
        <h4 class="mb-0">@Model.ProductName</h4>
        <small class="text-muted">Product Details</small>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <!-- Main Info -->
    <div class="col-lg-8">
        <!-- Product Images -->
        <div class="card border-0 shadow-sm mb-4" style="border-radius: 1rem;">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0"><i class="bi bi-images me-2 text-primary"></i>Product Images</h5>
            </div>
            <div class="card-body">
                @if (Model.Images?.Any() == true)
                {
                    <div class="row g-3">
                        @foreach (var img in Model.Images.OrderBy(i => i.IsMain ? 0 : 1))
                        {
                            <div class="col-md-3">
                                <div class="position-relative">
                                    <img src="@img.ImageUrl" alt="@img.AltText" class="img-fluid rounded-3" style="width: 100%; height: 150px; object-fit: cover;">
                                    @if (img.IsMain)
                                    {
                                        <span class="position-absolute top-0 start-0 badge bg-primary m-2">Main</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-5 bg-light rounded-3">
                        <i class="bi bi-image text-secondary" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-2 mb-0">No images available</p>
                    </div>
                }
            </div>
        </div>

        <!-- Variants -->
        <div class="card border-0 shadow-sm mb-4" style="border-radius: 1rem;">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-palette me-2 text-primary"></i>Product Variants</h5>
                <span class="badge bg-secondary rounded-pill">@(Model.Variants?.Count() ?? 0) variants</span>
            </div>
            <div class="card-body p-0">
                @if (Model.Variants?.Any() == true)
                {
                    <div class="table-responsive">
                        <table class="table mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="border-0 py-3 ps-4 text-uppercase" style="font-size: 0.7rem;">SKU</th>
                                    <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Color</th>
                                    <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Size</th>
                                    <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Price Adj</th>
                                    <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Stock</th>
                                    <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var variant in Model.Variants)
                                {
                                    <tr class="border-bottom">
                                        <td class="py-3 ps-4">
                                            <code class="small">@variant.SKU</code>
                                        </td>
                                        <td class="py-3">
                                            <div class="d-flex align-items-center gap-2">
                                                @if (!string.IsNullOrEmpty(variant.Color))
                                                {
                                                    <span class="color-dot" style="width: 20px; height: 20px; background: @WebActionResults.Helpers.ColorHelper.ToCssColor(variant.Color); border-radius: 50%; border: 2px solid #ddd;"></span>
                                                    <span>@variant.Color</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </div>
                                        </td>
                                        <td class="py-3">@(variant.Size ?? "-")</td>
                                        <td class="py-3">
                                            @if (variant.PriceAdjustment != 0)
                                            {
                                                <span class="text-@(variant.PriceAdjustment > 0 ? "danger" : "success")">
                                                    @(variant.PriceAdjustment > 0 ? "+" : "")@variant.PriceAdjustment.Value.ToString("N0") VND
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        </td>
                                        <td class="py-3">
                                            <span class="fw-semibold @(variant.StockQuantity > 0 ? "text-success" : "text-danger")">
                                                @variant.StockQuantity
                                            </span>
                                        </td>
                                        <td class="py-3">
                                            @if (variant.IsActive && variant.StockQuantity > 0)
                                            {
                                                <span class="badge bg-success rounded-pill">Active</span>
                                            }
                                            else if (variant.StockQuantity <= 0)
                                            {
                                                <span class="badge bg-danger rounded-pill">Out of Stock</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary rounded-pill">Inactive</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5">
                        <i class="bi bi-box-seam text-muted" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-2 mb-0">No variants available</p>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Sidebar Info -->
    <div class="col-lg-4">
        <!-- Basic Info -->
        <div class="card border-0 shadow-sm mb-4" style="border-radius: 1rem;">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0"><i class="bi bi-info-circle me-2 text-primary"></i>Basic Information</h5>
            </div>
            <div class="card-body">
                <table class="table table-borderless mb-0">
                    <tr>
                        <td class="text-muted ps-0" style="width: 140px;">Product ID</td>
                        <td class="fw-semibold">#@Model.Id</td>
                    </tr>
                    <tr>
                        <td class="text-muted ps-0">Product Name</td>
                        <td class="fw-semibold">@Model.ProductName</td>
                    </tr>
                    <tr>
                        <td class="text-muted ps-0">Category</td>
                        <td><span class="badge bg-light text-dark">@Model.Category?.CategoryName</span></td>
                    </tr>
                    <tr>
                        <td class="text-muted ps-0">Supplier</td>
                        <td>@Model.Supplier?.CompanyName</td>
                    </tr>
                    <tr>
                        <td class="text-muted ps-0">Price</td>
                        <td class="fw-bold text-primary fs-5">@Model.UnitPrice.ToString("N0") VND</td>
                    </tr>
                    <tr>
                        <td class="text-muted ps-0">Description</td>
                        <td>@(string.IsNullOrEmpty(Model.QuantityPerUnit) ? "-" : Model.QuantityPerUnit)</td>
                    </tr>
                    <tr>
                        <td class="text-muted ps-0">Status</td>
                        <td>
                            @if (Model.Discontinued)
                            {
                                <span class="badge bg-danger rounded-pill">Discontinued</span>
                            }
                            else
                            {
                                <span class="badge bg-success rounded-pill">Active</span>
                            }
                        </td>
                    </tr>
                </table>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="card border-0 shadow-sm" style="border-radius: 1rem;">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0"><i class="bi bi-lightning me-2 text-warning"></i>Quick Actions</h5>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-area="Admin" asp-controller="AdminProduct" asp-action="Edit" asp-route-id="@Model.Id"
                       class="btn btn-primary rounded-pill">
                        <i class="bi bi-pencil me-2"></i>Edit Product
                    </a>
                    <form asp-area="Admin" asp-controller="AdminProduct" asp-action="Delete" asp-route-id="@Model.Id" method="post"
                          onsubmit="return confirm('Are you sure you want to delete this product?');">
                        <button type="submit" class="btn btn-outline-danger rounded-pill w-100">
                            <i class="bi bi-trash me-2"></i>Delete Product
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .color-dot {
        display: inline-block;
        box-shadow: inset 0 0 0 1px rgba(0,0,0,0.1);
    }

    code {
        background: #f0f0f0;
        padding: 0.15em 0.4em;
        border-radius: 0.25rem;
    }

    .btn.rounded-pill {
        padding-left: 1.5rem;
        padding-right: 1.5rem;
    }
</style>