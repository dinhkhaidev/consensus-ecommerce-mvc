@model IEnumerable<WebActionResults.Data.Entities.Coupon>
@{
    ViewData["Title"] = "Coupons";
    var searchTerm = ViewData["SearchTerm"] as string;
    var currentPage = ViewData["CurrentPage"] != null ? (int)ViewData["CurrentPage"] : 1;
    var totalPages = ViewData["TotalPages"] != null ? (int)ViewData["TotalPages"] : 1;
    var totalCount = ViewData["TotalCount"] != null ? (int)ViewData["TotalCount"] : 0;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Coupons</h4>
        <p class="text-muted mb-0">@totalCount coupons in system</p>
    </div>
    <a asp-area="Admin" asp-controller="AdminCoupon" asp-action="Create" class="btn btn-primary rounded-pill px-4">
        <i class="bi bi-plus-lg me-2"></i>Add Coupon
    </a>
</div>

<div class="card border-0 shadow-sm mb-4" style="border-radius: 1rem;">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-8">
                <label class="form-label small text-muted text-uppercase">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" value="@searchTerm" class="form-control border-start-0 ps-0"
                           placeholder="Search by code or description...">
                </div>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100 rounded-pill">
                    <i class="bi bi-search me-2"></i>Search
                </button>
            </div>
        </form>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 1rem;">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="border-0 py-3 ps-4 text-uppercase" style="font-size: 0.7rem;">Code</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Description</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Discount</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Min Order</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Valid Period</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Usage</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Status</th>
                            <th class="border-0 py-3 text-uppercase" style="font-size: 0.7rem;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var coupon in Model)
                        {
                            var isActive = coupon.IsActive && coupon.StartDate <= DateTime.UtcNow && coupon.EndDate >= DateTime.UtcNow;
                            var isExpired = coupon.EndDate < DateTime.UtcNow;
                            <tr class="border-bottom">
                                <td class="py-3 ps-4">
                                    <span class="fw-bold text-primary">@coupon.Code</span>
                                </td>
                                <td class="py-3">@coupon.Description</td>
                                <td class="py-3 fw-semibold">
                                    @if (coupon.Type == WebActionResults.Data.Entities.CouponType.Percentage)
                                    {
                                        <span class="text-success">@coupon.DiscountValue%</span>
                                    }
                                    else if (coupon.Type == WebActionResults.Data.Entities.CouponType.FixedAmount)
                                    {
                                        <span class="text-success">@coupon.DiscountValue.ToString("N0") VND</span>
                                    }
                                    else
                                    {
                                        <span class="text-success">Free Shipping</span>
                                    }
                                </td>
                                <td class="py-3">@(coupon.MinOrderAmount?.ToString("N0") ?? "0") VND</td>
                                <td class="py-3">
                                    <small class="text-muted">
                                        @coupon.StartDate.ToString("MMM dd") - @coupon.EndDate.ToString("MMM dd, yyyy")
                                    </small>
                                </td>
                                <td class="py-3">
                                    <span class="badge bg-@(coupon.UsedCount >= coupon.UsageLimit ? "danger" : "info") rounded-pill">
                                        @coupon.UsedCount / @coupon.UsageLimit
                                    </span>
                                </td>
                                <td class="py-3">
                                    @if (isExpired)
                                    {
                                        <span class="badge bg-secondary rounded-pill">Expired</span>
                                    }
                                    else if (isActive)
                                    {
                                        <span class="badge bg-success rounded-pill">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning rounded-pill">Inactive</span>
                                    }
                                </td>
                                <td class="py-3">
                                    <div class="d-flex gap-2">
                                        <a asp-area="Admin" asp-controller="AdminCoupon" asp-action="Edit" asp-route-id="@coupon.Id"
                                           class="btn btn-sm btn-primary rounded-pill px-3">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-area="Admin" asp-controller="AdminCoupon" asp-action="Delete" asp-route-id="@coupon.Id"
                                              method="post" class="d-inline" onsubmit="return confirm('Delete this coupon?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger rounded-pill px-3">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (totalPages > 1)
            {
                <div class="card-footer bg-white py-3">
                    <nav>
                        <ul class="pagination justify-content-center mb-0">
                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link" asp-area="Admin" asp-controller="AdminCoupon" asp-action="Index"
                                   asp-route-page="@(currentPage - 1)" asp-route-search="@searchTerm">Previous</a>
                            </li>
                            @for (int i = 1; i <= totalPages; i++)
                            {
                                <li class="page-item @(currentPage == i ? "active" : "")">
                                    <a class="page-link" asp-area="Admin" asp-controller="AdminCoupon" asp-action="Index"
                                       asp-route-page="@i" asp-route-search="@searchTerm">@i</a>
                                </li>
                            }
                            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                <a class="page-link" asp-area="Admin" asp-controller="AdminCoupon" asp-action="Index"
                                   asp-route-page="@(currentPage + 1)" asp-route-search="@searchTerm">Next</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-ticket-perforated text-muted" style="font-size: 4rem;"></i>
                <h4 class="mt-3 mb-2">No coupons found</h4>
                <p class="text-muted mb-4">Start creating discount coupons</p>
                <a asp-area="Admin" asp-controller="AdminCoupon" asp-action="Create" class="btn btn-primary rounded-pill">
                    <i class="bi bi-plus-lg me-2"></i>Create First Coupon
                </a>
            </div>
        }
    </div>
</div>

<style>
    .btn.rounded-pill { padding-left: 1.25rem; padding-right: 1.25rem; }
    .page-link { border-radius: 50% !important; margin: 0 3px; min-width: 36px; text-align: center; }
    .page-item.active .page-link { background-color: #d47f31; border-color: #d47f31; }
</style>
