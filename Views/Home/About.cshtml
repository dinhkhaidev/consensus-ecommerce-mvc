@{
    ViewData["Title"] = "About Us";
    var settings = ViewData["WebSettings"] as Dictionary<string, string> ?? new();
    var storeName = settings.GetValueOrDefault("StoreName", "Furnish");
    var footerAbout = settings.GetValueOrDefault("FooterShortAbout", "");
}

<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h1 class="display-5 fw-bold mb-4">About @storeName</h1>
                @if (!string.IsNullOrWhiteSpace(footerAbout))
                {
                    <p class="lead text-muted mb-4">@footerAbout</p>
                }
                <div class="row g-4 mt-3">
                    <div class="col-md-4 text-center">
                        <i class="bi bi-truck display-4 text-primary mb-3 d-block"></i>
                        <h5 class="fw-bold">Fast Delivery</h5>
                        <p class="text-muted small">We deliver nationwide with care and speed.</p>
                    </div>
                    <div class="col-md-4 text-center">
                        <i class="bi bi-shield-check display-4 text-success mb-3 d-block"></i>
                        <h5 class="fw-bold">Quality Guaranteed</h5>
                        <p class="text-muted small">All products are carefully inspected.</p>
                    </div>
                    <div class="col-md-4 text-center">
                        <i class="bi bi-headset display-4 text-warning mb-3 d-block"></i>
                        <h5 class="fw-bold">24/7 Support</h5>
                        <p class="text-muted small">Our team is here whenever you need help.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
