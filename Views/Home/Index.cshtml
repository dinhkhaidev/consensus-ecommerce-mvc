            if (supportsFinePointer) {
                portal.addEventListener("pointermove", event => {
                    const rect = portal.getBoundingClientRect();
                    const x = (event.clientX - rect.left) / rect.width - 0.5;
                    const y = (event.clientY - rect.top) / rect.height - 0.5;

                    portal.style.setProperty("--portal-tilt-x", `${(-y * 5).toFixed(2)}deg`);
                    portal.style.setProperty("--portal-tilt-y", `${(x * 7).toFixed(2)}deg`);
                    portal.style.setProperty("--portal-depth-x", `${(-x * 12).toFixed(1)}px`);
                    portal.style.setProperty("--portal-depth-y", `${(-y * 12).toFixed(1)}px`);
                    portal.style.setProperty("--portal-glow-x", `${((x + .5) * 100).toFixed(1)}%`);
                    portal.style.setProperty("--portal-glow-y", `${((y + .5) * 100).toFixed(1)}%`);
                });

                portal.addEventListener("pointerleave", () => {
                    portal.style.setProperty("--portal-tilt-x", "0deg");
                    portal.style.setProperty("--portal-tilt-y", "0deg");
                    portal.style.setProperty("--portal-depth-x", "0px");
                    portal.style.setProperty("--portal-depth-y", "0px");
                    portal.style.setProperty("--portal-glow-x", "28%");
                    portal.style.setProperty("--portal-glow-y", "50%");
