            hero.addEventListener("pointermove", event => {
                const activeStage = hero.querySelector(".swiper-slide-active .hero-slide-stage");
                if (!activeStage) return;

                const rect = activeStage.getBoundingClientRect();
                const x = (event.clientX - rect.left) / rect.width - 0.5;
                const y = (event.clientY - rect.top) / rect.height - 0.5;

                activeStage.style.setProperty("--hero-parallax-x", `${(x * 10).toFixed(1)}px`);
                activeStage.style.setProperty("--hero-parallax-y", `${(y * 8).toFixed(1)}px`);
                activeStage.style.setProperty("--hero-copy-x", `${(-x * 4).toFixed(1)}px`);
                activeStage.style.setProperty("--hero-copy-y", `${(-y * 3).toFixed(1)}px`);
                activeStage.style.setProperty("--hero-action-x", `${(-x * 3).toFixed(1)}px`);
                activeStage.style.setProperty("--hero-action-y", `${(-y * 2).toFixed(1)}px`);
            });

            hero.addEventListener("pointerleave", () => {
                hero.querySelectorAll(".hero-slide-stage").forEach(stage => {
                    stage.style.setProperty("--hero-parallax-x", "0px");
                    stage.style.setProperty("--hero-parallax-y", "0px");
                    stage.style.setProperty("--hero-copy-x", "0px");
                    stage.style.setProperty("--hero-copy-y", "0px");
                    stage.style.setProperty("--hero-action-x", "0px");
                    stage.style.setProperty("--hero-action-y", "0px");
                });
            });
        }

        revealTargets.forEach((element, index) => {
            if (element.hasAttribute("data-reveal-item")) {
                element.style.setProperty("--reveal-delay", `${Math.min(index % 8, 5) * 70}ms`);
            }
        });

        updateScrollEffects();
        window.addEventListener("scroll", requestScrollTick, { passive: true });
        window.addEventListener("resize", requestScrollTick);

        if (prefersReducedMotion || !("IntersectionObserver" in window)) {
            revealTargets.forEach(element => element.classList.add("is-visible"));
            return;
        }

        const observer = new IntersectionObserver(entries => {
            entries.forEach(entry => {
                if (!entry.isIntersecting) return;
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
            });
        }, { threshold: 0.16, rootMargin: "0px 0px -8% 0px" });

        revealTargets.forEach(element => observer.observe(element));
    })();
</script>
