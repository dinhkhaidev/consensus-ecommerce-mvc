<script>
    (() => {
        const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        const revealTargets = Array.from(document.querySelectorAll("[data-reveal], [data-reveal-item]"));
        const portal = document.querySelector(".room-portal");
        const progress = document.querySelector(".dashboard-scroll-progress");
        const promo = document.querySelector("[data-promo-parallax]");
        const hero = document.querySelector(".dashboard-hero");
        const supportsFinePointer = window.matchMedia("(hover: hover) and (pointer: fine)").matches;
        const transitionLayer = document.createElement("div");

        transitionLayer.className = "dashboard-room-transition";
        transitionLayer.setAttribute("aria-hidden", "true");
        document.body.appendChild(transitionLayer);

        let ticking = false;

        function updateScrollEffects() {
            ticking = false;

            const scrollTop = window.scrollY || document.documentElement.scrollTop;
            const maxScroll = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
            const ratio = Math.min(1, Math.max(0, scrollTop / maxScroll));

            if (progress) {
                progress.style.setProperty("--scroll-progress", ratio.toFixed(4));
