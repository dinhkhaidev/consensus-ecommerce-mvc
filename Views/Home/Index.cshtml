                const centerOffset = (rect.top + rect.height / 2) - window.innerHeight / 2;
                const shift = Math.max(-34, Math.min(34, centerOffset * -0.045));
                promo.style.setProperty("--promo-shift", `${shift.toFixed(1)}px`);
