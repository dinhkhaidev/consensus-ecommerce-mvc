@{
    ViewData["Title"] = "Furnish - Premium Furniture Store";
    var featuredProducts = ViewData["FeaturedProducts"] as List<Product>;
    var categories = ViewData["Categories"] as List<Category>;
    var testimonials = ViewData["Testimonials"] as List<WebActionResults.ViewModels.ReviewViewModel> ?? new();
    var settings = ViewData["WebSettings"] as Dictionary<string, string> ?? new();
}
@{
    var isVietnamese = localizer.CurrentLanguage == "vi";
    string SettingOrDefault(string key, string fallback)
    {
        var value = settings.GetValueOrDefault(key, "");
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }

    var siteTitle = settings.GetValueOrDefault("SiteTitle", "Furnish - Premium Furniture Store");
    var siteDescription = settings.GetValueOrDefault("SiteDescription", "");
    var heroTitle = SettingOrDefault("HeroTitle", "20% OFF");
    var heroSubtitle = SettingOrDefault("HeroSubtitle", "Comfy Sofa Home-Office");
    var heroDescription = SettingOrDefault("HeroDescription", "Premium comfort for your modern workspace");
    var feature1Title = SettingOrDefault("Feature1Title", isVietnamese ? "Giao hàng nhanh" : "Fast Delivery");
    var feature1Desc = SettingOrDefault("Feature1Desc", isVietnamese ? "Đóng gói kỹ, giao tận nhà theo lịch hẹn." : "Carefully packed and delivered to your door.");
    var feature2Title = SettingOrDefault("Feature2Title", isVietnamese ? "Thanh toán an toàn" : "Secure Payment");
    var feature2Desc = SettingOrDefault("Feature2Desc", isVietnamese ? "Thông tin được bảo vệ trong toàn bộ quy trình." : "Protected checkout from cart to confirmation.");
    var feature3Title = SettingOrDefault("Feature3Title", isVietnamese ? "Đổi trả rõ ràng" : "Easy Returns");
    var feature3Desc = SettingOrDefault("Feature3Desc", isVietnamese ? "Chính sách minh bạch, hỗ trợ xử lý nhanh." : "Clear policy with responsive return support.");
    var feature4Title = SettingOrDefault("Feature4Title", isVietnamese ? "Tư vấn tận tâm" : "Dedicated Support");
    var feature4Desc = SettingOrDefault("Feature4Desc", isVietnamese ? "Đội ngũ hỗ trợ chọn nội thất hợp không gian." : "Helpful guidance for every room and style.");
    var newsletterTitle = SettingOrDefault("NewsletterTitle", isVietnamese ? "Đăng ký nhận bản tin" : "Subscribe to our Newsletter");
    var newsletterDesc = SettingOrDefault("NewsletterDesc", isVietnamese ? "Nhập địa chỉ email của bạn để nhận ưu đãi và cảm hứng nội thất mới nhất." : "Enter your email for exclusive deals and interior inspiration.");
    var contactEmail = settings.GetValueOrDefault("ContactEmail", "info@furnish.com");
    var contactPhone = settings.GetValueOrDefault("ContactPhone", "");
    var address = settings.GetValueOrDefault("Address", "");
}

<!-- Hero Slider Section -->
<section class="py-lg-8 pt-6">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xxl-8 col-12">
                <div class="swiper-container swiper swiper-pagination-light" id="heroSlider"
                    data-pagination-type="" data-speed="800" data-space-between="100" data-pagination="true"
                    data-navigation="true" data-autoplay="true" data-effect="slide" data-autoplay-delay="5000"
                    data-breakpoints='{"480": {"slidesPerView": 2}, "768": {"slidesPerView": 1}, "1024": {"slidesPerView": 1}}'>
                    <div class="swiper-wrapper">
                        <div class="swiper-slide px-md-8">
                            <div class="position-relative text-center">
                                <img src="/assets/images/slider/slider-img-2.png" alt="" class="img-fluid my-5 my-lg-0">
                                <div class="hero-slide-copy text-center position-absolute top-0 start-0 w-100 px-3">
                                    <h1 class="fs-1 fst-italic text-secondary">@heroTitle</h1>
                                    <h2 class="hero-slide-title">@heroSubtitle</h2>
                                </div>
                                <div class="position-absolute top-md-65 top-75 start-50 translate-middle-x mt-lg-9">
                                    <p class="d-none d-lg-block mb-1">@heroDescription</p>
                                    <a asp-controller="Product" asp-action="Index" class="btn btn-primary">@settings.GetValueOrDefault("HeroCtaText", localizer.Get("Shop"))</a>
                                </div>
                            </div>
                        </div>
                        <div class="swiper-slide px-md-8">
                            <div class="position-relative text-center">
                                <img src="/assets/images/slider/slider-img-1.png" alt="" class="img-fluid my-5 my-lg-0">
                                <div class="hero-slide-copy text-center position-absolute top-0 start-0 w-100 px-3">
                                    <h1 class="fs-1 fst-italic text-success">@localizer.Get("NewArrivals")</h1>
                                    <h2 class="hero-slide-title">@localizer.Get("ExchangeOldFurniture")</h2>
                                </div>
                                <div class="position-absolute top-md-65 top-75 start-50 translate-middle-x mt-lg-9">
                                    <p class="d-none d-lg-block mb-1">@localizer.Get("SaveUpTo100")</p>
                                    <a asp-controller="Product" asp-action="Index" class="btn btn-success">@localizer.Get("Explore")</a>
                                </div>
                            </div>
                        </div>
                        <div class="swiper-slide px-md-8">
                            <div class="position-relative text-center">
                                <img src="/assets/images/slider/slider-img-3.png" alt="" class="img-fluid my-5 my-lg-0">
                                <div class="hero-slide-copy text-center position-absolute top-0 start-0 w-100 px-3">
                                    <h1 class="fs-1 fst-italic text-warning">@localizer.Get("PremiumCollection")</h1>
                                    <h2 class="hero-slide-title">@localizer.Get("RoyalComfortSofa")</h2>
                                </div>
                                <div class="position-absolute top-md-65 top-75 start-50 translate-middle-x mt-lg-9">
                                    <p class="d-none d-lg-block mb-1">@localizer.Get("TimelessCraftsmanship")</p>
                                    <a asp-controller="Product" asp-action="Index" class="btn btn-warning text-dark">@localizer.Get("ViewCollection")</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="swiper-navigation mb-4">
                        <div class="swiper-button-prev"></div>
                        <div class="swiper-button-next"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Categories Section -->
<section class="py-lg-8 py-5" style="background: #faf9f7;">
    <div class="container">
        <div class="row mb-5">
            <div class="col-12 text-center">
                <h2 class="display-5 fw-bold mb-2">@localizer.Get("ShopbyCategory")</h2>
                <p class="text-muted">@localizer.Get("FindPerfectFurniture")</p>
            </div>
        </div>
        <div class="row g-4">
            @if (categories != null && categories.Any())
            {
                foreach (var category in categories.Take(6))
                {
                    var iconClass = "bi-folder";

                    if (category.CategoryName.Contains("Living", StringComparison.OrdinalIgnoreCase))
                    {
                        iconClass = "bi-house-door";
                    }
                    else if (category.CategoryName.Contains("Office", StringComparison.OrdinalIgnoreCase))
                    {
                        iconClass = "bi-laptop";
                    }
                    else if (category.CategoryName.Contains("Bed", StringComparison.OrdinalIgnoreCase))
                    {
                        iconClass = "bi-moon";
                    }
                    else if (category.CategoryName.Contains("Dining", StringComparison.OrdinalIgnoreCase))
                    {
                        iconClass = "bi-cup-hot";
                    }
                    else if (category.CategoryName.Contains("Decor", StringComparison.OrdinalIgnoreCase))
                    {
                        iconClass = "bi-flower1";
                    }
                    else if (category.CategoryName.Contains("Outdoor", StringComparison.OrdinalIgnoreCase))
                    {
                        iconClass = "bi-sun";
                    }

                    <div class="col-6 col-md-4 col-lg-3">
                        <a asp-controller="Product" asp-action="Index" asp-route-categoryId="@category.Id" class="text-decoration-none">
                            <div class="card category-card h-100 border-0 shadow-sm text-center hover-lift">
                                <div class="card-body d-flex flex-column justify-content-center align-items-center py-5">
                                    <span class="dashboard-category-icon mb-3">
                                        <i class="bi @iconClass"></i>
                                    </span>
                                    <h5 class="card-title mb-2">@category.CategoryName</h5>
                                    <p class="text-muted small mb-0">@category.ProductCount @localizer.Get("Products")</p>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- Our Favourite Collection Section -->
@if (featuredProducts != null && featuredProducts.Any())
{
    <section class="py-lg-10 mx-3 mx-lg-0 bg-white">
        <div class="container">
            <div class="row mb-md-8 mb-4">
                <div class="col-lg-12 mb-8">
                    <div class="d-flex flex-column flex-md-row align-items-md-end justify-content-md-between gap-4">
                        <div class="col-sm-5">
                            <h2 class="display-4">@localizer.Get("OurFavouriteCollection")</h2>
                            <p class="mb-0 lead">@localizer.Get("InspiredByLife")</p>
                        </div>
                    </div>
                </div>
                <div class="col-lg-12">
                    <div class="swiper-container swiper" id="swiper-featured"
                        data-pagination-type="bullets" data-speed="400" data-space-between="30"
                        data-pagination="true" data-navigation="false" data-autoplay="false" data-effect="slide"
                        data-autoplay-delay="3000"
                        data-breakpoints='{"480": {"slidesPerView": 2}, "768": {"slidesPerView": 3}, "1024": {"slidesPerView": 3}}'>
                        <div class="swiper-wrapper pb-10">
                            @foreach (var product in featuredProducts)
                            {
                                var imgNum = (product.Id - 1) % 8 + 1;
                                var imgUrl = $"/assets/images/product-img-{imgNum}.jpg";

                                <div class="swiper-slide">
                                    <div>
                                        <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id">
                                            <img src="@imgUrl" alt="@product.ProductName" class="img-fluid" loading="lazy"
                                                 onerror="this.src='/assets/images/product-img-1.jpg'">
                                        </a>
                                        <div class="text-center">
                                            <h3 class="mt-3 h5">
                                                <a asp-controller="Product" asp-action="Details" asp-route-id="@product.Id"
                                                   class="text-decoration-none text-dark">@product.ProductName</a>
                                            </h3>
                                            <div class="">
                                                <span class="fw-semibold">@product.UnitPrice.ToString("N0") VND</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="swiper-pagination mb-3"></div>
                        <div class="swiper-navigation position-absolute start-50 translate-middle-x bottom-0 mb-4 d-none d-lg-block">
                            <div class="swiper-button-prev" id="slide1"></div>
                            <div class="swiper-button-next" id="slide2"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<!-- Promo Banner Section -->
<section class="py-lg-11 py-6 position-relative"
         style="background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/assets/images/couch-with-cushions-glass-table.jpg') center/cover no-repeat;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center text-white">
                <span class="badge dashboard-badge px-4 py-2 mb-3">@localizer.Get("LimitedTimeOffer")</span>
                <h2 class="display-4 fw-bold mb-3">@localizer.Get("Get25PercentOff")</h2>
                <p class="lead mb-4 opacity-75">@localizer.Get("TransformYourSpace")</p>
                <a asp-controller="Product" asp-action="Index" class="btn dashboard-btn-light btn-lg px-5">@localizer.Get("ShopNow")</a>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="dashboard-features py-lg-8 py-5 bg-white">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-3 col-6">
                <div class="dashboard-feature-item h-100">
                    <span class="dashboard-feature-icon" title="@feature1Title" aria-label="@feature1Title">
                        <i class="bi bi-truck"></i>
                    </span>
                    <h6 class="fw-bold mb-1">@feature1Title</h6>
                    <p class="text-muted small mb-0">@feature1Desc</p>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="dashboard-feature-item h-100">
                    <span class="dashboard-feature-icon" title="@feature2Title" aria-label="@feature2Title">
                        <i class="bi bi-shield-check"></i>
                    </span>
                    <h6 class="fw-bold mb-1">@feature2Title</h6>
                    <p class="text-muted small mb-0">@feature2Desc</p>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="dashboard-feature-item h-100">
                    <span class="dashboard-feature-icon" title="@feature3Title" aria-label="@feature3Title">
                        <i class="bi bi-arrow-repeat"></i>
                    </span>
                    <h6 class="fw-bold mb-1">@feature3Title</h6>
                    <p class="text-muted small mb-0">@feature3Desc</p>
                </div>
            </div>
            <div class="col-md-3 col-6">
                <div class="dashboard-feature-item h-100">
                    <span class="dashboard-feature-icon" title="@feature4Title" aria-label="@feature4Title">
                        <i class="bi bi-headset"></i>
                    </span>
                    <h6 class="fw-bold mb-1">@feature4Title</h6>
                    <p class="text-muted small mb-0">@feature4Desc</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Testimonials Section -->
<section class="py-lg-10 py-5" style="background: #faf9f7;">
    <div class="container">
        <div class="row mb-5">
            <div class="col-12 text-center">
                <h2 class="display-5 fw-bold mb-2">@localizer.Get("WhatOurCustomersSay")</h2>
                <p class="text-muted">@localizer.Get("TrustedByThousands")</p>
            </div>
        </div>
        <div class="row g-4">
            @foreach (var testimonial in testimonials)
            {
                var avatarUrl = !string.IsNullOrWhiteSpace(testimonial.UserAvatar)
                    ? testimonial.UserAvatar
                    : $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(testimonial.UserName)}&background=ecebe9&color=211f1c&size=96";

                <div class="col-md-4">
                    <div class="card testimonial-card h-100 border-0 shadow-sm">
                        <div class="card-body testimonial-card-body text-center">
                            <div class="testimonial-content">
                                <span class="testimonial-quote-mark" aria-hidden="true">“</span>
                                <p class="card-text fst-italic text-muted mb-0">"@testimonial.Comment"</p>
                            </div>
                            <div class="testimonial-user mt-auto">
                                <img src="@avatarUrl" alt="@testimonial.UserName" class="rounded-circle customer-say-avatar"
                                     onerror="this.src='https://ui-avatars.com/api/?name=@Uri.EscapeDataString(testimonial.UserName)&background=ecebe9&color=211f1c&size=96';">
                                <div class="testimonial-user-meta">
                                    <strong>@testimonial.UserName</strong>
                                    <small class="text-muted d-block">@testimonial.CreatedAt.ToString("dd/MM/yyyy")</small>
                                    <div class="dashboard-rating mt-2" aria-label="@testimonial.Rating/5">
                                        @for (var i = 1; i <= 5; i++)
                                        {
                                            var isFilled = i <= testimonial.Rating;
                                            <i class="bi @(isFilled ? "bi-star-fill is-filled" : "bi-star is-empty")"></i>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Newsletter Section -->
<section class="dashboard-newsletter py-lg-10 py-5">
    <div class="container">
        <div class="row justify-content-center mx-lg-10">
            <div class="col-lg-8 text-center">
                <h2 class="mb-3">@newsletterTitle</h2>
                <p class="text-muted mb-5">@newsletterDesc</p>
                <form class="d-flex justify-content-center gap-2 flex-column flex-sm-row">
                    <input type="email" class="form-control form-control-lg w-lg-50 w-100 dashboard-newsletter-input" placeholder="@localizer.Get("EnterYourEmail")" required>
                    <button type="submit" class="btn dashboard-btn-dark btn-lg px-4">
                        <i class="bi bi-send me-2"></i>@localizer.Get("Subscribe")
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>

<style>
    .dashboard-kicker {
        color: #5f5a54 !important;
        letter-spacing: 0.01em;
    }

    .dashboard-kicker-soft {
        color: #7d766e !important;
    }

    .dashboard-kicker-deep {
        color: #22201d !important;
    }

    .dashboard-btn-dark,
    .dashboard-btn-outline,
    .dashboard-btn-light {
        border-radius: 999px;
        font-weight: 700;
        letter-spacing: 0.01em;
        padding-inline: 1.35rem;
    }

    .dashboard-btn-dark {
        color: #fff;
        border-color: #161616;
        background: #161616;
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.16);
    }

    .dashboard-btn-dark:hover,
    .dashboard-btn-dark:focus {
        color: #fff;
        border-color: #34302c;
        background: #34302c;
    }

    .dashboard-btn-outline {
        color: #161616;
        border-color: rgba(22, 22, 22, 0.45);
        background: rgba(255, 255, 255, 0.72);
        backdrop-filter: blur(8px);
    }

    .dashboard-btn-outline:hover,
    .dashboard-btn-outline:focus {
        color: #fff;
        border-color: #161616;
        background: #161616;
    }

    .dashboard-btn-light {
        color: #161616;
        border-color: #fff;
        background: #fff;
    }

    .dashboard-btn-light:hover,
    .dashboard-btn-light:focus {
        color: #fff;
        border-color: #161616;
        background: #161616;
    }

    .dashboard-badge {
        color: #171717;
        border: 1px solid rgba(255, 255, 255, 0.5);
        background: rgba(255, 255, 255, 0.82);
        backdrop-filter: blur(10px);
    }

    .dashboard-category-icon {
        width: 72px;
        height: 72px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(24, 24, 24, 0.08);
        border-radius: 50%;
        color: #272421;
        background: radial-gradient(circle at 35% 25%, rgba(255, 255, 255, 0.95), rgba(236, 233, 228, 0.88));
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8), 0 16px 34px rgba(31, 29, 26, 0.08);
    }

    .dashboard-category-icon i {
        font-size: 2rem;
    }

    .dashboard-features {
        border-top: 1px solid rgba(24, 24, 24, 0.06);
        border-bottom: 1px solid rgba(24, 24, 24, 0.06);
    }

    .dashboard-feature-item {
        min-height: 190px;
        padding: 1.35rem 1rem;
        text-align: center;
        border: 1px solid rgba(24, 24, 24, 0.08);
        border-radius: 18px;
        background: linear-gradient(180deg, #fff, #fbfaf8);
        box-shadow: 0 16px 36px rgba(31, 29, 26, 0.055);
        transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
    }

    .dashboard-feature-item:hover {
        transform: translateY(-4px);
        border-color: rgba(24, 24, 24, 0.16);
        box-shadow: 0 22px 44px rgba(31, 29, 26, 0.09);
    }

    .dashboard-feature-icon {
        width: 58px;
        height: 58px;
        margin: 0 auto 1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 18px;
        color: #191817;
        background: #f0ede8;
        box-shadow: inset 0 0 0 1px rgba(24, 24, 24, 0.07);
    }

    .dashboard-feature-icon i {
        font-size: 1.7rem;
        line-height: 1;
    }

    .testimonial-card {
        min-height: 340px;
        padding: 1.5rem;
        overflow: hidden;
        border: 1px solid rgba(24, 24, 24, 0.075) !important;
        border-radius: 18px;
        background:
            linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(250, 249, 247, 0.96)),
            radial-gradient(circle at 12% 8%, rgba(138, 129, 120, 0.13), transparent 30%);
        box-shadow: 0 20px 48px rgba(31, 29, 26, 0.075) !important;
        transition: transform 0.24s ease, box-shadow 0.24s ease, border-color 0.24s ease;
    }

    .testimonial-card:hover {
        transform: translateY(-6px);
        border-color: rgba(24, 24, 24, 0.13) !important;
        box-shadow: 0 28px 62px rgba(31, 29, 26, 0.11) !important;
    }

    .testimonial-card-body {
        min-height: 100%;
        padding: 0;
        display: flex;
        flex-direction: column;
    }

    .dashboard-rating {
        display: inline-flex;
        justify-content: flex-start;
        gap: 0.12rem;
        font-size: 0.82rem;
        line-height: 1;
    }

    .dashboard-rating .is-filled {
        color: #c99a2e;
    }

    .dashboard-rating .is-empty {
        color: #d6d0c8;
    }

    .testimonial-content {
        position: relative;
        min-height: 148px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.4rem 0.3rem 1.5rem;
    }

    .testimonial-quote-mark {
        position: absolute;
        top: -0.45rem;
        left: 0;
        color: rgba(33, 31, 28, 0.08);
        font-family: Georgia, "Times New Roman", serif;
        font-size: 5.8rem;
        font-style: normal;
        line-height: 1;
        pointer-events: none;
    }

    .testimonial-content .card-text {
        display: -webkit-box;
        overflow: hidden;
        -webkit-line-clamp: 4;
        -webkit-box-orient: vertical;
        color: #5d5751 !important;
        font-size: 1rem;
        line-height: 1.72;
        position: relative;
        z-index: 1;
    }

    .testimonial-user {
        margin: 0 -0.25rem -0.25rem;
        padding: 1.05rem 1.1rem;
        border-top: 1px solid rgba(24, 24, 24, 0.08);
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 1rem;
        text-align: left;
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.72);
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.8);
    }

    .dashboard-newsletter {
        background: #fff;
        border-top: 1px solid rgba(24, 24, 24, 0.06);
    }

    .dashboard-newsletter h2 {
        font-size: clamp(2rem, 3vw, 3rem);
        font-weight: 500;
        letter-spacing: 0;
    }

    .dashboard-newsletter-input {
        max-width: 430px;
        border-color: rgba(24, 24, 24, 0.16);
        border-radius: 999px;
        padding-inline: 1.25rem;
    }

    /* Swiper */
    .swiper {
        width: 100%;
        overflow: hidden;
        position: relative;
    }

    .swiper-wrapper {
        display: flex;
        flex-direction: row;
        box-sizing: border-box;
    }

    .swiper-slide {
        flex-shrink: 0;
        height: auto;
        display: block;
    }

    .hero-slide-copy {
        z-index: 2;
    }

    .hero-slide-title {
        max-width: 520px;
        margin: 0 auto;
        font-size: 3rem;
        font-weight: 400;
        line-height: 1.05;
    }

