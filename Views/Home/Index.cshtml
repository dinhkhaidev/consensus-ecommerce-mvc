    .room-portal::after {
        content: "";
        position: absolute;
        inset: -2px;
        z-index: -1;
        opacity: 0;
        border-radius: inherit;
        background:
            radial-gradient(circle at 28% 50%, rgba(255, 238, 210, 0.34), transparent 28%),
