@model WebActionResults.Models.Product

@{
    var formAction = ViewData["FormAction"] as string ?? "Create";
    var submitText = ViewData["SubmitText"] as string ?? "Save";
    var showProductId = ViewData["ShowProductId"] as bool? ?? false;
}

<div class="panel-card form-card">
    <form asp-action="@formAction" method="post" novalidate>
        @if (showProductId)
        {
            <input type="hidden" asp-for="Id" />
        }

        <div asp-validation-summary="All" class="alert alert-warning validation-summary-box" role="alert"></div>

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="ProductName" class="form-label"></label>
                <input asp-for="ProductName" class="form-control" placeholder="Enter product name" />
                <span asp-validation-for="ProductName" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="Id" class="form-label"></label>
                <select asp-for="Id" class="form-select" asp-items="ViewBag.Categories"></select>
                <span asp-validation-for="Category.Id" class="text-danger"></span>
            </div>

            <div class="col-md-6">
                <label asp-for="QuantityPerUnit" class="form-label"></label>
                <input asp-for="QuantityPerUnit" class="form-control" placeholder="Example: 12 boxes" />
                <span asp-validation-for="QuantityPerUnit" class="text-danger"></span>
            </div>

            <div class="col-md-3">
                <label asp-for="UnitPrice" class="form-label"></label>
                <input asp-for="UnitPrice" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="UnitPrice" class="text-danger"></span>
            </div>

            <div class="col-md-3 d-flex align-items-center">
                <div class="form-check mt-4">
                    <input asp-for="Discontinued" class="form-check-input" />
                    <label asp-for="Discontinued" class="form-check-label"></label>
                </div>
            </div>
        </div>

        <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-primary">@submitText</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</div>