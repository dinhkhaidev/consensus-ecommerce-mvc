@model WebActionResults.ViewModels.ProductDetailViewModel
@{
    ViewData["Title"] = Model.ProductName + " - Furnish";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var defaultVariant = Model.Variants.FirstOrDefault(v => v.StockQuantity > 0) ?? Model.Variants.FirstOrDefault();
    var displayPrice = Model.UnitPrice + (defaultVariant?.PriceAdjustment ?? 0);
    var galleryImages = Model.Images
        .Concat(Model.Variants.SelectMany(v => v.Images))
        .Where(i => !string.IsNullOrWhiteSpace(i.ImageUrl))
        .GroupBy(i => i.ImageUrl)
        .Select(g => g.First())
        .OrderByDescending(i => i.IsMain)
        .ThenBy(i => i.Id)
        .ToList();
    var mainImage = galleryImages.FirstOrDefault(i => i.IsMain) ?? galleryImages.FirstOrDefault();
}

<!-- Breadcrumb -->
<section class="py-3 bg-light">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none"><i class="bi bi-house me-1"></i>@localizer.Get("Home")</a></li>
                <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index" class="text-decoration-none">@localizer.Get("Products")</a></li>
                @if (!string.IsNullOrEmpty(Model.CategoryName))
                {
                    <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index" class="text-decoration-none">@Model.CategoryName</a></li>
                }
                <li class="breadcrumb-item active" aria-current="page">@Model.ProductName</li>
            </ol>
        </nav>
    </div>
</section>

<!-- Product Detail -->
<section class="py-lg-8 py-5">
    <div class="container">
        <div class="row">
            <!-- Product Images -->
            <div class="col-lg-6 mb-4 mb-lg-0">
                <div class="product-gallery">
                    @if (mainImage != null)
                    {
                        <div class="card border-0 shadow-sm mb-3">
                            <div class="main-image-container product-gallery-main">
                                @if (galleryImages.Count > 1)
                                {
                                    <button type="button" class="gallery-arrow gallery-arrow-prev" aria-label="Previous image" onclick="showGalleryImage(currentGalleryIndex - 1)">
                                        <i class="bi bi-chevron-left"></i>
                                    </button>
                                }

                                <img src="@mainImage.ImageUrl" alt="@(mainImage.AltText ?? Model.ProductName)"
                                     class="img-fluid rounded" id="mainProductImage"
                                     style="max-height: 450px; object-fit: contain;">

                                @if (galleryImages.Count > 1)
                                {
                                    <button type="button" class="gallery-arrow gallery-arrow-next" aria-label="Next image" onclick="showGalleryImage(currentGalleryIndex + 1)">
                                        <i class="bi bi-chevron-right"></i>
                                    </button>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="d-flex align-items-center justify-content-center bg-light rounded" style="min-height: 400px;">
                            <i class="bi bi-image text-secondary" style="font-size: 8rem;"></i>
                        </div>
                    }

                    @if (galleryImages.Count > 1)
                    {
                        <div class="gallery-thumbnails">
                            @for (var i = 0; i < galleryImages.Count; i++)
                            {
                                var img = galleryImages[i];
                                var isActive = img.ImageUrl == mainImage?.ImageUrl;
                                <button type="button"
                                        class="gallery-thumb @(isActive ? "active" : "")"
                                        onclick="showGalleryImage(@i)"
                                        data-gallery-index="@i"
                                        data-image-url="@img.ImageUrl"
                                        data-bs-toggle="tooltip"
                                        title="@(img.AltText ?? Model.ProductName)">
                                    <img src="@img.ImageUrl" alt="@(img.AltText ?? Model.ProductName)" />
                                </button>
                            }
                        </div>
                    }
                </div>

                @if (galleryImages.Any())
                {
                    <script type="application/json" id="productGalleryData">
                        @Html.Raw(System.Text.Json.JsonSerializer.Serialize(galleryImages.Select(i => new
                        {
                            url = i.ImageUrl,
                            alt = i.AltText ?? Model.ProductName
                        })))
                    </script>
                }
            </div>

            <!-- Product Info -->
            <div class="col-lg-6">
                <!-- Category & Title -->
                <div class="mb-3">
                    @if (!string.IsNullOrEmpty(Model.CategoryName))
                    {
                        <span class="badge bg-light text-dark text-uppercase text-xs">
                            <i class="bi bi-tag me-1"></i>@Model.CategoryName
                        </span>
                    }
                </div>
                <h1 class="mb-3">@Model.ProductName</h1>

                <!-- Rating -->
                @if (Model.ReviewCount > 0)
                {
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <div class="text-warning">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="bi @(i <= Math.Round(Model.AverageRating) ? "bi-star-fill" : "bi-star")"></i>
                            }
                        </div>
                        <a href="#reviews" class="text-decoration-none text-muted">
                            (@Model.ReviewCount @localizer.Get("Reviews"))
                        </a>
                    </div>
                }

                <!-- Price -->
                <div class="mb-4">
                    <span class="display-6 fw-bold text-primary" id="productPrice" data-base-price="@Model.UnitPrice">@displayPrice.ToString("N0") VND</span>
                    @if (Model.OriginalPrice.HasValue && Model.OriginalPrice > Model.UnitPrice)
                    {
                        <span class="text-muted text-decoration-line-through ms-2">@Model.OriginalPrice.Value.ToString("N0") VND</span>
                        <span class="badge bg-danger ms-2">-@(((1 - Model.UnitPrice / Model.OriginalPrice.Value) * 100).ToString("0"))%</span>
                    }
                </div>

                @{
                    var webSettings = ViewData["WebSettings"] as Dictionary<string, string> ?? new();
                    var showLowStock = string.Equals(webSettings.GetValueOrDefault("ShowLowStockWarning", "true"), "true", StringComparison.OrdinalIgnoreCase);
                    var lowStockThreshold = int.TryParse(webSettings.GetValueOrDefault("LowStockThreshold", "5"), out var lst) ? lst : 5;
                    var totalStock = Model.Variants.Any() ? Model.Variants.Sum(v => v.StockQuantity) : 0;
                    var returnPolicy = webSettings.GetValueOrDefault("ReturnPolicySummary", "");
                    var returnDays = webSettings.GetValueOrDefault("ReturnWindowDays", "30");
                }

                <!-- Low Stock Warning -->
                @if (showLowStock && totalStock > 0 && totalStock <= lowStockThreshold)
                {
                    <div class="alert alert-warning py-2 px-3 d-flex align-items-center gap-2 mb-3" style="font-size: 0.85rem;">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <span><strong>@localizer.Get("LowStock")!</strong> @string.Format(localizer.Get("OnlyXLeft"), totalStock)</span>
                    </div>
                }

                <!-- Return Policy Badge -->
                @if (!string.IsNullOrWhiteSpace(returnPolicy))
                {
                    <div class="d-flex align-items-center gap-2 mb-3 text-muted small">
                        <i class="bi bi-arrow-repeat text-success"></i>
                        <span>@returnPolicy</span>
                    </div>
                }
                else if (!string.IsNullOrWhiteSpace(returnDays))
                {
                    <div class="d-flex align-items-center gap-2 mb-3 text-muted small">
                        <i class="bi bi-arrow-repeat text-success"></i>
                        <span>@returnDays-day return policy</span>
                    </div>
                }

                <!-- Description -->
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div class="mb-4">
                        <p class="text-muted">@Model.Description</p>
                    </div>
                }

                <!-- Variants -->
                @if (Model.Variants.Any())
                {
                    <div class="mb-4">
                        <h6 class="fw-semibold mb-3 text-uppercase text-xs">
                            <i class="bi bi-palette me-1"></i> @localizer.Get("Options")
                        </h6>
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (var variant in Model.Variants)
                            {
                                var variantImage = variant.Images.FirstOrDefault()?.ImageUrl;
                                var isSelected = defaultVariant?.Id == variant.Id;
                                var finalPrice = Model.UnitPrice + (variant.PriceAdjustment ?? 0);
                                <div class="variant-card border rounded p-3 text-center @(isSelected ? "border-primary selected" : "") @(variant.StockQuantity <= 0 ? "opacity-50" : "")"
                                     style="min-width: 120px; cursor: @(variant.StockQuantity > 0 ? "pointer" : "not-allowed");"
                                     data-price="@finalPrice"
                                     data-image="@variantImage"
                                     onclick="selectVariant(this, '@variant.Id')">
                                    @if (!string.IsNullOrEmpty(variant.Color))
                                    {
                                        <div class="color-swatch mb-2"
                                             style="width: 30px; height: 30px; background: @WebActionResults.Helpers.ColorHelper.ToCssColor(variant.Color); border-radius: 50%; border: 2px solid #ddd; margin: 0 auto; box-shadow: inset 0 0 0 1px rgba(0,0,0,0.1);"></div>
                                        <span class="badge bg-secondary">@variant.Color</span>
                                    }
                                    @if (!string.IsNullOrEmpty(variant.Size))
                                    {
                                        <div class="small text-muted">@variant.Size</div>
                                    }
                                    <div class="small mt-1 @(variant.StockQuantity > 0 ? "text-success" : "text-danger")">
                                        @(variant.StockQuantity > 0 ? $"{variant.StockQuantity} {localizer.Get("UnitsAvailable")}" : localizer.Get("OutOfStock"))
                                    </div>
                                    @if (variant.PriceAdjustment.HasValue && variant.PriceAdjustment != 0)
                                    {
                                        <div class="small text-primary fw-semibold">
                                            +@variant.PriceAdjustment.Value.ToString("N0") VND
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Add to Cart Form -->
                <form asp-controller="Cart" asp-action="Add" method="post" class="mb-4" id="addToCartForm">
                    <input type="hidden" name="productId" value="@Model.ProductId" />
                    <input type="hidden" name="variantId" id="selectedVariantId" value="@(defaultVariant?.Id ?? 0)" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />

                    <div class="d-flex align-items-center gap-3">
                            <label class="form-label visually-hidden">@localizer.Get("Quantity")</label>
                            <div class="d-flex align-items-center border rounded" style="height: 48px;">
                                <button type="button" class="btn btn-outline-secondary border-0 rounded-0 px-3" onclick="decrementQty()" style="height: 100%;">
                                    <i class="bi bi-dash"></i>
                                </button>
                                <input type="number" name="quantity" id="quantity" value="1" min="1" max="99"
                                       class="form-control border-0 text-center p-0" style="width: 50px; height: 100%; box-shadow: none;">
                                <button type="button" class="btn btn-outline-secondary border-0 rounded-0 px-3" onclick="incrementQty()" style="height: 100%;">
                                    <i class="bi bi-plus"></i>
                                </button>
                            </div>
                            <button type="submit" class="btn btn-primary flex-grow-1 py-3" style="font-size: 1rem;" @(Model.Variants.Any() && defaultVariant?.StockQuantity <= 0 ? "disabled" : "")>
                                <i class="bi bi-cart-plus me-2"></i>@localizer.Get("AddToCart")
                            </button>
                        </div>
                </form>

                <!-- Wishlist -->
                @{
                    var wishlistEnabled = string.Equals(webSettings.GetValueOrDefault("EnableWishlist", "true"), "true", StringComparison.OrdinalIgnoreCase);
                }
                @if (wishlistEnabled)
                {
                    if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="mb-4">
                            <form asp-controller="Wishlist" asp-action="Add" method="post" class="flex-grow-1">
                                <input type="hidden" name="productId" value="@Model.ProductId" />
                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                <button type="submit" class="btn btn-outline-danger w-100 @(Model.IsInWishlist ? "active" : "")">
                                    <i class="bi @(Model.IsInWishlist ? "bi-heart-fill" : "bi-heart") me-2"></i>
                                    @(Model.IsInWishlist ? localizer.Get("Wishlist") : localizer.Get("AddToWishlist"))
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <div class="mb-4">
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-danger w-100">
                                <i class="bi bi-heart me-2"></i>@localizer.Get("Wishlist")
                            </a>
                        </div>
                    }
                }

                <!-- Features -->
                <div class="row g-3 mt-3">
                    <div class="col-6">
                        <div class="d-flex align-items-center text-muted small">
                            <i class="bi bi-truck me-2 text-primary"></i>
                            <span>@localizer.Get("FastDelivery")</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center text-muted small">
                            <i class="bi bi-shield-check me-2 text-success"></i>
                            <span>@localizer.Get("SecureCheckout")</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center text-muted small">
                            <i class="bi bi-arrow-repeat me-2 text-warning"></i>
                            <span>@localizer.Get("EasyReturns")</span>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="d-flex align-items-center text-muted small">
                            <i class="bi bi-headset me-2 text-info"></i>
                            <span>@localizer.Get("Support247")</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Reviews Section -->
        @{
            var reviewsEnabled = string.Equals(webSettings.GetValueOrDefault("EnableReviews", "true"), "true", StringComparison.OrdinalIgnoreCase);
        }
        @if (reviewsEnabled)
        {
        <div class="row mt-5" id="reviews">
            <div class="col-lg-12">
                <hr class="my-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h3 class="fw-bold mb-1">@localizer.Get("Reviews")</h3>
                        @if (Model.ReviewCount > 0)
                        {
                            <div class="text-warning">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <i class="bi @(i <= Math.Round(Model.AverageRating) ? "bi-star-fill" : "bi-star")"></i>
                                }
                                <span class="text-muted ms-2">@Model.AverageRating.ToString("0.0") / 5 (@Model.ReviewCount @localizer.Get("Reviews"))</span>
                            </div>
                        }
                    </div>
                </div>

                @if (Model.Reviews.Any())
                {
                    <div class="row g-4">
                        @foreach (var review in Model.Reviews)
                        {
                            <div class="col-md-6">
                                <div class="card border-0 shadow-sm h-100">
                                    <div class="card-body p-4">
                                        <div class="d-flex justify-content-between mb-2">
                                            <div class="d-flex align-items-center gap-2">
                                                <img src="https://ui-avatars.com/api/?name=@review.UserName&background=007bff&color=fff"
                                                     alt="@review.UserName" class="rounded-circle" width="40">
                                                <div>
                                                    <strong>@review.UserName</strong>
                                                    <div class="text-muted small">@review.CreatedAt.ToString("MMM dd, yyyy")</div>
                                                </div>
                                            </div>
                                            <div class="text-warning">
                                                @for (int i = 1; i <= 5; i++)
                                                {
                                                    <i class="bi @(i <= review.Rating ? "bi-star-fill" : "bi-star")"></i>
                                                }
                                            </div>
                                        </div>
                                        <p class="mb-0 text-muted">@review.Comment</p>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary text-center py-4">
                        <i class="bi bi-chat-square-text display-4 text-muted mb-3"></i>
                        <p class="mb-0">@localizer.Get("NoReviewsYet")</p>
                    </div>
                }

                <!-- Write Review -->
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="mt-5 p-4 bg-light rounded">
                        <h4 class="mb-3"><i class="bi bi-pencil-square me-2"></i>@localizer.Get("WriteReview")</h4>
                        <form asp-action="AddReview" method="post">
                            <input type="hidden" name="ProductId" value="@Model.ProductId" />
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <label class="form-label">@localizer.Get("Rating")</label>
                                    <select name="Rating" class="form-select" required>
                                        <option value="5">5 - @localizer.Get("Excellent")</option>
                                        <option value="4">4 - @localizer.Get("Good")</option>
                                        <option value="3">3 - @localizer.Get("Average")</option>
                                        <option value="2">2 - @localizer.Get("Poor")</option>
                                        <option value="1">1 - @localizer.Get("Terrible")</option>
                                    </select>
                                </div>
                                <div class="col-md-9">
                                    <label class="form-label">@localizer.Get("ReviewComment")</label>
                                    <textarea name="Comment" class="form-control" rows="3" required maxlength="500"
                                              placeholder="@localizer.Get("ReviewComment")"></textarea>
                                </div>
                            </div>
                            <div class="mt-3">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-send me-2"></i>@localizer.Get("SubmitReview")
                                </button>
                            </div>
                        </form>
                    </div>
                }
                else
                {
                    <div class="mt-4 text-center">
                        <p class="text-muted">
                            <a asp-controller="Account" asp-action="Login" class="text-decoration-none">@localizer.Get("Login")</a>
                            @localizer.Get("LoginToReview")
                        </p>
                    </div>
                }
            </div>
        </div>
        } @* end reviewsEnabled *@
    </div>
</section>

<!-- Related Products (if available) -->
@if (Model.RelatedProducts?.Any() == true)
{
    <section class="py-lg-8 py-5 bg-light">
        <div class="container">
            <h3 class="fw-bold mb-4">@localizer.Get("RelatedProducts")</h3>
            <div class="row g-4">
                @foreach (var related in Model.RelatedProducts)
                {
                    <div class="col-sm-6 col-md-3">
                        <div class="card border-0 shadow-sm h-100">
                            @{
                                var relatedImage = related.MainImageUrl;
                            }
                            @if (!string.IsNullOrEmpty(relatedImage))
                            {
                                <a asp-action="Details" asp-route-id="@related.ProductId">
                                    <img src="@relatedImage" class="card-img-top" alt="@related.ProductName"
                                         style="height: 180px; object-fit: cover;">
                                </a>
                            }
                            <div class="card-body text-center">
                                <h6 class="mb-1">
                                    <a asp-action="Details" asp-route-id="@related.ProductId" class="text-decoration-none text-dark">
                                        @related.ProductName
                                    </a>
                                </h6>
                                <span class="fw-bold text-primary">@related.UnitPrice.ToString("N0") VND</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
}

@section Scripts {
    <script>
        const galleryDataElement = document.getElementById('productGalleryData');
        const productGallery = galleryDataElement ? JSON.parse(galleryDataElement.textContent || '[]') : [];
        let currentGalleryIndex = 0;

        window.showGalleryImage = function(index) {
            if (!productGallery.length) return;

            currentGalleryIndex = (index + productGallery.length) % productGallery.length;
            const image = productGallery[currentGalleryIndex];
            const mainImage = document.getElementById('mainProductImage');

            if (mainImage) {
                mainImage.src = image.url;
                mainImage.alt = image.alt || '@Model.ProductName';
            }

            document.querySelectorAll('.gallery-thumb').forEach(thumb => {
                thumb.classList.toggle('active', Number(thumb.dataset.galleryIndex) === currentGalleryIndex);
            });
        }

        function showGalleryImageByUrl(url) {
            const imageIndex = productGallery.findIndex(image => image.url === url);
            if (imageIndex >= 0) {
                showGalleryImage(imageIndex);
                return true;
            }

            return false;
        }

        function incrementQty() {
            var input = document.getElementById('quantity');
            var value = parseInt(input.value) || 1;
            if (value < 99) input.value = value + 1;
        }

        function decrementQty() {
            var input = document.getElementById('quantity');
            var value = parseInt(input.value) || 1;
            if (value > 1) input.value = value - 1;
        }

        function selectVariant(card, variantId) {
            if (card.classList.contains('opacity-50')) return;

            document.querySelectorAll('.variant-card').forEach(c => c.classList.remove('border-primary', 'selected'));
            card.classList.add('border-primary', 'selected');

            var variantInput = document.getElementById('selectedVariantId');
            if (variantInput) variantInput.value = variantId;

            var price = Number(card.dataset.price || 0);
            var priceEl = document.getElementById('productPrice');
            if (priceEl && price > 0) {
                priceEl.textContent = price.toLocaleString('vi-VN') + ' VND';
            }

            var imageUrl = card.dataset.image;
            var mainImage = document.getElementById('mainProductImage');
            if (imageUrl && mainImage) {
                if (!showGalleryImageByUrl(imageUrl)) {
                    mainImage.src = imageUrl;
                    document.querySelectorAll('.gallery-thumb').forEach(thumb => thumb.classList.remove('active'));
                }
            }
        }

        // Initialize tooltips
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
    </script>
}

<style>
    .product-gallery-main {
        position: relative;
        min-height: 400px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem 3.5rem;
        background: #f8f9fa;
        overflow: hidden;
    }

    .gallery-arrow {
        position: absolute;
        top: 50%;
        z-index: 2;
        width: 42px;
        height: 42px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(33, 31, 28, 0.12);
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.92);
        color: #211f1c;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
        transform: translateY(-50%);
        transition: all 0.18s ease;
    }

    .gallery-arrow:hover {
        background: #d47f31;
        border-color: #d47f31;
        color: #fff;
    }

    .gallery-arrow-prev {
        left: 16px;
    }

    .gallery-arrow-next {
        right: 16px;
    }

    .gallery-thumbnails {
        display: flex;
        gap: 0.75rem;
        padding: 0.2rem 0 0.35rem;
        overflow-x: auto;
        scrollbar-width: thin;
    }

    .gallery-thumb {
        width: 78px;
        height: 78px;
        flex: 0 0 78px;
        padding: 3px;
        border: 2px solid transparent;
        border-radius: 8px;
        background: #fff;
        cursor: pointer;
        transition: border-color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
    }

    .gallery-thumb img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
        border-radius: 6px;
    }

    .gallery-thumb:hover,
    .gallery-thumb.active {
        border-color: #d47f31;
        box-shadow: 0 8px 22px rgba(212, 127, 49, 0.16);
        transform: translateY(-1px);
    }

    @@media (max-width: 575.98px) {
        .product-gallery-main {
            min-height: 310px;
            padding: 1rem 2.7rem;
        }

        .gallery-arrow {
            width: 36px;
            height: 36px;
        }

        .gallery-arrow-prev {
            left: 10px;
        }

        .gallery-arrow-next {
            right: 10px;
        }

        .gallery-thumb {
            width: 64px;
            height: 64px;
            flex-basis: 64px;
        }
    }

    .variant-card {
        transition: all 0.2s ease;
    }

    .variant-card:hover {
        border-color: #d47f31 !important;
        background-color: #fef9f5;
    }

    .variant-card.border-primary {
        border-color: #d47f31 !important;
        background-color: #fef9f5;
    }

    .color-swatch {
        transition: transform 0.2s ease;
    }

