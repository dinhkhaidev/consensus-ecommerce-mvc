@model WebActionResults.ViewModels.ProductDetailViewModel
@{
    ViewData["Title"] = Model.ProductName + " - Furnish";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var isVi = string.Equals(localizer.CurrentLanguage, "vi", StringComparison.OrdinalIgnoreCase);
    var defaultVariant = Model.Variants.FirstOrDefault(v => v.StockQuantity > 0) ?? Model.Variants.FirstOrDefault();
    var displayPrice = Model.UnitPrice + (defaultVariant?.PriceAdjustment ?? 0);
    var galleryImages = Model.Images
        .Concat(Model.Variants.SelectMany(v => v.Images))
        .Where(i => !string.IsNullOrWhiteSpace(i.ImageUrl))
        .GroupBy(i => i.ImageUrl)
        .Select(g => g.First())
        .OrderByDescending(i => i.IsMain)
        .ThenBy(i => i.Id)
        .ToList();
    var mainImage = galleryImages.FirstOrDefault(i => i.IsMain) ?? galleryImages.FirstOrDefault();
    var hasVariants = Model.Variants.Any();
    var totalStock = hasVariants ? Model.Variants.Sum(v => v.StockQuantity) : 0;
    var availableVariants = Model.Variants.Count(v => v.StockQuantity > 0);
    var selectedSku = defaultVariant?.SKU;
    var selectedColor = defaultVariant?.Color;
    var selectedSize = defaultVariant?.Size;
    var webSettings = ViewData["WebSettings"] as Dictionary<string, string> ?? new();
    var returnPolicy = webSettings.GetValueOrDefault("ReturnPolicySummary", "");
    var returnDays = webSettings.GetValueOrDefault("ReturnWindowDays", "30");
    var standardShippingFee = decimal.TryParse(webSettings.GetValueOrDefault("StandardShippingFee", "50000"), out var sf) ? sf : 50000;
    var freeShippingThreshold = decimal.TryParse(webSettings.GetValueOrDefault("FreeShippingThreshold", "500000"), out var ft) ? ft : 500000;
    var wishlistEnabled = string.Equals(webSettings.GetValueOrDefault("EnableWishlist", "true"), "true", StringComparison.OrdinalIgnoreCase);
    var room3DEnabled = string.Equals(webSettings.GetValueOrDefault("PageRoom3DEnabled", "true"), "true", StringComparison.OrdinalIgnoreCase);
    var reviewsEnabled = string.Equals(webSettings.GetValueOrDefault("EnableReviews", "true"), "true", StringComparison.OrdinalIgnoreCase);
    var ratingCounts = Enumerable.Range(1, 5).ToDictionary(i => i, i => Model.Reviews.Count(r => r.Rating == i));
    var productImageJson = System.Text.Json.JsonSerializer.Serialize(galleryImages.Select(i => new
    {
        url = i.ImageUrl,
        alt = i.AltText ?? Model.ProductName
    }));
    string T(string vi, string en) => isVi ? vi : en;
    var stockUnknownLabel = T("Chưa có thông tin tồn kho", "Stock not configured");
    var productNameJson = System.Text.Json.JsonSerializer.Serialize(Model.ProductName);
    var outOfStockJson = System.Text.Json.JsonSerializer.Serialize(localizer.Get("OutOfStock"));
    var preparingJson = System.Text.Json.JsonSerializer.Serialize(T("Đang chuẩn bị", "Preparing"));
}

<section class="product-detail-page">
    <div class="container">
        <nav aria-label="breadcrumb" class="product-breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index"><i class="bi bi-house me-1"></i>@localizer.Get("Home")</a></li>
                <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index">@localizer.Get("Products")</a></li>
                @if (!string.IsNullOrEmpty(Model.CategoryName))
                {
                    <li class="breadcrumb-item"><a asp-controller="Product" asp-action="Index" asp-route-categoryId="@Model.CategoryId">@Model.CategoryName</a></li>
                }
                <li class="breadcrumb-item active" aria-current="page">@Model.ProductName</li>
            </ol>
        </nav>

        <div class="showroom-shell">
            <div class="showroom-gallery @(galleryImages.Count > 1 ? "has-thumbs" : "")">
                <div class="gallery-frame">
                    @if (mainImage != null)
                    {
                        <button type="button" class="gallery-main-button" onclick="openProductLightbox()" aria-label="@T("Mở ảnh lớn", "Open large image")">
                            <img src="@mainImage.ImageUrl" alt="@(mainImage.AltText ?? Model.ProductName)" id="mainProductImage" />
                            <span class="gallery-zoom-chip"><i class="bi bi-arrows-fullscreen"></i>@T("Xem lớn", "View larger")</span>
                        </button>

                        @if (galleryImages.Count > 1)
                        {
                            <button type="button" class="gallery-arrow gallery-arrow-prev" aria-label="Previous image" onclick="showGalleryImage(currentGalleryIndex - 1)">
                                <i class="bi bi-chevron-left"></i>
                            </button>
                            <button type="button" class="gallery-arrow gallery-arrow-next" aria-label="Next image" onclick="showGalleryImage(currentGalleryIndex + 1)">
                                <i class="bi bi-chevron-right"></i>
                            </button>
                            <span class="gallery-counter" id="galleryCounter">1 / @galleryImages.Count</span>
                        }
                    }
                    else
                    {
                        <div class="gallery-empty">
                            <i class="bi bi-image"></i>
                            <span>@T("Chưa có ảnh sản phẩm", "No product image yet")</span>
                        </div>
                    }
                </div>

                @if (galleryImages.Count > 1)
                {
                    <div class="gallery-thumbnails" aria-label="@T("Ảnh sản phẩm", "Product images")">
                        @for (var i = 0; i < galleryImages.Count; i++)
                        {
                            var img = galleryImages[i];
                            var isActive = img.ImageUrl == mainImage?.ImageUrl;
                            <button type="button"
                                    class="gallery-thumb @(isActive ? "active" : "")"
                                    onclick="showGalleryImage(@i)"
                                    data-gallery-index="@i"
                                    data-image-url="@img.ImageUrl"
                                    title="@(img.AltText ?? Model.ProductName)">
                                <img src="@img.ImageUrl" alt="@(img.AltText ?? Model.ProductName)" />
                            </button>
                        }
                    </div>
                }

                <div class="experience-actions">
                    @Html.AntiForgeryToken()
                    @if (room3DEnabled && Model.HasRoom3DModel)
                    {
                        <button type="button" class="btn btn-dark" onclick="tryProductInRoom3D(this)" data-room-product-id="@Model.Room3DProductId">
                            <i class="bi bi-badge-3d me-2"></i>@T("Thử trong phòng 3D", "Try in 3D room")
                        </button>
                    }
                    <a asp-controller="Ai" asp-action="Stylist" asp-route-productId="@Model.ProductId" class="btn btn-outline-dark">
                        <i class="bi bi-stars me-2"></i>@T("Nhờ AI phối cùng", "Ask AI to style it")
                    </a>
                </div>
            </div>

            <aside class="purchase-panel" aria-label="@T("Thông tin mua hàng", "Purchase information")">
                <div class="panel-kicker">
                    @if (!string.IsNullOrEmpty(Model.CategoryName))
                    {
                        <span><i class="bi bi-tag"></i>@Model.CategoryName</span>
                    }
                    @if (!string.IsNullOrEmpty(Model.SupplierName))
                    {
                        <span><i class="bi bi-shop"></i>@Model.SupplierName</span>
                    }
                </div>

                <h1>@Model.ProductName</h1>

                <div class="rating-line">
                    @if (Model.ReviewCount > 0)
                    {
                        <div class="stars" aria-label="@Model.AverageRating.ToString("0.0") out of 5">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="bi @(i <= Math.Round(Model.AverageRating) ? "bi-star-fill" : "bi-star")"></i>
                            }
                        </div>
                        <a href="#reviews">@Model.AverageRating.ToString("0.0") / 5 - @Model.ReviewCount @localizer.Get("Reviews")</a>
                    }
                    else
                    {
                        <span class="text-muted small">@T("Chưa có đánh giá. Hãy là người đầu tiên.", "No reviews yet. Be the first.")</span>
                    }
                </div>

                <div class="price-stack">
                    <span class="price money-vnd" id="productPrice" data-base-price="@Model.UnitPrice" data-money-vnd="@displayPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)">@displayPrice.ToString("N0") VND</span>
                    @if (Model.OriginalPrice.HasValue && Model.OriginalPrice > Model.UnitPrice)
                    {
                        <span class="old-price money-vnd" data-money-vnd="@Model.OriginalPrice.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)">@Model.OriginalPrice.Value.ToString("N0") VND</span>
                        <span class="sale-chip">-@(((1 - Model.UnitPrice / Model.OriginalPrice.Value) * 100).ToString("0"))%</span>
                    }
                </div>

                @if (Model.Variants.Any())
                {
                    <div class="option-section">
                        <div class="section-title">
                            <span>@localizer.Get("Options")</span>
                            <small>@T($"{Model.Variants.Count} lựa chọn", $"{Model.Variants.Count} options")</small>
                        </div>

                        <div class="variant-grid">
                            @foreach (var variant in Model.Variants)
                            {
                                var variantImage = variant.Images.FirstOrDefault()?.ImageUrl;
                                var isSelected = defaultVariant?.Id == variant.Id;
                                var finalPrice = Model.UnitPrice + (variant.PriceAdjustment ?? 0);
                                var labelParts = new[] { variant.Color, variant.Size }.Where(s => !string.IsNullOrWhiteSpace(s));
                                var optionLabel = string.Join(" / ", labelParts);
                                if (string.IsNullOrWhiteSpace(optionLabel))
                                {
                                    optionLabel = $"#{variant.Id}";
                                }

                                <button type="button"
                                        class="variant-card @(isSelected ? "selected" : "") @(variant.StockQuantity <= 0 ? "is-disabled" : "")"
                                        data-variant-id="@variant.Id"
                                        data-price="@finalPrice"
                                        data-image="@variantImage"
                                        data-stock="@variant.StockQuantity"
                                        data-sku="@variant.SKU"
                                        data-label="@optionLabel"
                                        onclick="selectVariant(this, '@variant.Id')"
                                        @(variant.StockQuantity <= 0 ? "disabled" : "")>
                                    @if (!string.IsNullOrEmpty(variant.Color))
                                    {
                                        <span class="color-dot" style="background: @WebActionResults.Helpers.ColorHelper.ToCssColor(variant.Color);"></span>
                                    }
                                    <span class="variant-main">@optionLabel</span>
                                    @if (!string.IsNullOrEmpty(variant.SKU))
                                    {
                                        <span class="variant-sub">SKU @variant.SKU</span>
                                    }
                                    @if (variant.StockQuantity <= 0)
                                    {
                                        <span class="variant-meta">@localizer.Get("OutOfStock")</span>
                                    }
                                    @if (variant.PriceAdjustment.HasValue && variant.PriceAdjustment != 0)
                                    {
                                        <span class="variant-price money-vnd" data-money-vnd="@variant.PriceAdjustment.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)">+@variant.PriceAdjustment.Value.ToString("N0") VND</span>
                                    }
                                </button>
                            }
                        </div>
                    </div>
                }

                <form asp-controller="Cart" asp-action="Add" method="post" id="addToCartForm" class="cart-form">
                    <input type="hidden" name="productId" value="@Model.ProductId" />
                    <input type="hidden" name="variantId" id="selectedVariantId" value="@(defaultVariant?.Id ?? 0)" />
                    <input type="hidden" name="returnUrl" value="@returnUrl" />

                    <div class="buy-row">
                        <div class="quantity-stepper" aria-label="@localizer.Get("Quantity")">
                            <button type="button" onclick="decrementQty()" aria-label="Decrease quantity"><i class="bi bi-dash"></i></button>
                            <input type="number" name="quantity" id="quantity" value="1" min="1" max="99" />
                            <button type="button" onclick="incrementQty()" aria-label="Increase quantity"><i class="bi bi-plus"></i></button>
                        </div>
                        <button type="submit" class="btn btn-primary add-cart-btn" id="addToCartButton" @(Model.Variants.Any() && defaultVariant?.StockQuantity <= 0 ? "disabled" : "")>
                            <i class="bi bi-cart-plus me-2"></i>@localizer.Get("AddToCart")
                        </button>
                    </div>
                </form>

                @if (wishlistEnabled)
                {
                    if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-controller="Wishlist" asp-action="Add" method="post">
                            <input type="hidden" name="productId" value="@Model.ProductId" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <button type="submit" class="btn btn-outline-danger w-100 wishlist-btn @(Model.IsInWishlist ? "active" : "")">
                                <i class="bi @(Model.IsInWishlist ? "bi-heart-fill" : "bi-heart") me-2"></i>
                                @(Model.IsInWishlist ? localizer.Get("Wishlist") : localizer.Get("AddToWishlist"))
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@returnUrl" class="btn btn-outline-danger w-100 wishlist-btn">
                            <i class="bi bi-heart me-2"></i>@localizer.Get("Wishlist")
                        </a>
                    }
                }

                <div class="micro-details">
                    <div>
                        <span>@T("Mã đang chọn", "Selected code")</span>
                        <strong id="selectedSku">@(string.IsNullOrWhiteSpace(selectedSku) ? $"FUR-{Model.ProductId:0000}" : selectedSku)</strong>
                    </div>
                    <div>
                        <span>@T("Tồn kho", "Stock")</span>
                        <strong>@(hasVariants ? totalStock.ToString("N0") : stockUnknownLabel)</strong>
                    </div>
                    <div>
                        <span>@T("Lựa chọn", "Variants")</span>
                        <strong>@(hasVariants ? $"{availableVariants}/{Model.Variants.Count}" : T("Không có biến thể", "No variants"))</strong>
                    </div>
                </div>

                <section class="mini-advisor" aria-label="@T("AI tư vấn mua hàng", "AI purchase advisor")">
                    @Html.AntiForgeryToken()
                    <div class="mini-advisor-head">
                        <span><i class="bi bi-stars"></i>@T("AI tư vấn nhanh", "Quick AI advisor")</span>
                        <small>@T("Nên mua không?", "Should you buy it?")</small>
                    </div>
                    <textarea id="advisorNeed" maxlength="800" rows="2" placeholder="@T("VD: Phòng khách 18m2, thích ấm cúng, ngân sách 10 triệu...", "Ex: 18m2 living room, cozy mood, 10M budget...")"></textarea>
                    <div class="mini-advisor-row">
                        <input id="advisorBudget" type="number" min="0" step="100000" placeholder="@T("Ngân sách", "Budget")" />
                        <button type="button" class="btn btn-dark" onclick="askProductAdvisor(this)">
                            <i class="bi bi-magic me-2"></i>@T("Tư vấn", "Advise")
                        </button>
                    </div>
                    <div id="advisorResult" class="mini-advisor-result" hidden></div>
                </section>

            </aside>
        </div>

        <div class="detail-tabs integrated-detail-tabs">
            <ul class="nav nav-pills" id="detailTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="story-tab" data-bs-toggle="pill" data-bs-target="#story" type="button" role="tab">@T("Câu chuyện", "Story")</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="spec-tab" data-bs-toggle="pill" data-bs-target="#spec" type="button" role="tab">@T("Thông tin", "Details")</button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="shipping-tab" data-bs-toggle="pill" data-bs-target="#shipping" type="button" role="tab">@T("Giao hàng", "Delivery")</button>
                </li>
            </ul>
            <div class="tab-content">
                <div class="tab-pane fade show active" id="story" role="tabpanel" aria-labelledby="story-tab">
                    <div class="story-panel">
                        <div class="story-panel-copy">
                            <span>@T("Mood and use", "Mood and use")</span>
                            <h2>@T("Một điểm nhấn dễ phối, đủ nổi bật để nâng không gian.", "A flexible statement piece with enough presence to lift the room.")</h2>
                        </div>
                        <p>@(string.IsNullOrWhiteSpace(Model.Description) ? T("Sản phẩm được chọn để tạo cảm giác gọn gàng, dễ phối và đủ tinh tế cho nhịp sống hằng ngày.", "Selected to feel clean, easy to style, and refined enough for everyday living.") : Model.Description)</p>
                    </div>
                </div>
                <div class="tab-pane fade" id="spec" role="tabpanel" aria-labelledby="spec-tab">
                    <div class="spec-grid">
                        <div><span>@T("Danh mục", "Category")</span><strong>@(Model.CategoryName ?? "-")</strong></div>
                        <div><span>@T("Nhà cung cấp", "Supplier")</span><strong>@(Model.SupplierName ?? "-")</strong></div>
                        <div><span>@T("Mã sản phẩm", "Product code")</span><strong>@(string.IsNullOrWhiteSpace(selectedSku) ? $"FUR-{Model.ProductId:0000}" : selectedSku)</strong></div>
                        <div><span>@T("Màu đang chọn", "Selected color")</span><strong>@(selectedColor ?? "-")</strong></div>
                        <div><span>@T("Kích cỡ", "Size")</span><strong>@(selectedSize ?? "-")</strong></div>
                        <div class="stock-spec"><span><i class="bi bi-box-seam"></i>@T("Tồn kho", "Stock")</span><strong>@(hasVariants ? totalStock.ToString("N0") : stockUnknownLabel)</strong></div>
                    </div>
                </div>
                <div class="tab-pane fade" id="shipping" role="tabpanel" aria-labelledby="shipping-tab">
                    <div class="shipping-grid">
                        <div>
                            <i class="bi bi-truck"></i>
                            <span>@T("Phí vận chuyển tiêu chuẩn", "Standard shipping")</span>
                            <strong class="money-vnd" data-money-vnd="@standardShippingFee.ToString(System.Globalization.CultureInfo.InvariantCulture)">@standardShippingFee.ToString("N0") VND</strong>
                        </div>
                        <div>
                            <i class="bi bi-gift"></i>
                            <span>@T("Miễn phí vận chuyển từ", "Free shipping from")</span>
                            <strong class="money-vnd" data-money-vnd="@freeShippingThreshold.ToString(System.Globalization.CultureInfo.InvariantCulture)">@freeShippingThreshold.ToString("N0") VND</strong>
                        </div>
                        <div>
                            <i class="bi bi-arrow-repeat"></i>
                            <span>@T("Đổi trả", "Returns")</span>
                            <strong>@(string.IsNullOrWhiteSpace(returnPolicy) ? $"{returnDays} days" : returnPolicy)</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@if (Model.RelatedProducts?.Any() == true)
{
    <section class="related-showcase">
        <div class="container">
            <div class="section-heading">
                <div>
                    <span class="eyebrow">@T("Complete the look", "Complete the look")</span>
                    <h2>@T("Phối cùng sản phẩm này", "Style it with these pieces")</h2>
                    <p>@T("Gợi ý dựa trên sản phẩm thường mua chung, phong cách, tầm giá và đánh giá.", "Recommended by co-purchases, style, price range, and reviews.")</p>
                </div>
                <a asp-controller="Product" asp-action="Index" class="link-dark">@T("Xem tất cả", "View all")</a>
            </div>
            <div class="related-strip">
                @foreach (var related in Model.RelatedProducts)
                {
                    <a asp-action="Details" asp-route-id="@related.ProductId" class="related-card">
                        <span class="related-image">
                            @if (!string.IsNullOrEmpty(related.MainImageUrl))
                            {
                                <img src="@related.MainImageUrl" alt="@related.ProductName" loading="lazy" />
                            }
                            else
                            {
                                <i class="bi bi-image"></i>
                            }
                        </span>
                        <span class="related-name">@related.ProductName</span>
                        @{
                            var relatedPrice = related.MinPrice ?? related.UnitPrice;
                        }
                        <strong class="money-vnd" data-money-vnd="@relatedPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)">@relatedPrice.ToString("N0") VND</strong>
                    </a>
                }
            </div>
        </div>
    </section>
}

@if (reviewsEnabled)
{
    <section class="reviews-showcase" id="reviews">
        <div class="container">
            <div class="reviews-layout">
                <div class="review-summary">
                    <span class="eyebrow">@localizer.Get("Reviews")</span>
                    <h2>@(Model.ReviewCount > 0 ? Model.AverageRating.ToString("0.0") : "0.0")</h2>
                    <div class="stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="bi @(i <= Math.Round(Model.AverageRating) ? "bi-star-fill" : "bi-star")"></i>
                        }
                    </div>
                    <p>@Model.ReviewCount @localizer.Get("Reviews")</p>

                    @for (var star = 5; star >= 1; star--)
                    {
                        var count = ratingCounts[star];
                        var percent = Model.ReviewCount > 0 ? (count * 100 / Model.ReviewCount) : 0;
                        <div class="rating-bar">
                            <span>@star</span>
                            <div><i style="width:@percent%"></i></div>
                            <em>@count</em>
                        </div>
                    }
                </div>

                <div class="review-list">
                    <div class="section-heading compact">
                        <div>
                            <span class="eyebrow">@T("Customer voice", "Customer voice")</span>
                            <h2>@T("Khách hàng nói gì", "What customers say")</h2>
                        </div>
                    </div>

                    @if (Model.Reviews.Any())
                    {
                        <div class="review-cards">
                            @foreach (var review in Model.Reviews.Take(4))
                            {
                                <article class="review-card">
                                    <div class="review-card-head">
                                        <img src="https://ui-avatars.com/api/?name=@review.UserName&background=1f2933&color=fff" alt="@review.UserName" />
                                        <div>
                                            <strong>@review.UserName</strong>
                                            <span>@review.CreatedAt.ToString("MMM dd, yyyy")</span>
                                        </div>
                                        <div class="stars">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="bi @(i <= review.Rating ? "bi-star-fill" : "bi-star")"></i>
                                            }
                                        </div>
                                    </div>
                                    <p>@review.Comment</p>
                                </article>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-review">
                            <i class="bi bi-chat-square-heart"></i>
                            <h3>@localizer.Get("NoReviewsYet")</h3>
                            <p>@T("Sản phẩm này đang chờ những cảm nhận đầu tiên.", "This piece is waiting for its first customer notes.")</p>
                        </div>
                    }

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <div class="write-review">
                            <h3><i class="bi bi-pencil-square me-2"></i>@localizer.Get("WriteReview")</h3>
                            <form asp-action="AddReview" method="post">
                                <input type="hidden" name="ProductId" value="@Model.ProductId" />
                                <div class="row g-3">
                                    <div class="col-md-3">
                                        <label class="form-label">@localizer.Get("Rating")</label>
                                        <select name="Rating" class="form-select" required>
                                            <option value="5">5 - @localizer.Get("Excellent")</option>
                                            <option value="4">4 - @localizer.Get("Good")</option>
                                            <option value="3">3 - @localizer.Get("Average")</option>
                                            <option value="2">2 - @localizer.Get("Poor")</option>
                                            <option value="1">1 - @localizer.Get("Terrible")</option>
                                        </select>
                                    </div>
                                    <div class="col-md-9">
                                        <label class="form-label">@localizer.Get("ReviewComment")</label>
                                        <textarea name="Comment" class="form-control" rows="3" required maxlength="500" placeholder="@localizer.Get("ReviewComment")"></textarea>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-primary mt-3"><i class="bi bi-send me-2"></i>@localizer.Get("SubmitReview")</button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <p class="login-review">
                            <a asp-controller="Account" asp-action="Login">@localizer.Get("Login")</a>
                            @localizer.Get("LoginToReview")
                        </p>
                    }
                </div>
            </div>
        </div>
    </section>
}

<div class="product-lightbox" id="productLightbox" aria-hidden="true">
    <button type="button" class="lightbox-close" onclick="closeProductLightbox()" aria-label="Close"><i class="bi bi-x-lg"></i></button>
    <button type="button" class="lightbox-nav prev" onclick="showLightboxImage(currentGalleryIndex - 1)" aria-label="Previous image"><i class="bi bi-chevron-left"></i></button>
    <img src="" alt="" id="lightboxImage" />
    <button type="button" class="lightbox-nav next" onclick="showLightboxImage(currentGalleryIndex + 1)" aria-label="Next image"><i class="bi bi-chevron-right"></i></button>
</div>

<div class="mobile-buy-bar">
    @if (mainImage != null)
    {
        <img src="@mainImage.ImageUrl" alt="@Model.ProductName" />
    }
    <div>
        <strong id="mobileProductPrice" class="money-vnd" data-money-vnd="@displayPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)">@displayPrice.ToString("N0") VND</strong>
        <span>@Model.ProductName</span>
    </div>
    <button type="submit" form="addToCartForm" class="btn btn-primary" id="mobileAddToCartButton" @(Model.Variants.Any() && defaultVariant?.StockQuantity <= 0 ? "disabled" : "")>
        <i class="bi bi-cart-plus"></i>
    </button>
</div>

@if (galleryImages.Any())
{
    <script type="application/json" id="productGalleryData">@Html.Raw(productImageJson)</script>
}

@section Scripts {
    <script>
        const galleryDataElement = document.getElementById('productGalleryData');
        const productGallery = galleryDataElement ? JSON.parse(galleryDataElement.textContent || '[]') : [];
        const productNameText = @Html.Raw(productNameJson);
        const outOfStockText = @Html.Raw(outOfStockJson);
        const preparingText = @Html.Raw(preparingJson);
        let currentGalleryIndex = 0;

        window.showGalleryImage = function(index) {
            if (!productGallery.length) return;
            currentGalleryIndex = (index + productGallery.length) % productGallery.length;
            const image = productGallery[currentGalleryIndex];
            const mainImage = document.getElementById('mainProductImage');

            if (mainImage) {
                mainImage.src = image.url;
                mainImage.alt = image.alt || productNameText;
            }

            document.querySelectorAll('.gallery-thumb').forEach(thumb => {
                thumb.classList.toggle('active', Number(thumb.dataset.galleryIndex) === currentGalleryIndex);
            });

            const counter = document.getElementById('galleryCounter');
            if (counter) counter.textContent = `${currentGalleryIndex + 1} / ${productGallery.length}`;
        };

        function showGalleryImageByUrl(url) {
            const imageIndex = productGallery.findIndex(image => image.url === url);
            if (imageIndex >= 0) {
                showGalleryImage(imageIndex);
                return true;
            }
            return false;
        }

        function updateBuyButtons(stock) {
            const disabled = stock !== null && stock <= 0;
            document.getElementById('addToCartButton')?.toggleAttribute('disabled', disabled);
            document.getElementById('mobileAddToCartButton')?.toggleAttribute('disabled', disabled);
        }

        function incrementQty() {
            const input = document.getElementById('quantity');
            const max = Number(input.max || 99);
            const value = parseInt(input.value) || 1;
            if (value < max) input.value = value + 1;
        }

        function decrementQty() {
            const input = document.getElementById('quantity');
            const value = parseInt(input.value) || 1;
            if (value > 1) input.value = value - 1;
        }

        function selectVariant(card, variantId) {
            if (card.classList.contains('is-disabled')) return;

            document.querySelectorAll('.variant-card').forEach(c => c.classList.remove('selected'));
            card.classList.add('selected');

            const stock = Number(card.dataset.stock || 0);
            const variantInput = document.getElementById('selectedVariantId');
            if (variantInput) variantInput.value = variantId;

            const price = Number(card.dataset.price || 0);
            const priceEl = document.getElementById('productPrice');
            if (priceEl && price > 0) {
                priceEl.textContent = price.toLocaleString('vi-VN') + ' VND';
                priceEl.dataset.moneyVnd = String(price);
            }

            const mobilePriceEl = document.getElementById('mobileProductPrice');
            if (mobilePriceEl && price > 0) {
                mobilePriceEl.textContent = price.toLocaleString('vi-VN') + ' VND';
                mobilePriceEl.dataset.moneyVnd = String(price);
            }

            if (price > 0) {
                document.dispatchEvent(new CustomEvent('furnish:money-updated'));
            }

            const skuEl = document.getElementById('selectedSku');
            if (skuEl) skuEl.textContent = card.dataset.sku || `FUR-${String(@Model.ProductId).padStart(4, '0')}`;

            const qty = document.getElementById('quantity');
            if (qty) {
                qty.max = stock > 0 ? Math.min(stock, 99) : 1;
                if (Number(qty.value) > Number(qty.max)) qty.value = qty.max;
            }

            updateBuyButtons(stock);

            const imageUrl = card.dataset.image;
            const mainImage = document.getElementById('mainProductImage');
            if (imageUrl && mainImage) {
                if (!showGalleryImageByUrl(imageUrl)) {
                    mainImage.src = imageUrl;
                    document.querySelectorAll('.gallery-thumb').forEach(thumb => thumb.classList.remove('active'));
                }
            }
        }

        window.openProductLightbox = function() {
            if (!productGallery.length) return;
            const lightbox = document.getElementById('productLightbox');
            lightbox.classList.add('active');
            lightbox.setAttribute('aria-hidden', 'false');
            showLightboxImage(currentGalleryIndex);
            document.body.style.overflow = 'hidden';
        };

        window.closeProductLightbox = function() {
            const lightbox = document.getElementById('productLightbox');
            lightbox.classList.remove('active');
            lightbox.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        };

        window.showLightboxImage = function(index) {
            if (!productGallery.length) return;
            currentGalleryIndex = (index + productGallery.length) % productGallery.length;
            const image = productGallery[currentGalleryIndex];
            const lightboxImage = document.getElementById('lightboxImage');
            lightboxImage.src = image.url;
            lightboxImage.alt = image.alt || productNameText;
            showGalleryImage(currentGalleryIndex);
        };

        window.tryProductInRoom3D = async function(btn) {
            const original = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>' + preparingText;
            const token = document.querySelector('.experience-actions input[name="__RequestVerificationToken"]')?.value
                || document.querySelector('input[name="__RequestVerificationToken"]')?.value
                || '';

            try {
                const response = await fetch('@Url.Action("TrySingleInRoom3D", "Ai")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({ productId: @Model.ProductId })
                });
                const data = await response.json();
                if (data.ok && data.redirectUrl) {
                    window.location.href = data.redirectUrl;
                    return;
                }
                btn.innerHTML = original;
                btn.disabled = false;
            } catch {
                btn.innerHTML = original;
                btn.disabled = false;
            }
        };

        function advisorEscape(value) {
            const div = document.createElement('div');
            div.textContent = value ?? '';
            return div.innerHTML;
        }

        function advisorProductCard(product) {
            const image = product.imageUrl
                ? `<img src="${advisorEscape(product.imageUrl)}" alt="${advisorEscape(product.productName)}" loading="lazy" />`
                : '<span class="advisor-product-fallback"><i class="bi bi-box"></i></span>';

            return `<a class="advisor-product" href="/Product/Details/${product.productId}">
                ${image}
                <span>
                    <strong>${advisorEscape(product.productName)}</strong>
                    <small data-money-vnd="${Number(product.unitPrice)}">${Number(product.unitPrice).toLocaleString('vi-VN')} VND</small>
                    <small>${advisorEscape(product.reason || '')}</small>
                </span>
            </a>`;
        }

        function renderAdvisorResult(data) {
            const resultEl = document.getElementById('advisorResult');
            if (!resultEl) return;

            const result = data.result || {};
            const fitNotes = (result.fitNotes || []).map(note => `<li>${advisorEscape(note)}</li>`).join('');
            const watchOuts = (result.watchOuts || []).map(note => `<li>${advisorEscape(note)}</li>`).join('');
            const betterMatches = (data.betterMatches || []).map(advisorProductCard).join('');

            resultEl.innerHTML = `
                <div class="advisor-verdict">
                    <strong>${advisorEscape(result.verdictLabel || '@T("Nên cân nhắc", "Consider")')}</strong>
                    <span>${Number(result.confidence || 70)}% @T("mức phù hợp", "fit")</span>
                </div>
                <p>${advisorEscape(result.summary || '')}</p>
                ${fitNotes ? `<ul class="advisor-list">${fitNotes}</ul>` : ''}
                ${watchOuts ? `<ul class="advisor-list">${watchOuts}</ul>` : ''}
                ${betterMatches ? `<div class="advisor-products"><strong>@T("Có thể hợp hơn", "May fit better")</strong>${betterMatches}</div>` : ''}
            `;
            resultEl.hidden = false;
        }

        window.askProductAdvisor = async function(btn) {
            const original = btn.innerHTML;
            const resultEl = document.getElementById('advisorResult');
            const need = document.getElementById('advisorNeed')?.value?.trim() || '';
            const budgetRaw = document.getElementById('advisorBudget')?.value || '';
            const token = document.querySelector('.mini-advisor input[name="__RequestVerificationToken"]')?.value
                || document.querySelector('input[name="__RequestVerificationToken"]')?.value
                || '';

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>@T("Đang tư vấn", "Advising")';
            if (resultEl) {
                resultEl.hidden = false;
                resultEl.innerHTML = '<p>@T("AI đang so sản phẩm này với nhu cầu và vài lựa chọn khác...", "AI is comparing this product with your need and alternatives...")</p>';
            }

            try {
                const response = await fetch('@Url.Action("ProductAdvisor", "Ai")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({
                        productId: @Model.ProductId,
                        needDescription: need,
                        budget: budgetRaw ? Number(budgetRaw) : null,
                        roomType: ''
                    })
                });
                const data = await response.json();
                if (!data.ok) {
                    if (resultEl) resultEl.innerHTML = `<p>${advisorEscape(data.message || '@T("Chưa tư vấn được lúc này.", "Could not advise right now.")')}</p>`;
                    return;
                }

                renderAdvisorResult(data);
            } catch {
                if (resultEl) resultEl.innerHTML = '<p>@T("Kết nối AI chưa ổn, bạn thử lại sau nhé.", "AI connection is not ready, please try again later.")</p>';
            } finally {
                btn.disabled = false;
                btn.innerHTML = original;
            }
        };

        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') closeProductLightbox();
            if (event.key === 'ArrowLeft' && document.getElementById('productLightbox')?.classList.contains('active')) showLightboxImage(currentGalleryIndex - 1);
            if (event.key === 'ArrowRight' && document.getElementById('productLightbox')?.classList.contains('active')) showLightboxImage(currentGalleryIndex + 1);
        });
    </script>
}

<style>
    .product-detail-page {
        background: #fff;
        padding: 1.25rem 0 4rem;
    }

    .product-breadcrumb {
        padding: 0.75rem 0 1.5rem;
    }

    .product-breadcrumb a {
        color: #4b5563;
        text-decoration: none;
    }

    .showroom-shell {
        display: grid;
        grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
        gap: clamp(1rem, 2.2vw, 1.75rem);
        align-items: start;
        background: transparent;
        border: 0;
        border-radius: 8px;
        padding: 0;
        box-shadow: none;
    }

    .showroom-gallery {
        min-width: 0;
    }

    .showroom-gallery.has-thumbs {
        display: grid;
        grid-template-columns: 84px minmax(0, 1fr);
        grid-template-areas: "thumbs main";
        gap: 0.85rem;
        align-items: start;
    }

    .gallery-frame {
        grid-area: main;
        position: relative;
        min-height: clamp(420px, 52vw, 620px);
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        overflow: hidden;
    }

    .gallery-main-button {
        width: 100%;
        height: 100%;
        min-height: inherit;
        border: 0;
        background: transparent;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: clamp(1.5rem, 5vw, 4rem);
        cursor: zoom-in;
    }

    .gallery-main-button img {
        width: 100%;
        height: 100%;
        max-height: 620px;
        object-fit: contain;
        transition: transform 0.25s ease;
    }

    .gallery-main-button:hover img {
        transform: scale(1.025);
    }

    .gallery-zoom-chip {
        position: absolute;
        right: 1rem;
        bottom: 1rem;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        border-radius: 999px;
        background: rgba(31, 41, 51, 0.9);
        color: #fff;
        padding: 0.55rem 0.8rem;
        font-size: 0.82rem;
        font-weight: 700;
    }

    .gallery-counter {
        position: absolute;
        left: 1rem;
        bottom: 1rem;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.92);
        color: #1f2933;
        border: 1px solid #e5e7eb;
        padding: 0.5rem 0.75rem;
        font-size: 0.82rem;
        font-weight: 800;
    }

    .gallery-empty {
        min-height: inherit;
        display: grid;
        place-items: center;
        color: #9ca3af;
        text-align: center;
    }

    .gallery-empty i {
        display: block;
        font-size: 5rem;
    }

    .gallery-arrow {
        position: absolute;
        top: 50%;
        z-index: 2;
        width: 44px;
        height: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(31, 41, 51, 0.12);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.94);
        color: #1f2933;
        transform: translateY(-50%);
        transition: all 0.18s ease;
    }

    .gallery-arrow:hover {
        background: #d47f31;
        border-color: #d47f31;
        color: #fff;
    }

    .gallery-arrow-prev {
        left: 1rem;
    }

    .gallery-arrow-next {
        right: 1rem;
    }

    .gallery-thumbnails {
        grid-area: thumbs;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        max-height: clamp(420px, 52vw, 620px);
        overflow-y: auto;
        overflow-x: hidden;
        padding-right: 0.2rem;
    }

    .gallery-thumb {
        width: 82px;
        height: 82px;
        flex: 0 0 82px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        background: #fff;
        padding: 4px;
    }

    .gallery-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 6px;
    }

    .gallery-thumb.active,
    .gallery-thumb:hover {
        border-color: #d47f31;
        box-shadow: 0 8px 18px rgba(31, 41, 51, 0.08);
    }

    .purchase-panel {
        position: sticky;
        top: 1rem;
        background: transparent;
        border: 0;
        border-left: 1px solid #e5e7eb;
        border-radius: 0;
        padding: clamp(0.6rem, 1.5vw, 1.1rem) 0 clamp(0.6rem, 1.5vw, 1.1rem) clamp(1rem, 2vw, 1.6rem);
        box-shadow: none;
    }

    .panel-kicker,
    .rating-line,
    .price-stack,
    .section-title {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.65rem;
    }

    .panel-kicker span {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        color: #6b7280;
        font-size: 0.78rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .purchase-panel h1 {
        margin: 0.8rem 0;
        color: #1f2933;
        font-size: clamp(2rem, 4vw, 3.25rem);
        line-height: 1.02;
        letter-spacing: 0;
    }

    .stars {
        display: inline-flex;
        color: #d47f31;
        gap: 0.12rem;
    }

    .rating-line a {
        color: #4b5563;
        text-decoration: none;
        font-size: 0.92rem;
    }

    .price-stack {
        margin: 1.4rem 0 1rem;
    }

    .price {
        color: #d47f31;
        font-size: clamp(2rem, 4vw, 2.75rem);
        font-weight: 800;
    }

    .old-price {
        color: #9ca3af;
        text-decoration: line-through;
    }

    .sale-chip {
        border-radius: 999px;
        background: #f4eee8;
        color: #8a4a19;
        padding: 0.4rem 0.7rem;
        font-weight: 800;
        font-size: 0.8rem;
    }

    .option-section {
        margin: 1.25rem 0;
    }

    .section-title {
        justify-content: space-between;
        margin-bottom: 0.85rem;
        font-weight: 800;
        color: #1f2933;
    }

    .section-title small {
        color: #6b7280;
        font-weight: 700;
    }

    .variant-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
    }

    .variant-card {
        min-height: 112px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        background: #fff;
        text-align: left;
        padding: 0.85rem;
        display: grid;
        gap: 0.25rem;
        color: #1f2933;
        transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease;
    }

    .variant-card:hover,
    .variant-card.selected {
        border-color: #d47f31;
        box-shadow: 0 12px 28px rgba(212, 127, 49, 0.14);
        transform: translateY(-1px);
    }

    .variant-card.is-disabled {
        opacity: 0.55;
        cursor: not-allowed;
    }

    .color-dot {
        width: 24px;
        height: 24px;
        border-radius: 999px;
        border: 2px solid #fff;
        box-shadow: 0 0 0 1px rgba(31, 41, 51, 0.16);
    }

    .variant-main {
        font-weight: 800;
    }

    .variant-sub,
    .variant-meta {
        color: #6b7280;
        font-size: 0.8rem;
    }

    .variant-price {
        color: #d47f31;
        font-size: 0.82rem;
        font-weight: 800;
    }

    .cart-form {
        margin: 1.25rem 0 0.75rem;
    }

    .buy-row {
        display: grid;
        grid-template-columns: 128px minmax(0, 1fr);
        gap: 0.8rem;
    }

    .quantity-stepper {
        height: 52px;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        display: grid;
        grid-template-columns: 38px 1fr 38px;
        overflow: hidden;
    }

    .quantity-stepper button,
    .quantity-stepper input {
        border: 0;
        background: #fff;
        text-align: center;
        min-width: 0;
    }

    .quantity-stepper button:hover {
        background: #f3f4f6;
    }

    .add-cart-btn {
        min-height: 52px;
        font-weight: 800;
    }

    .wishlist-btn {
        min-height: 48px;
        font-weight: 800;
    }

    .experience-actions {
        grid-column: 1 / -1;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.75rem;
        margin-top: 0.75rem;
        padding-top: 0.75rem;
        border-top: 1px solid #e5e7eb;
    }

    .experience-actions .btn {
        position: relative;
        overflow: hidden;
        min-height: 46px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease, background-color 0.18s ease;
    }

    .experience-actions .btn::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(110deg, transparent 0%, rgba(255,255,255,0.22) 45%, transparent 62%);
        transform: translateX(-120%);
        transition: transform 0.55s ease;
        pointer-events: none;
    }

    .experience-actions .btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 14px 30px rgba(31, 41, 51, 0.14);
    }

    .experience-actions .btn:hover::after {
        transform: translateX(120%);
    }

    .experience-actions .btn-outline-dark:hover {
        border-color: #d47f31;
        color: #d47f31;
        background: #fff;
        box-shadow: 0 14px 30px rgba(212, 127, 49, 0.14);
    }

    .micro-details {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.65rem;
        margin-top: 1rem;
    }

    .micro-details div {
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        padding: 0.75rem;
        background: #fff;
    }

    .micro-details span {
        display: block;
        color: #6b7280;
        font-size: 0.72rem;
        margin-bottom: 0.25rem;
    }

    .micro-details strong {
        display: block;
        color: #1f2933;
        font-size: 0.85rem;
        word-break: break-word;
    }

    .mini-advisor {
        display: grid;
        gap: 0.75rem;
        margin-top: 1rem;
        padding: 0.95rem;
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        background: #fff;
    }

    .mini-advisor-head {
        align-items: center;
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
    }

    .mini-advisor-head span {
        align-items: center;
        color: #1f2933;
        display: inline-flex;
        font-weight: 900;
        gap: 0.45rem;
    }

    .mini-advisor-head i {
        color: #d47f31;
    }

    .mini-advisor-head small {
        color: #6b7280;
        font-size: 0.75rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .mini-advisor textarea,
    .mini-advisor input {
        border: 1px solid #e5e7eb;
        border-radius: 8px;
        color: #1f2933;
        font-size: 0.9rem;
        outline: 0;
        padding: 0.75rem;
        width: 100%;
    }

    .mini-advisor textarea {
        min-height: 72px;
        resize: vertical;
    }

    .mini-advisor textarea:focus,
    .mini-advisor input:focus {
        border-color: #d47f31;
        box-shadow: 0 0 0 3px rgba(212, 127, 49, 0.12);
    }

    .mini-advisor-row {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 0.65rem;
    }

    .mini-advisor-row .btn {
        min-height: 44px;
        min-width: 112px;
        font-weight: 900;
    }

    .mini-advisor-result {
        border-top: 1px solid #eef0f2;
        display: grid;
        gap: 0.7rem;
        padding-top: 0.85rem;
    }

    .advisor-verdict {
        align-items: center;
        display: flex;
        justify-content: space-between;
        gap: 0.75rem;
    }

    .advisor-verdict strong {
        color: #1f2933;
        font-size: 1rem;
    }

    .advisor-verdict span {
        background: #f3f4f6;
        border-radius: 999px;
        color: #4b5563;
