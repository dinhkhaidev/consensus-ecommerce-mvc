@model WebActionResults.Models.Product

@{
    ViewData["Title"] = "Product Details";
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="page-hero d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title mb-1">Product Details</h1>
        <p class="text-secondary mb-0">Information about the selected product.</p>
    </div>
    <div class="d-flex gap-2">
        <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline">
            <input type="hidden" name="productId" value="@Model.ProductID" />
            <input type="hidden" name="quantity" value="1" />
            <input type="hidden" name="returnUrl" value="@returnUrl" />
            <button type="submit" class="btn btn-success">Add to Cart</button>
        </form>
        <a asp-action="Edit" asp-route-id="@Model.ProductID" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>

<div class="panel-card">
    <dl class="row mb-0">
        <dt class="col-sm-3">ID</dt>
        <dd class="col-sm-9">@Model.ProductID</dd>

        <dt class="col-sm-3">Product Name</dt>
        <dd class="col-sm-9 fw-semibold">@Model.ProductName</dd>

        <dt class="col-sm-3">Category</dt>
        <dd class="col-sm-9">@Model.Category.CategoryName</dd>

        <dt class="col-sm-3">Supplier</dt>
        <dd class="col-sm-9">@Model.Supplier.CompanyName</dd>

        <dt class="col-sm-3">Quantity Per Unit</dt>
        <dd class="col-sm-9">@Model.QuantityPerUnit</dd>

        <dt class="col-sm-3">Unit Price</dt>
        <dd class="col-sm-9">@Model.UnitPrice.ToString("N0")</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">
            @if (Model.Discontinued)
            {
                <span class="badge text-bg-secondary">Discontinued</span>
            }
            else
            {
                <span class="badge text-bg-success">Active</span>
            }
        </dd>
    </dl>
</div>
