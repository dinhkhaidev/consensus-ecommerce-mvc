@model WebActionResults.Models.Product

@{
    ViewData["Title"] = "Edit Product";

    var formViewData = new ViewDataDictionary(ViewData)
    {
        ["FormAction"] = "Edit",
        ["SubmitText"] = "Update",
        ["ShowProductId"] = true
    };
}

<div class="page-hero d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title mb-1">Edit Product</h1>
        <p class="text-secondary mb-0">Update product information.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<partial name="_ProductForm" model="Model" view-data="formViewData" />

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
