@model WebActionResults.ViewModels.ProductDetailViewModel

<div class="row">
    <!-- Product Images -->
    <div class="col-md-5">
        @if (Model.Images.Any())
        {
            var mainImage = Model.Images.FirstOrDefault(i => i.IsMain) ?? Model.Images.First();
            <div class="text-center p-3" style="background: #f8f9fa; border-radius: 8px;">
                <img src="@mainImage.ImageUrl" alt="@Model.ProductName"
                     class="img-fluid rounded" style="max-height: 250px; object-fit: contain;">
            </div>
        }
        else
        {
            <div class="d-flex align-items-center justify-content-center bg-light rounded" style="height: 180px;">
                <i class="bi bi-image text-secondary" style="font-size: 3rem;"></i>
            </div>
        }
    </div>

    <!-- Product Info -->
    <div class="col-md-7">
        <h5 class="fw-bold mb-2">@Model.ProductName</h5>
        <p class="text-muted small mb-2">
            <i class="bi bi-tag me-1"></i>@Model.CategoryName
        </p>

        @if (Model.AverageRating > 0)
        {
            <div class="mb-2">
                @for (int i = 1; i <= 5; i++)
                {
                    <i class="bi @(i <= Model.AverageRating ? "bi-star-fill text-warning" : "bi-star text-muted")"></i>
                }
                <span class="small text-muted">(@Model.ReviewCount reviews)</span>
            </div>
        }

        <h4 class="text-primary fw-bold mb-2">@Model.UnitPrice.ToString("N0") VND</h4>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="small text-muted mb-3">@Model.Description</p>
        }

        <!-- Variants with Price Details -->
        @if (Model.Variants.Any())
        {
            <div class="mb-3">
                <small class="fw-semibold text-muted">Selected Options:</small>
                <div class="mt-2">
                    @foreach (var variant in Model.Variants)
                    {
                        var adjustment = variant.PriceAdjustment ?? 0;
                        var variantPrice = Model.UnitPrice + adjustment;
                        var priceChange = adjustment != 0;
                        <div class="d-flex justify-content-between align-items-center py-2 px-3 mb-1 rounded @(priceChange ? "bg-light" : "")" style="border: 1px solid #eee;">
                            <div>
                                <span class="fw-semibold">@variant.Color</span>
                                @if (!string.IsNullOrEmpty(variant.Size))
                                {
                                    <span class="text-muted"> / @variant.Size</span>
                                }
                                @if (!string.IsNullOrEmpty(variant.SKU))
                                {
                                    <span class="text-muted small ms-2">SKU: @variant.SKU</span>
                                }
                            </div>
                            <div class="text-end">
                                @if (priceChange)
                                {
                                    <span class="text-muted text-decoration-line-through small">@Model.UnitPrice.ToString("N0")</span>
                                    <span class="text-success fw-bold ms-1">+@adjustment.ToString("N0") VND</span>
                                }
                                <span class="fw-bold ms-1">@variantPrice.ToString("N0") VND</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Stock info -->
        @if (Model.Variants.Any())
        {
            var totalStock = Model.Variants.Sum(v => v.StockQuantity);
            <p class="small mb-0">
                <i class="bi bi-box me-1"></i>
                @(totalStock > 0 ? $"{totalStock} units available" : "Out of stock")
            </p>
        }
    </div>
</div>

<!-- Reviews -->
@if (Model.Reviews.Any())
{
    <div class="mt-3 pt-2 border-top">
        <h6 class="fw-bold mb-2">Customer Reviews</h6>
        @foreach (var review in Model.Reviews.Take(3))
        {
            <div class="mb-2 p-2 bg-light rounded">
                <div class="d-flex justify-content-between">
                    <strong class="small">@review.UserName</strong>
                    <small class="text-muted">@review.CreatedAt.ToString("MMM dd, yyyy")</small>
                </div>
                <div class="text-warning small">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi @(i <= review.Rating ? "bi-star-fill" : "bi-star")"></i>
                    }
                </div>
                <p class="mb-0 small text-muted">@review.Comment</p>
            </div>
        }
    </div>
}