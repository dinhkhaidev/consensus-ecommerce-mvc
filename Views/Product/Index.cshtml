@model IEnumerable<WebActionResults.ViewModels.ProductListViewModel>
@{
    ViewData["Title"] = localizer.Get("Products");
    var returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
    var categories = ViewBag.Categories as IEnumerable<WebActionResults.ViewModels.CategoryViewModel> ?? Enumerable.Empty<WebActionResults.ViewModels.CategoryViewModel>();
    var selectedCategory = ViewData["SelectedCategoryId"] as int?;
    var currentPage = (int)(ViewData["CurrentPage"] ?? 1);
    var totalPages = (int)(ViewData["TotalPages"] ?? 1);
    var totalCount = (int)(ViewData["TotalCount"] ?? 0);
    var searchTerm = ViewData["SearchTerm"] as string;
    var sortBy = Context.Request.Query["sort"].ToString();
    var priceRange = Context.Request.Query["priceRange"].ToString();
    var minPriceStr = Context.Request.Query["minPrice"].ToString();
    var maxPriceStr = Context.Request.Query["maxPrice"].ToString();
    int? minPrice = int.TryParse(minPriceStr, out var mp) ? mp : (int?)null;
    int? maxPrice = int.TryParse(maxPriceStr, out var xp) ? xp : (int?)null;
}

<!-- Page Header -->
<section class="py-lg-8 py-5 bg-light">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <h1 class="display-5 fw-bold mb-3">@localizer.Get("OurCollection")</h1>
                <p class="text-muted lead">
                    @if (!string.IsNullOrEmpty(searchTerm))
                    {
                        <span>@localizer.Get("SearchResultsFor") "<strong>@searchTerm</strong>"</span>
                    }
                    else if (selectedCategory.HasValue)
                    {
                        <span>@localizer.Get("BrowseProductsByCategory")</span>
                    }
                    else
                    {
                        <span>@localizer.Get("DiscoverPremiumFurniture")</span>
                    }
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="py-lg-8 py-5">
    <div class="container">
        <div class="row">
            <!-- Sidebar Filters -->
            <aside class="col-lg-3 mb-4">
                <div class="card border-0 shadow-sm" style="position: sticky; top: 80px;">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="fw-bold mb-0">
                                <i class="bi bi-funnel me-2"></i>@localizer.Get("Filters")
                            </h5>
                            @if (selectedCategory.HasValue || !string.IsNullOrEmpty(searchTerm))
                            {
                                <a asp-action="Index" class="btn btn-sm btn-outline-danger">@localizer.Get("ClearAll")</a>
                            }
                        </div>

                        <!-- Search Form -->
                        <form method="get" asp-action="Index" class="mb-4">
                            <div class="input-group">
                                <input type="text" name="search" class="form-control"
                                       placeholder="@localizer.Get("SearchPlaceholder")"
                                       value="@searchTerm">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-search"></i>
                                </button>
                            </div>
                        </form>

                        <!-- Category Filter -->
                        <div class="mb-4">
                            <h6 class="fw-semibold text-uppercase text-xs mb-3 text-muted">
                                <i class="bi bi-grid-3x3-gap me-1"></i> @localizer.Get("Category")
                            </h6>
                            <ul class="list-unstyled">
                                <li class="mb-2">
                                    <a href="@Url.Action("Index", "Product")"
                                       class="text-decoration-none @(selectedCategory == null ? "fw-bold text-primary" : "text-dark") d-flex align-items-center justify-content-between p-2 rounded">
                                        <span><i class="bi bi-grid me-2"></i>@localizer.Get("AllProducts")</span>
                                        <span class="badge bg-secondary">@totalCount</span>
                                    </a>
                                </li>
                                @foreach (var cat in categories)
                                {
                                    <li class="mb-2">
                                        <a href="@Url.Action("Index", "Product", new { categoryId = cat.CategoryId })"
                                           class="text-decoration-none @(selectedCategory == cat.CategoryId ? "fw-bold text-primary bg-light" : "text-dark") d-flex align-items-center justify-content-between p-2 rounded hover-bg-light">
                                            <span><i class="bi bi-chevron-right me-2"></i>@cat.CategoryName</span>
                                            <span class="badge bg-@(selectedCategory == cat.CategoryId ? "primary" : "secondary")">@cat.ProductCount</span>
                                        </a>
                                    </li>
                                }
                            </ul>
                        </div>

                        <!-- Price Filter -->
                        <div class="mb-4">
                            <h6 class="fw-semibold text-uppercase text-xs mb-3 text-muted">
                                <i class="bi bi-currency-dollar me-1"></i> @localizer.Get("PriceRange")
                            </h6>
                            <form method="get" asp-action="Index" class="mb-3">
                                @if (selectedCategory.HasValue)
                                {
                                    <input type="hidden" name="categoryId" value="@selectedCategory" />
                                }
                                @if (!string.IsNullOrEmpty(searchTerm))
                                {
                                    <input type="hidden" name="search" value="@searchTerm" />
                                }
                                <div class="row g-2">
                                    <div class="col-6">
                                        <input type="number" name="minPrice" class="form-control form-control-sm" placeholder="@localizer.Get("MinVND")" min="0">
                                    </div>
                                    <div class="col-6">
                                        <input type="number" name="maxPrice" class="form-control form-control-sm" placeholder="@localizer.Get("MaxVND")" min="0">
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-primary btn-sm w-100 mt-2">
                                    <i class="bi bi-search me-1"></i>@localizer.Get("Apply")
                                </button>
                            </form>
                            <hr class="my-3">
                            <form method="get" asp-action="Index">
                                @if (selectedCategory.HasValue)
                                {
                                    <input type="hidden" name="categoryId" value="@selectedCategory" />
                                }
                                @if (!string.IsNullOrEmpty(searchTerm))
                                {
                                    <input type="hidden" name="search" value="@searchTerm" />
                                }
                                <div class="d-grid gap-2">
                                    <a href="@Url.Action("Index", "Product", new { categoryId = selectedCategory, search = searchTerm, priceRange = "under-2000000" })"
                                       class="btn btn-outline-secondary btn-sm text-start @(sortBy == "under-2000000" ? "active" : "")">
                                        @localizer.Get("Under2Million")
                                    </a>
                                    <a href="@Url.Action("Index", "Product", new { categoryId = selectedCategory, search = searchTerm, priceRange = "2000000-5000000" })"
                                       class="btn btn-outline-secondary btn-sm text-start">
                                        @localizer.Get("Between2And5Million")
                                    </a>
                                    <a href="@Url.Action("Index", "Product", new { categoryId = selectedCategory, search = searchTerm, priceRange = "5000000-10000000" })"
                                       class="btn btn-outline-secondary btn-sm text-start">
                                        @localizer.Get("Between5And10Million")
                                    </a>
                                    <a href="@Url.Action("Index", "Product", new { categoryId = selectedCategory, search = searchTerm, priceRange = "above-10000000" })"
                                       class="btn btn-outline-secondary btn-sm text-start">
                                        @localizer.Get("Above10Million")
                                    </a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </aside>

            <!-- Product Grid -->
            <div class="col-lg-9">
                <!-- Sort & Results Info -->
                <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
                    <div class="text-muted">
                        @if (totalCount > 0)
                        {
                            <span>@localizer.Get("Showing") <strong>@((currentPage - 1) * 12 + 1)-@(Math.Min(currentPage * 12, totalCount))</strong> @localizer.Get("Of") <strong>@totalCount</strong> @localizer.Get("Products").ToLower()</span>
                        }
                        else
                        {
                            <span>@localizer.Get("NoProductsFound")</span>
                        }
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <label class="text-muted small">@localizer.Get("SortBy"):</label>
                        <select class="form-select form-select-sm" style="width: auto;"
                                onchange="window.location.href=this.value">
                            @{
                                var sortUrl = Url.Action("Index", "Product", new { categoryId = selectedCategory, search = searchTerm, sort = "", priceRange, minPrice, maxPrice });
                            }
                            <option value="@sortUrl" selected="@(string.IsNullOrEmpty(sortBy))">@localizer.Get("Featured")</option>
                            @{
                                sortUrl = Url.Action("Index", "Product", new { categoryId = selectedCategory, search = searchTerm, sort = "price_asc", priceRange, minPrice, maxPrice });
                            }
                            <option value="@sortUrl" selected="@(sortBy == "price_asc")">@localizer.Get("PriceLowHigh")</option>
                            @{
                                sortUrl = Url.Action("Index", "Product", new { categoryId = selectedCategory, search = searchTerm, sort = "price_desc", priceRange, minPrice, maxPrice });
                            }
                            <option value="@sortUrl" selected="@(sortBy == "price_desc")">@localizer.Get("PriceHighLow")</option>
                            @{
                                sortUrl = Url.Action("Index", "Product", new { categoryId = selectedCategory, search = searchTerm, sort = "name_asc", priceRange, minPrice, maxPrice });
                            }
                            <option value="@sortUrl" selected="@(sortBy == "name_asc")">@localizer.Get("NameAZ")</option>
                            @{
                                sortUrl = Url.Action("Index", "Product", new { categoryId = selectedCategory, search = searchTerm, sort = "name_desc", priceRange, minPrice, maxPrice });
                            }
                            <option value="@sortUrl" selected="@(sortBy == "name_desc")">@localizer.Get("NameZA")</option>
                        </select>
                    </div>
                </div>

                <!-- Active Filters -->
                @if (selectedCategory.HasValue || !string.IsNullOrEmpty(searchTerm))
                {
                    <div class="mb-4">
                        <div class="d-flex flex-wrap gap-2 align-items-center">
                            <span class="text-muted small">@localizer.Get("ActiveFilters"):</span>
                            @if (selectedCategory.HasValue)
                            {
                                var catName = categories.FirstOrDefault(c => c.CategoryId == selectedCategory)?.CategoryName;
                                <span class="badge bg-primary d-flex align-items-center gap-1">
                                    @catName
                                    <a href="@Url.Action("Index", "Product", new { search = searchTerm })"
                                       class="text-white text-decoration-none">
                                        <i class="bi bi-x"></i>
                                    </a>
                                </span>
                            }
                            @if (!string.IsNullOrEmpty(searchTerm))
                            {
                                <span class="badge bg-info d-flex align-items-center gap-1">
                                    "@searchTerm"
                                    <a href="@Url.Action("Index", "Product", new { categoryId = selectedCategory })"
                                       class="text-white text-decoration-none">
                                        <i class="bi bi-x"></i>
                                    </a>
                                </span>
                            }
                        </div>
                    </div>
                }

                <!-- Products Grid -->
                @if (!Model.Any())
                {
                    <div class="alert alert-secondary text-center py-5">
                        <i class="bi bi-search" style="font-size: 4rem;"></i>
                        <h5 class="mt-3 mb-2">@localizer.Get("NoProductsFound")</h5>
                        <p class="text-muted mb-4">@localizer.Get("TryAdjustingFilters")</p>
                        <a asp-action="Index" class="btn btn-primary">
                            <i class="bi bi-arrow-left me-2"></i>@localizer.Get("ViewAllProducts")
                        </a>
                    </div>
                }
                else
                {
                    <div class="row g-4">
                        @foreach (var item in Model)
                        {
                            <div class="col-sm-6 col-md-4">
                                <div class="card product-card h-100 border-0 shadow-sm hover-lift">
                                    @if (!string.IsNullOrEmpty(item.MainImageUrl))
                                    {
                                        <a asp-action="Details" asp-route-id="@item.ProductId" class="product-img-wrapper">
                                            <img src="@item.MainImageUrl" class="card-img-top object-fit-cover"
                                                 alt="@item.ProductName" style="height: 220px;"
                                                 onerror="this.src='/assets/images/product-placeholder.jpg'">
                                            @if (item.HasVariants)
                                            {
                                                <span class="badge bg-dark position-absolute top-0 end-0 m-2">
                                                    <i class="bi bi-palette me-1"></i>@localizer.Get("MultipleColors")
                                                </span>
                                            }
                                        </a>
                                    }
                                    else
                                    {
                                        <div class="card-img-top d-flex align-items-center justify-content-center bg-light" style="height: 220px;">
                                            <i class="bi bi-image text-secondary" style="font-size: 4rem;"></i>
                                        </div>
                                    }
                                    <div class="card-body text-center">
                                        <p class="text-muted mb-2 text-uppercase text-xs">@item.CategoryName</p>
                                        <h3 class="h6 mb-2">
                                            <a asp-action="Details" asp-route-id="@item.ProductId"
                                               class="text-decoration-none text-dark product-name">@item.ProductName</a>
                                        </h3>
                                        <div class="price-wrapper mb-3">
                                            <span class="fw-bold text-primary fs-5">@item.UnitPrice.ToString("N0") VND</span>
                                        </div>
                                        <div class="d-flex gap-2">
                                            <form asp-controller="Cart" asp-action="Add" method="post" class="flex-grow-1">
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <input type="hidden" name="quantity" value="1" />
                                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                <button type="submit" class="btn btn-primary btn-sm w-100">
                                                    <i class="bi bi-cart-plus me-1"></i>@localizer.Get("Add")
                                                </button>
                                            </form>
                                            <form asp-controller="Wishlist" asp-action="Add" method="post">
                                                <input type="hidden" name="productId" value="@item.ProductId" />
                                                <input type="hidden" name="returnUrl" value="@returnUrl" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                                    <i class="bi bi-heart"></i>
                                                </button>
                                            </form>
                                            <a asp-action="Details" asp-route-id="@item.ProductId"
                                               class="btn btn-outline-secondary btn-sm">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Pagination -->
                    @if (totalPages > 1)
                    {
                        <nav class="mt-5" aria-label="Product pagination">
                            <ul class="pagination justify-content-center">
                                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                    <a class="page-link"
                                       href="@Url.Action("Index", "Product", new { page = currentPage - 1, categoryId = selectedCategory, search = searchTerm, sort = sortBy, priceRange, minPrice, maxPrice })">
                                        <i class="bi bi-chevron-left"></i>
                                    </a>
                                </li>

                                @{
                                    var startPage = Math.Max(1, currentPage - 2);
                                    var endPage = Math.Min(totalPages, startPage + 4);

                                    if (endPage - startPage < 4)
                                    {
                                        startPage = Math.Max(1, endPage - 4);
                                    }
                                }

                                @if (startPage > 1)
                                {
                                    <li class="page-item">
                                        <a class="page-link" href="@Url.Action("Index", "Product", new { page = 1, categoryId = selectedCategory, search = searchTerm, sort = sortBy, priceRange, minPrice, maxPrice })">1</a>
                                    </li>
                                    @if (startPage > 2)
                                    {
                                        <li class="page-item disabled"><span class="page-link">...</span></li>
                                    }
                                }

                                @for (int i = startPage; i <= endPage; i++)
                                {
                                    <li class="page-item @(i == currentPage ? "active" : "")">
                                        <a class="page-link"
                                           href="@Url.Action("Index", "Product", new { page = i, categoryId = selectedCategory, search = searchTerm, sort = sortBy, priceRange, minPrice, maxPrice })">
                                            @i
                                        </a>
                                    </li>
                                }

                                @if (endPage < totalPages)
                                {
                                    @if (endPage < totalPages - 1)
                                    {
                                        <li class="page-item disabled"><span class="page-link">...</span></li>
                                    }
                                    <li class="page-item">
                                        <a class="page-link"
                                           href="@Url.Action("Index", "Product", new { page = totalPages, categoryId = selectedCategory, search = searchTerm, sort = sortBy, priceRange, minPrice, maxPrice })">
                                            @totalPages
                                        </a>
                                    </li>
                                }

                                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                                    <a class="page-link"
                                       href="@Url.Action("Index", "Product", new { page = currentPage + 1, categoryId = selectedCategory, search = searchTerm, sort = sortBy, priceRange, minPrice, maxPrice })">
                                        <i class="bi bi-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    }
                }
            </div>
        </div>
    </div>
</section>

<style>
    .product-card {
        transition: all 0.3s ease;
    }

    .product-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0,0,0,0.12) !important;
    }

    .product-img-wrapper {
        position: relative;
        overflow: hidden;
        display: block;
    }

    .product-img-wrapper img {
        transition: transform 0.4s ease;
    }

    .product-img-wrapper:hover img {
        transform: scale(1.08);
    }

    .product-name {
        transition: color 0.2s ease;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .product-card:hover .product-name {
        color: #d47f31 !important;
    }

    .hover-lift:hover {
        transform: translateY(-5px);
    }

    .hover-bg-light:hover {
        background-color: rgba(0,0,0,0.05);
    }

    .form-select:focus {
        border-color: #d47f31;
        box-shadow: 0 0 0 0.2rem rgba(212, 127, 49, 0.25);
    }
</style>
