@model IEnumerable<WebActionResults.ViewModels.OrderListViewModel>
@{
    ViewData["Title"] = localizer.Get("MyOrders") + " - Furnish";
}

<!-- Breadcrumb -->
<section class="py-3 bg-light">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">@localizer.Get("Home")</a></li>
                <li class="breadcrumb-item"><a asp-controller="Account" asp-action="Profile" class="text-decoration-none">@localizer.Get("Profile")</a></li>
                <li class="breadcrumb-item active">@localizer.Get("Orders")</li>
            </ol>
        </nav>
    </div>
</section>

<section class="py-lg-8 py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h1 class="display-5 fw-bold mb-3">
                <i class="bi bi-box-seam me-2"></i>@localizer.Get("MyOrders")
            </h1>
            <p class="text-muted lead">@localizer.Get("NoOrdersYet")</p>
        </div>

        @if (!Model.Any())
        {
            <div class="row justify-content-center">
                <div class="col-lg-6 text-center">
                    <div class="card border-0 shadow-sm py-5">
                        <div class="card-body">
                            <i class="bi bi-bag-x text-muted" style="font-size: 6rem;"></i>
                            <h4 class="mt-4 mb-3">@localizer.Get("NoOrdersYet")</h4>
                            <p class="text-muted mb-4">@localizer.Get("StartShopping")</p>
                            <a asp-controller="Product" asp-action="Index" class="btn btn-primary btn-lg">
                                <i class="bi bi-bag me-2"></i>@localizer.Get("Products")
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var order in Model)
                {
                    <div class="col-12">
                        <div class="card border-0 shadow-sm hover-lift">
                            <div class="card-body py-4">
                                <div class="row align-items-center gy-3">
                                    <div class="col-lg-2">
                                        <span class="text-muted small text-uppercase fw-semibold">@localizer.Get("OrderNumber")</span>
                                        <h5 class="mb-0 text-primary fw-bold">#@order.OrderNumber</h5>
                                    </div>
                                    <div class="col-lg-2">
                                        <span class="text-muted small text-uppercase fw-semibold">@localizer.Get("OrderDate")</span>
                                        <p class="mb-0">@order.CreatedAt.ToString("MMM dd, yyyy")</p>
                                    </div>
                                    <div class="col-lg-2">
                                        <span class="text-muted small text-uppercase fw-semibold">@localizer.Get("Product")</span>
                                        <p class="mb-0">@order.ItemCount @localizer.Get("UnitsAvailable")</p>
                                    </div>
                                    <div class="col-lg-2">
                                        <span class="text-muted small text-uppercase fw-semibold">@localizer.Get("Total")</span>
                                        <p class="mb-0 fw-bold text-primary fs-5">@order.TotalAmount.ToString("N0") VND</p>
                                    </div>
                                    <div class="col-lg-2">
                                        <span class="badge bg-@GetStatusBadgeClass(order.Status) px-3 py-2">
                                            <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem;"></i>
                                            @order.StatusText
                                        </span>
                                    </div>
                                    <div class="col-lg-2 text-lg-end">
                                        <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-outline-primary">
                                            <i class="bi bi-eye me-1"></i>@localizer.Get("ViewDetails")
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>

@{
    string GetStatusBadgeClass(WebActionResults.Data.Entities.OrderStatus status) => status switch
    {
        WebActionResults.Data.Entities.OrderStatus.Pending => "warning text-dark",
        WebActionResults.Data.Entities.OrderStatus.Confirmed => "info",
        WebActionResults.Data.Entities.OrderStatus.Processing => "primary",
        WebActionResults.Data.Entities.OrderStatus.Shipped => "info",
        WebActionResults.Data.Entities.OrderStatus.Delivered => "success",
        WebActionResults.Data.Entities.OrderStatus.Cancelled => "danger",
        WebActionResults.Data.Entities.OrderStatus.CancellationRequested => "warning text-dark",
        WebActionResults.Data.Entities.OrderStatus.ReturnRequested => "warning text-dark",
        WebActionResults.Data.Entities.OrderStatus.ReturnApproved => "success",
        WebActionResults.Data.Entities.OrderStatus.ReturnRejected => "danger",
        _ => "secondary"
    };
}

<style>
    .card {
        border-radius: 1rem;
    }

    .hover-lift:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 20px rgba(0,0,0,0.1) !important;
    }
</style>
