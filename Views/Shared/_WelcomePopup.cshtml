@{
    var settings = ViewData["WebSettings"] as Dictionary<string, string> ?? new();
    var enabled = string.Equals(settings.GetValueOrDefault("PopupEnabled", settings.GetValueOrDefault("EnableNewsletterPopup", "false")), "true", StringComparison.OrdinalIgnoreCase);
    var title = settings.GetValueOrDefault("PopupTitle", "Welcome!");
    var content = settings.GetValueOrDefault("PopupContent", settings.GetValueOrDefault("NewsletterDesc", "Get the latest offers and new arrivals from our store."));
    var imageUrl = settings.GetValueOrDefault("PopupImageUrl", "");
    var delay = settings.GetValueOrDefault("PopupDelay", "3000");
    var signature = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes($"{title}|{content}|{imageUrl}"));
}

@if (enabled && !string.IsNullOrWhiteSpace(content))
{
    <!-- Welcome Popup -->
    <div class="modal fade" id="welcomePopupModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content border-0 shadow-lg overflow-hidden" style="border-radius: 1.2rem;">
                <button type="button" class="btn-close position-absolute top-0 end-0 m-3 z-3"
                        data-bs-dismiss="modal" aria-label="Close"></button>
                <div class="row g-0">
                    @if (!string.IsNullOrWhiteSpace(imageUrl))
                    {
                        <div class="col-md-5 d-none d-md-block">
                            <img src="@imageUrl" alt="@title"
                                 class="w-100 h-100 object-fit-cover" style="min-height: 320px;" />
                        </div>
                    }
                    <div class="col-md-@(!string.IsNullOrWhiteSpace(imageUrl) ? "7" : "12")">
                        <div class="p-5 d-flex flex-column justify-content-center h-100">
                            <div class="text-center text-md-start">
                                <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 mb-3 d-inline-block"
                                      style="font-size: 0.75rem; border-radius: 2rem;">
                                    <i class="bi bi-gift me-1"></i>Special Offer
                                </span>
                                <h3 class="fw-bold mb-3" style="font-size: 1.6rem; line-height: 1.3;">@title</h3>
                                <p class="text-muted mb-4">@content</p>
                                <a asp-controller="Product" asp-action="Index"
                                   class="btn btn-primary btn-lg px-5 rounded-pill"
                                   data-bs-dismiss="modal">
                                    <i class="bi bi-bag me-2"></i>@localizer.Get("ShopNow")
                                </a>
                                <div class="mt-3">
                                    <a href="#" class="text-muted small text-decoration-none" data-bs-dismiss="modal">
                                        No thanks, just browsing
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        #welcomePopupModal .modal-content {
            animation: popupSlideUp 0.4s ease-out;
        }

        @@keyframes popupSlideUp {
            from { transform: translateY(30px) scale(0.95); opacity: 0; }
            to { transform: translateY(0) scale(1); opacity: 1; }
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (localStorage.getItem('welcomePopupShown:@signature')) return;

            setTimeout(function () {
                var popupEl = document.getElementById('welcomePopupModal');
                if (popupEl && typeof bootstrap !== 'undefined') {
                    var modal = new bootstrap.Modal(popupEl);
                    modal.show();
                    localStorage.setItem('welcomePopupShown:@signature', '1');
                }
            }, @delay);
        });
    </script>
}
