@{
    var currentLang = localizer.CurrentLanguage;
    var settings = ViewData["WebSettings"] as Dictionary<string, string> ?? new();
    var storeName = settings.GetValueOrDefault("StoreName", localizer.Get("AppName"));
    var logoUrl = settings.GetValueOrDefault("LogoUrl", "");
    var tagline = settings.GetValueOrDefault("SiteTagline", "Premium Furniture");
    var userAvatarUrl = Context.Session.GetString("USER_AVATAR") ?? "";
    var userInitial = Context.Session.GetString("USER_NAME")?.FirstOrDefault().ToString() ?? "";
}
<nav class="navbar navbar-expand-lg bg-white shadow-sm sticky-top px-4 py-2 navbar-custom">
    <div class="container-fluid">
        <!-- Logo -->
        <a class="navbar-brand d-flex align-items-center me-3" asp-area="" asp-controller="Home" asp-action="Index">
            @if (!string.IsNullOrWhiteSpace(logoUrl))
            {
                <img src="@logoUrl" alt="@storeName" class="site-logo-img me-2"
                     onerror="this.classList.add('d-none'); this.nextElementSibling.classList.remove('d-none');" />
            }
            <span class="site-logo-fallback me-2 @(!string.IsNullOrWhiteSpace(logoUrl) ? "d-none" : "")">
                <i class="bi bi-house-door-fill"></i>
            </span>
            <div class="d-flex flex-column lh-sm">
                <span class="fw-bold text-uppercase" style="letter-spacing: .15rem; font-size: 0.85rem;">@storeName</span>
                <span class="text-muted" style="font-size: 0.6rem;">@tagline</span>
            </div>
        </a>

        <!-- Desktop Navigation -->
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav mx-auto">
                <li class="nav-item">
                    <a class="nav-link px-3 @(Context.Request.Path.Value == "/" ? "active" : "")" asp-controller="Home" asp-action="Index">@localizer.Get("Home")</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link px-3 @(Context.Request.Path.Value?.StartsWith("/Product") == true ? "active" : "")" asp-controller="Product" asp-action="Index">@localizer.Get("Shop")</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link px-3 @(Context.Request.Path.Value?.StartsWith("/Room3D") == true ? "active" : "")" asp-controller="Room3D" asp-action="Index">3D Room</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link px-3 @(Context.Request.Path.Value?.StartsWith("/Category") == true ? "active" : "")" asp-controller="Category" asp-action="Index">@localizer.Get("Categories")</a>
                </li>
            </ul>
        </div>

        <!-- Right Icons -->
        <div class="d-flex align-items-center gap-2">
            <!-- Language Switcher -->
            <div class="dropdown">
                <a class="nav-link p-2 dropdown-toggle" href="#" data-bs-toggle="dropdown" title="@localizer.Get("Language")">
                    <i class="bi bi-globe fs-5"></i>
                    <span class="d-none d-lg-inline ms-1">@currentLang.ToUpper()</span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 py-2" style="min-width: 140px;">
                    <li>
                        <a class="dropdown-item py-2 @(currentLang == "en" ? "active" : "")" asp-controller="Language" asp-action="Switch" asp-route-lang="en" asp-route-returnUrl="@Context.Request.Path">
                            <i class="bi bi-check me-2 @(currentLang != "en" ? "invisible" : "")"></i>English
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item py-2 @(currentLang == "vi" ? "active" : "")" asp-controller="Language" asp-action="Switch" asp-route-lang="vi" asp-route-returnUrl="@Context.Request.Path">
                            <i class="bi bi-check me-2 @(currentLang != "vi" ? "invisible" : "")"></i>Tiếng Việt
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Search -->
            <form method="get" asp-controller="Product" asp-action="Index" class="d-none d-md-flex">
                <div class="input-group input-group-sm">
                    <input type="text" name="search" class="form-control" placeholder="@localizer.Get("SearchPlaceholder")">
                    <button type="submit" class="btn btn-outline-secondary">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </form>

            <!-- Cart Icon -->
            <a class="nav-link position-relative p-2" asp-controller="Cart" asp-action="Index" title="@localizer.Get("ShoppingCart")">
                <i class="bi bi-cart3 fs-5"></i>
                <span id="cartBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem; display: none;">0</span>
            </a>

            <!-- User Menu -->
            @if (Context.Session.GetInt32("USER_ID").HasValue)
            {
                <div class="dropdown">
                    <a class="nav-link dropdown-toggle p-2" href="#" data-bs-toggle="dropdown">
                        <span class="user-avatar-shell d-inline-flex align-items-center justify-content-center">
                            @if (!string.IsNullOrWhiteSpace(userAvatarUrl))
                            {
                                <img src="@userAvatarUrl" alt="@Context.Session.GetString("USER_NAME")"
                                     class="user-avatar-img"
                                     onerror="this.classList.add('d-none'); this.nextElementSibling.classList.remove('d-none');" />
                            }
                            <span class="user-avatar d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white @(!string.IsNullOrWhiteSpace(userAvatarUrl) ? "d-none" : "")">
                                @userInitial
                            </span>
                        </span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 py-2" style="min-width: 200px;">
                        <li class="px-3 py-2 text-muted small">
                            <strong>@Context.Session.GetString("USER_NAME")</strong>
                        </li>
                        <li><hr class="dropdown-divider mx-3"></li>
                        <li><a class="dropdown-item py-2" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>@localizer.Get("Profile")</a></li>
                        <li><a class="dropdown-item py-2" asp-controller="Order" asp-action="Index"><i class="bi bi-box-seam me-2"></i>@localizer.Get("Orders")</a></li>
                        @if (string.Equals(settings.GetValueOrDefault("EnableWishlist", "true"), "true", StringComparison.OrdinalIgnoreCase))
                        {
                            <li><a class="dropdown-item py-2" asp-controller="Wishlist" asp-action="Index"><i class="bi bi-heart me-2"></i>@localizer.Get("Wishlist")</a></li>
                        }
                        <li><hr class="dropdown-divider mx-3"></li>
                        <li>
                            <form asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="dropdown-item py-2 text-danger">
                                    <i class="bi bi-box-arrow-right me-2"></i>@localizer.Get("Logout")
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
            else
            {
                <a class="btn btn-outline-primary btn-sm" asp-controller="Account" asp-action="Login">@localizer.Get("Login")</a>
            }

            <!-- Mobile Menu -->
            <a class="nav-link d-lg-none p-2" data-bs-toggle="offcanvas" href="#offcanvasMenu">
                <i class="bi bi-list fs-4"></i>
            </a>
        </div>
    </div>
</nav>

<script>
    async function updateCartBadge() {
        try {
            const res = await fetch('/Cart/GetCartCount');
            const data = await res.json();
            const badge = document.getElementById('cartBadge');
            if (badge) {
                if (data.count > 0) {
                    badge.textContent = data.count;
                    badge.style.display = 'inline-block';
                } else {
                    badge.style.display = 'none';
                }
            }
        } catch (e) {}
    }
    updateCartBadge();
</script>

<style>
    .navbar-custom {
        z-index: 1020;
    }

    .nav-link {
        color: #333;
        font-weight: 500;
        transition: color 0.2s;
    }

    .nav-link:hover {
        color: #000;
    }

    .nav-link.active {
        color: #000;
        font-weight: 600;
    }

    .user-avatar {
        font-weight: 600;
        width: 32px;
        height: 32px;
        font-size: 0.875rem;
    }

    .user-avatar-img {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        object-fit: cover;
        border: 1px solid rgba(0, 0, 0, 0.08);
    }

    .site-logo-img {
        height: 36px;
        width: auto;
        max-width: 120px;
        object-fit: contain;
    }

    .site-logo-fallback {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: #d47f31;
        background: rgba(212, 127, 49, 0.12);
        font-size: 1.25rem;
    }

    .dropdown-menu {
        border-radius: 0.75rem;
    }

    .dropdown-item:hover {
        background-color: rgba(0, 0, 0, 0.05);
        color: #000;
    }

    .nav-link.dropdown-toggle::after {
        display: none;
    }
</style>
