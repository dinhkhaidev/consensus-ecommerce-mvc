@model WebActionResults.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = localizer.Get("Checkout") + " - Furnish";
    var addresses = ViewBag.Addresses as List<WebActionResults.ViewModels.AddressViewModel> ?? new();
}

<!-- Breadcrumb -->
<section class="py-3 bg-light">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">@localizer.Get("Home")</a></li>
                <li class="breadcrumb-item"><a asp-controller="Cart" asp-action="Index" class="text-decoration-none">@localizer.Get("Cart")</a></li>
                <li class="breadcrumb-item active">@localizer.Get("Checkout")</li>
            </ol>
        </nav>
    </div>
</section>

<section class="py-lg-8 py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h1 class="display-5 fw-bold mb-3">
                <i class="bi bi-bag-check me-2"></i>@localizer.Get("Checkout")
            </h1>
            <p class="text-muted lead">@localizer.Get("SecureCheckout")</p>
        </div>

        <form asp-action="ProcessCheckout" method="post">
            <input type="hidden" name="couponCode" value="@Model.CouponCode" />

            <div class="row g-4">
                <div class="col-lg-8">
                    <!-- Shipping Address -->
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white py-3">
                            <h5 class="mb-0"><i class="bi bi-geo-alt me-2 text-primary"></i>@localizer.Get("ShippingAddress")</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-flex flex-column gap-3 mb-4">
                                @if (addresses.Any())
                                {
                                    <label class="border rounded p-3 d-flex gap-3 align-items-start">
                                        <input class="form-check-input mt-1" type="radio" name="AddressEntryMode" value="saved"
                                               checked="@(Model.AddressEntryMode != "manual")" />
                                        <span class="flex-grow-1">
                                            <span class="fw-semibold d-block">@localizer.Get("UseSavedAddress")</span>
                                            <span class="text-muted small">@localizer.Get("ChooseSavedAddress")</span>
                                        </span>
                                    </label>
                                }
                                <label class="border rounded p-3 d-flex gap-3 align-items-start">
                                    <input class="form-check-input mt-1" type="radio" name="AddressEntryMode" value="manual"
                                           checked="@(!addresses.Any() || Model.AddressEntryMode == "manual")" />
                                    <span class="flex-grow-1">
                                        <span class="fw-semibold d-block">@localizer.Get("EnterNewAddress")</span>
                                        <span class="text-muted small">@localizer.Get("SelectVietnamAddress")</span>
                                    </span>
                                </label>
                            </div>

                            @if (addresses.Any())
                            {
                                <div id="savedAddressSection" class="mb-4">
                                    <label class="form-label fw-semibold text-muted small text-uppercase">
                                        <i class="bi bi-collection me-1"></i>@localizer.Get("ShippingAddress")
                                    </label>
                                    <select name="SelectedAddressId" class="form-select form-select-lg" id="addressSelect">
                                        @foreach (var addr in addresses)
                                        {
                                            <option value="@addr.Id" selected="@(addr.Id == Model.SelectedAddressId)">
                                                @addr.FullName - @addr.Phone - @addr.AddressLine, @addr.Ward, @addr.District, @addr.City
                                            </option>
                                        }
                                    </select>
                                </div>
                            }

                            <div id="newAddressSection">
                                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2 mb-3">
                                    <div>
                                        <h6 class="fw-semibold text-muted text-uppercase text-xs mb-1">@localizer.Get("EnterNewAddress")</h6>
                                        <p class="text-muted small mb-0">@localizer.Get("UseMyLocationNote")</p>
                                    </div>
                                    <button type="button" class="btn btn-outline-primary btn-sm align-self-start" id="useMyLocationBtn">
                                        <i class="bi bi-crosshair me-1"></i>@localizer.Get("UseMyLocation")
                                    </button>
                                </div>
                                <div class="alert alert-info py-2 px-3 d-none" id="locationStatus" role="status"></div>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold text-muted small">@localizer.Get("FullName") <span class="text-danger">*</span></label>
                                        <input name="SelectedAddress.FullName" class="form-control form-control-lg"
                                               value="@Model.SelectedAddress?.FullName" placeholder="@localizer.Get("FullName")"
                                               required minlength="2" maxlength="100" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label fw-semibold text-muted small">@localizer.Get("Phone") <span class="text-danger">*</span></label>
                                        <input name="SelectedAddress.Phone" class="form-control form-control-lg"
                                               value="@Model.SelectedAddress?.Phone" placeholder="@localizer.Get("Phone")"
                                               required pattern="^0[0-9]{9,10}$" title="Enter valid phone (10-11 digits starting with 0)" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-semibold text-muted small">@localizer.Get("City") <span class="text-danger">*</span></label>
                                        <select name="SelectedAddress.City" class="form-select form-select-lg" id="citySelect" data-selected="@Model.SelectedAddress?.City" required>
                                            <option value="">@localizer.Get("SelectCity")</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-semibold text-muted small">@localizer.Get("District") <span class="text-danger">*</span></label>
                                        <select name="SelectedAddress.District" class="form-select form-select-lg" id="districtSelect" data-selected="@Model.SelectedAddress?.District" required>
                                            <option value="">@localizer.Get("SelectDistrict")</option>
                                        </select>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-semibold text-muted small">@localizer.Get("Ward") <span class="text-danger">*</span></label>
                                        <select name="SelectedAddress.Ward" class="form-select form-select-lg" id="wardSelect" data-selected="@Model.SelectedAddress?.Ward" required>
                                            <option value="">@localizer.Get("SelectWard")</option>
                                        </select>
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label fw-semibold text-muted small">@localizer.Get("AddressDetail") <span class="text-danger">*</span></label>
                                        <input name="SelectedAddress.AddressLine" class="form-control form-control-lg" id="addressDetailInput"
                                               value="@Model.SelectedAddress?.AddressLine" placeholder="@localizer.Get("AddressDetailPlaceholder")"
                                               required minlength="5" maxlength="255" />
                                    </div>
                                    <div class="col-12">
                                        <div class="form-check">
                                            <input class="form-check-input" type="checkbox" name="SaveNewAddressAsDefault" value="true"
                                                   id="saveNewAddressAsDefault" checked="@Model.SaveNewAddressAsDefault" />
                                            <label class="form-check-label text-muted" for="saveNewAddressAsDefault">
                                                @localizer.Get("SaveAsDefaultAddress")
                                            </label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Payment Method -->
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white py-3">
                            <h5 class="mb-0"><i class="bi bi-credit-card me-2 text-primary"></i>@localizer.Get("PaymentMethod")</h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label class="payment-card d-flex flex-column align-items-center justify-content-center p-4 border rounded h-100 cursor-pointer @(Model.SelectedPaymentMethod == WebActionResults.Data.Entities.PaymentMethod.COD ? "border-primary border-2" : "")">
                                        <input type="radio" name="SelectedPaymentMethod" value="0" checked class="d-none" />
                                        <i class="bi bi-cash display-4 text-success mb-2"></i>
                                        <strong>COD</strong>
                                        <span class="text-muted small text-center">Cash on Delivery</span>
                                    </label>
                                </div>
                                <div class="col-md-4">
                                    <label class="payment-card d-flex flex-column align-items-center justify-content-center p-4 border rounded h-100 cursor-pointer @(Model.SelectedPaymentMethod == WebActionResults.Data.Entities.PaymentMethod.VNPay ? "border-primary border-2" : "")">
                                        <input type="radio" name="SelectedPaymentMethod" value="1" class="d-none" />
                                        <img src="~/assets/images/vnpay.png" alt="VNPay" style="height: 40px;" class="mb-2" onerror="this.style.display='none'" />
                                        <strong>VNPay</strong>
                                        <span class="text-muted small text-center">VNPay e-wallet or bank transfer</span>
                                    </label>
                                </div>
                                <div class="col-md-4">
                                    <label class="payment-card d-flex flex-column align-items-center justify-content-center p-4 border rounded h-100 cursor-pointer @(Model.SelectedPaymentMethod == WebActionResults.Data.Entities.PaymentMethod.MoMo ? "border-primary border-2" : "")">
                                        <input type="radio" name="SelectedPaymentMethod" value="2" class="d-none" />
                                        <img src="~/assets/images/momo.png" alt="MoMo" style="height: 40px;" class="mb-2" onerror="this.style.display='none'" />
                                        <strong>MoMo</strong>
                                        <span class="text-muted small text-center">MoMo e-wallet</span>
                                    </label>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Order Notes -->
                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-white py-3">
                            <h5 class="mb-0"><i class="bi bi-sticky me-2 text-primary"></i>@localizer.Get("OrderNotes")</h5>
                        </div>
                        <div class="card-body">
                            <textarea name="OrderNotes" class="form-control" rows="3"
                                      placeholder="@localizer.Get("OrderNotes")"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Order Summary -->
                <div class="col-lg-4">
                    <div class="card border-0 shadow-sm sticky-top" style="top: 100px;">
                        <div class="card-header bg-primary text-white py-3">
                            <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>@localizer.Get("OrderSummary")</h5>
                        </div>
                        <div class="card-body p-0">
                            <div class="list-group list-group-flush">
                                @foreach (var item in Model.Items)
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                                        <div class="flex-grow-1 me-3">
                                            <strong class="d-block">@item.ProductName</strong>
                                            @if (!string.IsNullOrWhiteSpace(item.VariantName))
                                            {
                                                <span class="text-muted small d-block">@item.VariantName</span>
                                            }
                                            @if (item.PriceAdjustment != 0)
                                            {
                                                <span class="text-success small d-block">@localizer.Get("Variant"): +@item.PriceAdjustment.ToString("N0") VND</span>
                                            }
                                            <span class="text-muted small">x @item.Quantity</span>
                                        </div>
                                        <span class="fw-semibold">@item.Total.ToString("N0") VND</span>
                                    </div>
                                }
                            </div>
                            <div class="p-3 border-top">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted">@localizer.Get("Subtotal")</span>
                                    <span>@Model.SubTotal.ToString("N0") VND</span>
                                </div>
                                @{
                                    var variantAdj = Model.Items.Where(i => i.PriceAdjustment != 0).Sum(i => i.PriceAdjustment * i.Quantity);
                                }
                                @if (variantAdj != 0)
                                {
                                    <div class="d-flex justify-content-between mb-2 text-success">
                                        <span>@localizer.Get("VariantAdjustments")</span>
                                        <span>+@variantAdj.ToString("N0") VND</span>
                                    </div>
                                }
                                @if (Model.DiscountAmount > 0)
                                {
                                    <div class="d-flex justify-content-between mb-2 text-success">
                                        <span>@localizer.Get("Discount")</span>
                                        <span>-@Model.DiscountAmount.ToString("N0") VND</span>
                                    </div>
                                }
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted">@localizer.Get("Shipping")</span>
                                    <span>@Model.ShippingFee.ToString("N0") VND</span>
                                </div>
                                <hr />
                                <div class="d-flex justify-content-between fw-bold fs-5 mb-3">
                                    <span>@localizer.Get("Total")</span>
                                    <span class="text-primary">@Model.Total.ToString("N0") VND</span>
                                </div>

                                <button type="submit" class="btn btn-primary btn-lg w-100">
                                    <i class="bi bi-bag-check me-2"></i>@localizer.Get("PlaceOrderConfirm")
                                </button>
                                <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">
                                    <i class="bi bi-arrow-left me-2"></i>@localizer.Get("BackToCart")
                                </a>
                            </div>
                        </div>
                    </div>

                    <!-- Applied Coupon (read-only, applied in Cart) -->
                    <div class="card border-0 shadow-sm mt-3">
                        <div class="card-body">
                            <h6 class="fw-semibold mb-3">
                                <i class="bi bi-tag me-2 text-primary"></i>@localizer.Get("Coupons")
                            </h6>
                            @if (!string.IsNullOrEmpty(Model.CouponCode))
                            {
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>@Model.CouponCode</span>
                                    <span class="text-muted small">@localizer.Get("CouponApplied")</span>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted small mb-0">@localizer.Get("HaveCoupon")</p>
                            }
                        </div>
                    </div>

                    <!-- Trust Badges -->
                    <div class="row g-3 mt-3 text-center">
                        <div class="col-4">
                            <i class="bi bi-shield-lock text-success fs-4"></i>
                            <p class="small mb-0 text-muted">@localizer.Get("SecureCheckout")</p>
                        </div>
                        <div class="col-4">
                            <i class="bi bi-truck text-primary fs-4"></i>
                            <p class="small mb-0 text-muted">@localizer.Get("FastDelivery")</p>
                        </div>
                        <div class="col-4">
                            <i class="bi bi-arrow-repeat text-warning fs-4"></i>
                            <p class="small mb-0 text-muted">@localizer.Get("EasyReturns")</p>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>

@section Scripts {
    <script src="~/assets/js/vietnam-address-data.js" asp-append-version="true"></script>
    <script>
        const vietnamAddressData = window.vietnamAddressData || {};

        document.addEventListener('DOMContentLoaded', function () {
            const modeRadios = document.querySelectorAll('input[name="AddressEntryMode"]');
            const savedSection = document.getElementById('savedAddressSection');
            const manualSection = document.getElementById('newAddressSection');
            const manualFields = manualSection ? manualSection.querySelectorAll('input, select') : [];
            const savedSelect = document.getElementById('addressSelect');
            const citySelect = document.getElementById('citySelect');
            const districtSelect = document.getElementById('districtSelect');
            const wardSelect = document.getElementById('wardSelect');
            const useMyLocationBtn = document.getElementById('useMyLocationBtn');
            const locationStatus = document.getElementById('locationStatus');
            const addressDetailInput = document.getElementById('addressDetailInput');

            const locationMessages = {
                detecting: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(localizer.Get("DetectingLocation"))),
                detected: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(localizer.Get("LocationDetected"))),
                unsupported: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(localizer.Get("LocationUnsupported"))),
                denied: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(localizer.Get("LocationPermissionDenied"))),
                failed: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(localizer.Get("LocationFailed")))
            };

            function fillSelect(select, values, placeholder, selectedValue) {
                if (!select) return;
                const matchedSelectedValue = selectedValue ? findMatchingValue(values, selectedValue) : '';
                select.innerHTML = `<option value="">${placeholder}</option>`;
                values.forEach(value => {
                    const option = document.createElement('option');
                    option.value = value;
                    option.textContent = value;
                    option.selected = value === matchedSelectedValue;
                    select.appendChild(option);
                });
            }

            function showLocationStatus(message, type = 'info') {
                if (!locationStatus) return;
                locationStatus.textContent = message;
                locationStatus.className = `alert alert-${type} py-2 px-3`;
            }

            function normalizeAddressText(value) {
                return (value || '')
                    .normalize('NFD')
                    .replace(/[\u0300-\u036f]/g, '')
                    .toLowerCase()
                    .replace(/\b(thanh pho|tp\.?|quan|huyen|thi xa|thi tran|phuong|xa)\b/g, '')
                    .replace(/[^a-z0-9]/g, '');
            }

            function findMatchingValue(values, rawValue) {
                const normalized = normalizeAddressText(rawValue);
                if (!normalized) return '';
                return values.find(value => {
                    const option = normalizeAddressText(value);
                    return option === normalized || option.includes(normalized) || normalized.includes(option);
                }) || rawValue;
            }

            function setSelectValue(select, rawValue) {
                if (!select || !rawValue) return '';
                const values = Array.from(select.options).map(option => option.value).filter(Boolean);
                const matched = findMatchingValue(values, rawValue);
                if (matched && !values.includes(matched)) {
                    const option = document.createElement('option');
                    option.value = matched;
                    option.textContent = matched;
                    select.appendChild(option);
                }
                select.value = matched;
                return matched;
            }

            function getAddressField(address, fields) {
                for (const field of fields) {
                    if (address[field]) return address[field];
                }
                return '';
            }

            function applyReverseAddress(data, fallbackCoords) {
                const address = data.address || {};
                const city = getAddressField(address, ['city', 'town', 'state', 'province', 'municipality']);
                const district = getAddressField(address, ['city_district', 'county', 'district', 'suburb']);
                const ward = getAddressField(address, ['quarter', 'neighbourhood', 'suburb', 'village', 'hamlet']);

                const selectedCity = setSelectValue(citySelect, city);
                if (selectedCity && !vietnamAddressData[selectedCity]) vietnamAddressData[selectedCity] = {};
                syncDistricts();

                const selectedDistrict = setSelectValue(districtSelect, district);
                if (selectedCity && selectedDistrict && !vietnamAddressData[selectedCity]?.[selectedDistrict]) {
                    vietnamAddressData[selectedCity][selectedDistrict] = [];
                }
                syncWards();
                setSelectValue(wardSelect, ward);

                const detailParts = [address.house_number, address.road, address.residential, address.building]
                    .filter(part => part && ![ward, district, city].includes(part));
                const detail = detailParts.join(' ') || data.display_name || fallbackCoords;
                if (addressDetailInput && detail) addressDetailInput.value = detail;
            }

            function syncDistricts() {
                const city = citySelect.value;
                const selectedDistrict = districtSelect.dataset.selected || '';
                const districts = city && vietnamAddressData[city] ? Object.keys(vietnamAddressData[city]) : [];
                fillSelect(districtSelect, districts, '@localizer.Get("SelectDistrict")', selectedDistrict);
                districtSelect.dataset.selected = '';
                syncWards();
            }

            function syncWards() {
                const city = citySelect.value;
                const district = districtSelect.value;
                const selectedWard = wardSelect.dataset.selected || '';
                const wards = city && district && vietnamAddressData[city]?.[district] ? vietnamAddressData[city][district] : [];
                fillSelect(wardSelect, wards, '@localizer.Get("SelectWard")', selectedWard);
                wardSelect.dataset.selected = '';
            }

            function setMode(mode) {
                const manual = mode === 'manual';
                if (savedSection) savedSection.classList.toggle('d-none', manual);
                if (manualSection) manualSection.classList.toggle('d-none', !manual);
                if (savedSelect) savedSelect.disabled = manual;
                manualFields.forEach(field => {
                    if (field.name === 'SaveNewAddressAsDefault') return;
                    field.disabled = !manual;
                    if (field.dataset.required !== 'false') field.required = manual;
                });
            }

            if (citySelect) {
                fillSelect(citySelect, Object.keys(vietnamAddressData), '@localizer.Get("SelectCity")', citySelect.dataset.selected || '');
                syncDistricts();
                citySelect.addEventListener('change', syncDistricts);
                districtSelect.addEventListener('change', syncWards);
            }

            modeRadios.forEach(radio => radio.addEventListener('change', () => setMode(radio.value)));
            const checkedMode = document.querySelector('input[name="AddressEntryMode"]:checked')?.value || 'manual';
            setMode(checkedMode);

            if (useMyLocationBtn) {
                useMyLocationBtn.addEventListener('click', function () {
                    const manualRadio = document.querySelector('input[name="AddressEntryMode"][value="manual"]');
                    if (manualRadio) manualRadio.checked = true;
                    setMode('manual');

                    if (!navigator.geolocation) {
                        showLocationStatus(locationMessages.unsupported, 'warning');
                        return;
                    }

                    useMyLocationBtn.disabled = true;
                    showLocationStatus(locationMessages.detecting);

                    navigator.geolocation.getCurrentPosition(async position => {
                        const { latitude, longitude } = position.coords;
                        const fallbackCoords = `${latitude.toFixed(6)}, ${longitude.toFixed(6)}`;

                        try {
                            const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=jsonv2&accept-language=vi&lat=${latitude}&lon=${longitude}`);
                            if (!response.ok) throw new Error('Reverse geocoding failed');
                            const data = await response.json();
                            applyReverseAddress(data, fallbackCoords);
                            showLocationStatus(locationMessages.detected, 'success');
                        } catch {
                            if (addressDetailInput) addressDetailInput.value = fallbackCoords;
                            showLocationStatus(locationMessages.failed, 'warning');
                        } finally {
                            useMyLocationBtn.disabled = false;
                        }
                    }, error => {
                        const message = error.code === error.PERMISSION_DENIED
                            ? locationMessages.denied
                            : locationMessages.failed;
                        showLocationStatus(message, 'warning');
                        useMyLocationBtn.disabled = false;
                    }, {
                        enableHighAccuracy: true,
                        timeout: 12000,
                        maximumAge: 300000
                    });
                });
            }
        });
    </script>
}

<style>
    .card {
        border-radius: 1rem;
    }

    .payment-card {
        transition: all 0.2s;
    }

    .payment-card:hover {
        border-color: #d47f31 !important;
        background-color: #fef9f5;
    }

    .form-control:focus {
        border-color: #d47f31;
        box-shadow: 0 0 0 0.2rem rgba(212, 127, 49, 0.25);
    }

    .sticky-top {
        z-index: 100;
    }
</style>

