@model WebActionResults.Models.Supplier

@{
    ViewData["Title"] = "Supplier Details";
}

<div class="page-hero d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title mb-1">Supplier Details</h1>
        <p class="text-secondary mb-0">Overview of supplier profile.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>

<div class="panel-card">
    <dl class="row mb-0">
        <dt class="col-sm-3">ID</dt>
        <dd class="col-sm-9">@Model.Id</dd>

        <dt class="col-sm-3">Company Name</dt>
        <dd class="col-sm-9 fw-semibold">@Model.CompanyName</dd>

        <dt class="col-sm-3">Phone</dt>
        <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Phone) ? "-" : Model.Phone)</dd>
    </dl>
</div>