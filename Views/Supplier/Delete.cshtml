@model WebActionResults.Models.Supplier

@{
    ViewData["Title"] = "Delete Supplier";
}

<div class="page-hero d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title mb-1 text-danger">Delete Supplier</h1>
        <p class="text-secondary mb-0">Please confirm this action.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="panel-card">
    <dl class="row mb-0">
        <dt class="col-sm-3">Company Name</dt>
        <dd class="col-sm-9 fw-semibold">@Model.CompanyName</dd>

        <dt class="col-sm-3">Phone</dt>
        <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Phone) ? "-" : Model.Phone)</dd>
    </dl>

    <form asp-action="Delete" method="post" class="mt-4 d-flex gap-2">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Confirm Delete</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>