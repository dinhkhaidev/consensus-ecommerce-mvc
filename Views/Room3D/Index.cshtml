@{
    ViewData["Title"] = "Trải nghiệm phòng 3D";
}

<link rel="stylesheet" href="~/css/room3d.css" asp-append-version="true" />

<div id="room3dPage" class="room3d-page" data-library-open="false" data-inspector-open="false" data-detail-open="false">
    @Html.AntiForgeryToken()

    <main class="room3d-stage" aria-label="Showroom nội thất 3D">
        <canvas id="room3dCanvas"></canvas>

        <div id="loadingOverlay" class="loading-overlay">
            <div class="loader"></div>
            <p>Đang dựng showroom 3D...</p>
        </div>

        <div id="roomToast" class="room-toast" role="status" aria-live="polite"></div>
    </main>

    <header class="room3d-topbar">
        <div class="topbar-left">
            <button id="libraryToggleBtn" type="button" class="room3d-icon-btn" aria-controls="room3dLibrary" aria-expanded="false" title="Mở thư viện nội thất">
                <i class="bi bi-grid-3x3-gap"></i>
            </button>
            <div>
                <div class="eyebrow">Interactive 3D Room</div>
                <h1>Trải nghiệm phòng 3D</h1>
                <p>Xem thử combo nội thất trong showroom ảo.</p>
            </div>
        </div>

        <div class="topbar-actions">
            <button id="fullscreenBtn" type="button" class="room3d-btn room3d-btn-light">
                <i class="bi bi-fullscreen"></i>
                <span>Full màn hình</span>
            </button>
            <button id="resetCameraBtn" type="button" class="room3d-btn room3d-btn-light">
                <i class="bi bi-camera-video"></i>
                <span>Reset view</span>
            </button>
            <button id="snapshotBtn" type="button" class="room3d-btn room3d-btn-light">
                <i class="bi bi-camera"></i>
                <span>Chụp ảnh</span>
            </button>
            <button id="buyRoomBtn" type="button" class="room3d-btn room3d-btn-primary">
                <i class="bi bi-bag-check"></i>
                <span>Thêm vào giỏ</span>
            </button>
        </div>
    </header>

    <aside id="room3dLibrary" class="room3d-sidebar" aria-label="Thư viện nội thất 3D">
        <div class="panel-toolbar">
            <div>
                <span class="panel-kicker">Furniture library</span>
                <h2>Thư viện nội thất</h2>
                <p>Chọn món để đặt vào phòng.</p>
            </div>
            <button id="libraryCloseBtn" type="button" class="room3d-icon-btn room3d-icon-btn-soft" title="Đóng thư viện">
                <i class="bi bi-x-lg"></i>
            </button>
        </div>

        <div class="library-search">
            <i class="bi bi-search"></i>
            <input id="productSearchInput" type="search" placeholder="Tìm sofa, bàn, đèn..." autocomplete="off" />
        </div>

        <div class="library-stats">
            <span id="libraryCount">0 models</span>
            <span>Lazy load khi Add</span>
        </div>

        <div id="categoryFilters" class="category-filters" aria-label="Lọc danh mục"></div>

        <div id="productList" class="product-list"></div>
    </aside>

    <aside id="room3dInspector" class="room3d-inspector" aria-label="Thông tin sản phẩm đang chọn">
        <div class="panel-toolbar">
            <div>
                <span class="panel-kicker">Selection</span>
                <h2>Đang chọn</h2>
            </div>
            <button id="inspectorCloseBtn" type="button" class="room3d-icon-btn room3d-icon-btn-soft" title="Thu gọn panel">
                <i class="bi bi-chevron-down"></i>
            </button>
        </div>

        <div id="selectedInfo" class="selected-info empty">Chưa chọn sản phẩm</div>

        <div class="control-grid">
            <button id="rotateLeftBtn" type="button" class="room3d-btn room3d-btn-light">
                <i class="bi bi-arrow-counterclockwise"></i>
                <span>Xoay trái</span>
            </button>
            <button id="rotateRightBtn" type="button" class="room3d-btn room3d-btn-light">
                <i class="bi bi-arrow-clockwise"></i>
                <span>Xoay phải</span>
            </button>
            <button id="pitchUpBtn" type="button" class="room3d-btn room3d-btn-light">
                <i class="bi bi-arrow-up-right"></i>
                <span>Nghiêng lên</span>
            </button>
            <button id="pitchDownBtn" type="button" class="room3d-btn room3d-btn-light">
                <i class="bi bi-arrow-down-left"></i>
                <span>Nghiêng xuống</span>
            </button>
            <button id="rollLeftBtn" type="button" class="room3d-btn room3d-btn-light">
                <i class="bi bi-arrow-bar-left"></i>
                <span>Lật trái</span>
            </button>
            <button id="rollRightBtn" type="button" class="room3d-btn room3d-btn-light">
                <i class="bi bi-arrow-bar-right"></i>
                <span>Lật phải</span>
            </button>
            <button id="focusSelectedBtn" type="button" class="room3d-btn room3d-btn-light">
                <i class="bi bi-crosshair"></i>
                <span>Focus</span>
            </button>
            <button id="resetRotationBtn" type="button" class="room3d-btn room3d-btn-light">
                <i class="bi bi-arrow-repeat"></i>
                <span>Reset xoay</span>
            </button>
            <button id="deleteBtn" type="button" class="room3d-btn room3d-btn-danger">
                <i class="bi bi-trash"></i>
                <span>Xóa</span>
            </button>
        </div>

        <div class="room-total">
            <span>Tổng giá</span>
            <strong id="totalPrice">0&nbsp;₫</strong>
        </div>
    </aside>

    <section id="productDetailModal" class="product-detail-modal" aria-modal="true" aria-label="Xem chi tiết model 3D">
        <div class="detail-viewer-shell">
            <canvas id="productDetailCanvas"></canvas>

            <div class="detail-loading" id="detailLoading">
                <div class="loader"></div>
                <p>Đang tải model chi tiết...</p>
            </div>

            <div class="detail-topbar">
                <div>
                    <span class="panel-kicker">Product viewer</span>
                    <h2 id="detailProductName">Model nội thất</h2>
                    <p id="detailProductMeta">Xoay, zoom và ngắm chi tiết sản phẩm.</p>
                </div>
                <button id="detailCloseBtn" type="button" class="room3d-icon-btn room3d-icon-btn-soft" title="Đóng xem chi tiết">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="detail-actions">
                <button id="detailAutoRotateBtn" type="button" class="room3d-btn room3d-btn-light" aria-pressed="false">
                    <i class="bi bi-arrow-repeat"></i>
                    <span>Tự quay</span>
                </button>
                <button id="detailAddBtn" type="button" class="room3d-btn room3d-btn-primary">
                    <i class="bi bi-plus-circle"></i>
                    <span>Đặt vào phòng</span>
                </button>
                <span><i class="bi bi-mouse"></i> Kéo để xoay · Scroll để zoom</span>
            </div>
        </div>
    </section>

    <button id="inspectorToggleBtn" type="button" class="selection-toggle" aria-controls="room3dInspector" aria-expanded="false">
        <i class="bi bi-sliders"></i>
        <span>Selection</span>
    </button>

    <!-- Easter Egg: Telescope Viewfinder Overlay -->
    <div id="telescopeViewfinder" class="telescope-viewfinder">
        <div class="viewfinder-frame">
            <div class="viewfinder-lens">
                <div id="earthCanvasContainer"></div>
                <div class="viewfinder-glass-shimmer"></div>
                <div class="viewfinder-crosshairs">
                    <div class="crosshair-h"></div>
                    <div class="crosshair-v"></div>
                    <div class="crosshair-center"></div>
                </div>
            </div>
            <div class="viewfinder-label">ĐANG QUAN SÁT: TRÁI ĐẤT (TERRA)</div>
            <div class="viewfinder-sublabel">Quần đảo Hoàng Sa và Trường Sa thuộc chủ quyền Việt Nam 🇻🇳</div>
            <div class="viewfinder-controls">
                <button type="button" class="planet-select-btn active" data-planet="earth">Trái Đất</button>
                <button type="button" class="planet-select-btn" data-planet="aurelia">Aurelia</button>
                <button type="button" class="planet-select-btn" data-planet="selene">Selene</button>
                <button type="button" class="planet-select-btn" data-planet="ignis">Ignis</button>
                <button type="button" class="planet-select-btn" data-planet="glacia">Glacia</button>
            </div>
            <button id="closeTelescopeViewBtn" type="button" class="viewfinder-close-btn">
                <i class="bi bi-arrow-left"></i> Quay Lại Showroom
            </button>
        </div>
    </div>

    <style>
        .viewfinder-controls {
            margin-top: 16px;
            display: flex;
            gap: 12px;
            z-index: 10;
        }
        .planet-select-btn {
            padding: 8px 20px;
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(212, 175, 55, 0.3);
            border-radius: 20px;
            color: rgba(255, 255, 255, 0.7);
            font-weight: 600;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.3s ease;
            font-family: 'Outfit', 'Inter', sans-serif;
        }
        .planet-select-btn:hover {
            background: rgba(212, 175, 55, 0.15);
            color: #d4af37;
            border-color: #d4af37;
        }
        .planet-select-btn.active {
            background: #d4af37;
            color: #02040c;
            border-color: #d4af37;
            box-shadow: 0 0 15px rgba(212, 175, 55, 0.35);
        }
        .telescope-viewfinder {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle, rgba(10, 15, 35, 0.98) 0%, rgba(2, 4, 12, 1) 100%);
            z-index: 10000;
            align-items: center;
            justify-content: center;
            opacity: 0;
            transition: opacity 0.4s ease;
        }
        .telescope-viewfinder.active {
            display: flex;
            opacity: 1;
        }
        .viewfinder-frame {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            animation: viewfinder-fade-in 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }
        .viewfinder-lens {
            width: min(72vw, 72vh);
            height: min(72vw, 72vh);
            border-radius: 50%;
            border: 12px double #d4af37;
            box-shadow: 0 0 45px rgba(212, 175, 55, 0.45), 
                        inset 0 0 80px rgba(0, 0, 0, 0.95);
            position: relative;
            overflow: hidden;
            background: #010308;
            cursor: grab;
        }
        .viewfinder-lens:active {
            cursor: grabbing;
        }
        #earthCanvasContainer {
            width: 100%;
            height: 100%;
        }
        .viewfinder-glass-shimmer {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            background: linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.02) 40%, rgba(0, 0, 0, 0) 50%, rgba(255, 255, 255, 0.01) 60%, rgba(0, 0, 0, 0.3) 100%);
            z-index: 5;
        }
        .viewfinder-crosshairs {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            border: 1px dashed rgba(212, 175, 55, 0.2);
            border-radius: 50%;
            box-sizing: border-box;
            z-index: 4;
        }
        .crosshair-h {
            position: absolute;
            top: 50%;
            left: 0;
            width: 100%;
            height: 1px;
            background: linear-gradient(90deg, rgba(212, 175, 55, 0) 0%, rgba(212, 175, 55, 0.25) 15%, rgba(212, 175, 55, 0.25) 85%, rgba(212, 175, 55, 0) 100%);
        }
        .crosshair-v {
            position: absolute;
            left: 50%;
            top: 0;
            height: 100%;
            width: 1px;
            background: linear-gradient(180deg, rgba(212, 175, 55, 0) 0%, rgba(212, 175, 55, 0.25) 15%, rgba(212, 175, 55, 0.25) 85%, rgba(212, 175, 55, 0) 100%);
        }
        .crosshair-center {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 48px;
            height: 48px;
            border: 1px solid rgba(212, 175, 55, 0.3);
            border-radius: 50%;
        }
        .viewfinder-label {
            margin-top: 24px;
            color: #d4af37;
            font-size: 1.25rem;
            font-weight: 600;
            letter-spacing: 2px;
            text-shadow: 0 0 10px rgba(212, 175, 55, 0.5);
            font-family: 'Outfit', 'Inter', sans-serif;
        }
        .viewfinder-sublabel {
            margin-top: 8px;
            color: #4ade80;
            font-size: 0.95rem;
            font-weight: 600;
            letter-spacing: 1px;
            text-shadow: 0 0 10px rgba(74, 222, 128, 0.6);
            font-family: 'Outfit', 'Inter', sans-serif;
            transition: all 0.3s ease;
            min-height: 20px;
        }
        .viewfinder-close-btn {
            margin-top: 20px;
            padding: 12px 28px;
            background: rgba(212, 175, 55, 0.12);
            border: 2px solid #d4af37;
            border-radius: 30px;
            color: #d4af37;
            font-weight: 700;
            font-size: 0.95rem;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.4);
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            font-family: 'Outfit', 'Inter', sans-serif;
        }
        .viewfinder-close-btn:hover {
            background: #d4af37;
            color: #02040c;
            box-shadow: 0 0 25px rgba(212, 175, 55, 0.45);
            transform: translateY(-2px);
        }
        .viewfinder-close-btn:active {
            transform: translateY(1px);
        }
        @@keyframes viewfinder-fade-in {
            from {
                opacity: 0;
                transform: scale(0.92);
            }
            to {
                opacity: 1;
                transform: scale(1);
            }
        }
    </style>
</div>

@section Scripts {
    <script type="importmap">
        {
            "imports": {
                "three": "https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.module.js",
                "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.160.0/examples/jsm/"
            }
        }
    </script>
    <script type="module" src="~/js/room3d.js" asp-append-version="true"></script>
}
