@model WebActionResults.Models.Category

@{
    ViewData["Title"] = "Delete Category";
}

<div class="page-hero d-flex justify-content-between align-items-center">
    <div>
        <h1 class="page-title mb-1 text-danger">Delete Category</h1>
        <p class="text-secondary mb-0">Please confirm this action.</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="panel-card">
    @if (Model.Products.Any())
    {
        <div class="alert alert-warning mb-3">
            This category has <strong>@Model.Products.Count</strong> product(s). Delete related products first.
        </div>
    }

    <dl class="row mb-0">
        <dt class="col-sm-3">Category Name</dt>
        <dd class="col-sm-9 fw-semibold">@Model.CategoryName</dd>

        <dt class="col-sm-3">Description</dt>
        <dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Description) ? "-" : Model.Description)</dd>

        <dt class="col-sm-3">Products</dt>
        <dd class="col-sm-9">@Model.Products.Count</dd>
    </dl>

    <form asp-action="Delete" method="post" class="mt-4 d-flex gap-2">
        <input type="hidden" asp-for="CategoryID" />
        <button type="submit" class="btn btn-danger" @(Model.Products.Any() ? "disabled" : null)>Confirm Delete</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>
