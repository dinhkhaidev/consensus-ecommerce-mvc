@model IEnumerable<WebActionResults.ViewModels.CategoryViewModel>
@{
    ViewData["Title"] = localizer.Get("Categories") + " - Furnish";
}

<!-- Breadcrumb -->
<section class="py-3 bg-light">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">@localizer.Get("Home")</a></li>
                <li class="breadcrumb-item active">@localizer.Get("Categories")</li>
            </ol>
        </nav>
    </div>
</section>

<section class="py-lg-8 py-5">
    <div class="container">
        <div class="text-center mb-5">
            <h1 class="display-5 fw-bold mb-3">
                <i class="bi bi-grid-3x3-gap me-2"></i>@localizer.Get("ShopCategories")
            </h1>
            <p class="text-muted lead">@localizer.Get("BrowseCollectionByCategory")</p>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-secondary text-center py-5">
                <i class="bi bi-folder-x" style="font-size: 4rem;"></i>
                <h5 class="mt-3 mb-2">@localizer.Get("NoCategoriesFound")</h5>
                <p class="text-muted mb-0">@localizer.Get("CheckBackCategories")</p>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var category in Model)
                {
                    <div class="col-6 col-md-4 col-lg-3">
                        <a asp-controller="Category" asp-action="Details" asp-route-id="@category.CategoryId"
                           class="text-decoration-none">
                            <div class="card category-card h-100 border-0 shadow-sm text-center hover-lift">
                                <div class="card-body d-flex flex-column justify-content-center align-items-center py-5">
                                    @{
                                        var iconClass = "bi-folder";
                                        if (category.CategoryName.Contains("Living"))
                                        {
                                            iconClass = "bi-house-door";
                                        }
                                        else if (category.CategoryName.Contains("Office"))
                                        {
                                            iconClass = "bi-laptop";
                                        }
                                        else if (category.CategoryName.Contains("Bed"))
                                        {
                                            iconClass = "bi-moon";
                                        }
                                        else if (category.CategoryName.Contains("Dining"))
                                        {
                                            iconClass = "bi-cup-hot";
                                        }
                                        else if (category.CategoryName.Contains("Decor"))
                                        {
                                            iconClass = "bi-flower1";
                                        }
                                        else if (category.CategoryName.Contains("Outdoor"))
                                        {
                                            iconClass = "bi-sun";
                                        }
                                    }
                                    <i class="bi @iconClass text-primary mb-3" style="font-size: 3rem;"></i>
                                    <h5 class="card-title mb-2">@category.CategoryName</h5>
                                    <p class="text-muted small mb-0">@category.ProductCount @localizer.Get("Products").ToLower()</p>
                                </div>
                            </div>
                        </a>
                    </div>
                }
            </div>
        }
    </div>
</section>

<style>
    .category-card {
        border-radius: 1rem;
        transition: all 0.3s ease;
    }

    .category-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 40px rgba(0,0,0,0.15) !important;
    }

    .category-card i {
        transition: transform 0.3s ease;
    }

    .category-card:hover i {
        transform: scale(1.2);
    }

    .hover-lift:hover {
        transform: translateY(-8px);
    }
</style>
