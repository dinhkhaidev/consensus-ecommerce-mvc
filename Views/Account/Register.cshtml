@model WebActionResults.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = localizer.Get("Register") + " - Furnish";
    var returnUrl = Context.Request.Query["returnUrl"].ToString();
}

<section class="py-lg-8 py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-6">
                <div class="card border-0 shadow-lg">
                    <div class="card-body p-4 p-lg-5">
                        <div class="text-center mb-4">
                            <div class="mb-3">
                                <i class="bi bi-house-door-fill text-primary" style="font-size: 3rem;"></i>
                            </div>
                            <h2 class="fw-bold">@localizer.Get("Register")</h2>
                            <p class="text-muted">@localizer.Get("DontHaveAccount")</p>
                        </div>

                        <form asp-action="Register" method="post">
                            <input type="hidden" name="returnUrl" value="@returnUrl" />
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="UserName" class="form-label fw-semibold">
                                        <i class="bi bi-person me-1"></i>@localizer.Get("Email")
                                    </label>
                                    <input asp-for="UserName" class="form-control form-control-lg"
                                           placeholder="@localizer.Get("Email")" />
                                    <span asp-validation-for="UserName" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Email" class="form-label fw-semibold">
                                        <i class="bi bi-envelope me-1"></i>@localizer.Get("Email")
                                    </label>
                                    <input asp-for="Email" class="form-control form-control-lg"
                                           type="email" placeholder="your@email.com" />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label asp-for="FullName" class="form-label fw-semibold">
                                    <i class="bi bi-card-text me-1"></i>@localizer.Get("FullName")
                                </label>
                                <input asp-for="FullName" class="form-control form-control-lg"
                                       placeholder="@localizer.Get("FullName")" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Password" class="form-label fw-semibold">
                                        <i class="bi bi-lock me-1"></i>@localizer.Get("Password")
                                    </label>
                                    <input asp-for="Password" class="form-control form-control-lg"
                                           type="password" placeholder="@localizer.Get("Password")" />
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="ConfirmPassword" class="form-label fw-semibold">
                                        <i class="bi bi-lock-fill me-1"></i>@localizer.Get("Password")
                                    </label>
                                    <input asp-for="ConfirmPassword" class="form-control form-control-lg"
                                           type="password" placeholder="@localizer.Get("Password")" />
                                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="PhoneNumber" class="form-label fw-semibold">
                                        <i class="bi bi-phone me-1"></i>@localizer.Get("Phone")
                                    </label>
                                    <input asp-for="PhoneNumber" class="form-control form-control-lg"
                                           placeholder="@localizer.Get("Phone")" />
                                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Birthday" class="form-label fw-semibold">
                                        <i class="bi bi-calendar me-1"></i>Birthday
                                    </label>
                                    <input asp-for="Birthday" class="form-control form-control-lg"
                                           type="date" />
                                    <span asp-validation-for="Birthday" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="form-check mb-4">
                                <input class="form-check-input" type="checkbox" id="termsCheck" required />
                                <label class="form-check-label text-muted small" for="termsCheck">
                                    I agree to the <a href="#" class="text-primary">Terms of Service</a>
                                    and <a href="#" class="text-primary">Privacy Policy</a>
                                </label>
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100">
                                <i class="bi bi-person-plus me-2"></i>@localizer.Get("SignUp")
                            </button>
                        </form>

                        <hr class="my-4">

                        <div class="text-center">
                            <span class="text-muted">@localizer.Get("AlreadyHaveAccount")</span>
                            <a asp-action="Login" asp-route-returnUrl="@returnUrl"
                               class="btn btn-outline-primary w-100 mt-2">
                                <i class="bi bi-box-arrow-in-right me-2"></i>@localizer.Get("Login")
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .card {
        border-radius: 1rem;
    }

    .form-control:focus {
        border-color: #d47f31;
        box-shadow: 0 0 0 0.2rem rgba(212, 127, 49, 0.25);
    }

    .btn-primary {
        background-color: #d47f31;
        border-color: #d47f31;
    }

    .btn-primary:hover {
        background-color: #b86d26;
        border-color: #b86d26;
    }
</style>