@model WebActionResults.ViewModels.AddressEditViewModel
@{
    ViewData["Title"] = "Add Address - Furnish";
}

<!-- Breadcrumb -->
<section class="py-3 bg-light">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-decoration-none">Home</a></li>
                <li class="breadcrumb-item"><a asp-controller="Account" asp-action="Profile" class="text-decoration-none">My Profile</a></li>
                <li class="breadcrumb-item active">Add Address</li>
            </ol>
        </nav>
    </div>
</section>

<section class="py-lg-8 py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8 col-lg-6">
                <div class="card border-0 shadow-lg">
                    <div class="card-header bg-white py-4">
                        <h4 class="mb-0"><i class="bi bi-geo-alt me-2 text-primary"></i>Add New Address</h4>
                    </div>
                    <div class="card-body p-4">
                        <form asp-action="AddAddress" method="post">
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                            <div class="mb-3">
                                <label asp-for="FullName" class="form-label fw-semibold text-muted small text-uppercase">
                                    <i class="bi bi-person me-1"></i>Full Name
                                </label>
                                <input asp-for="FullName" class="form-control form-control-lg"
                                       placeholder="Recipient's full name" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="Phone" class="form-label fw-semibold text-muted small text-uppercase">
                                    <i class="bi bi-phone me-1"></i>Phone Number
                                </label>
                                <input asp-for="Phone" class="form-control form-control-lg"
                                       placeholder="Contact phone number" />
                                <span asp-validation-for="Phone" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label asp-for="AddressLine" class="form-label fw-semibold text-muted small text-uppercase">
                                    <i class="bi bi-house me-1"></i>Address Line
                                </label>
                                <input asp-for="AddressLine" class="form-control form-control-lg"
                                       placeholder="Street address, house number, apartment, suite, etc." />
                                <span asp-validation-for="AddressLine" class="text-danger"></span>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="Ward" class="form-label fw-semibold text-muted small text-uppercase">
                                        <i class="bi bi-pin me-1"></i>Ward / Commune
                                    </label>
                                    <input asp-for="Ward" class="form-control form-control-lg"
                                           placeholder="Ward or Commune" />
                                    <span asp-validation-for="Ward" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="District" class="form-label fw-semibold text-muted small text-uppercase">
                                        <i class="bi bi-pin-fill me-1"></i>District
                                    </label>
                                    <input asp-for="District" class="form-control form-control-lg"
                                           placeholder="District" />
                                    <span asp-validation-for="District" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label asp-for="City" class="form-label fw-semibold text-muted small text-uppercase">
                                        <i class="bi bi-building me-1"></i>City / Province
                                    </label>
                                    <input asp-for="City" class="form-control form-control-lg"
                                           placeholder="City or Province" />
                                    <span asp-validation-for="City" class="text-danger"></span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label asp-for="PostalCode" class="form-label fw-semibold text-muted small text-uppercase">
                                        <i class="bi bi-mailbox me-1"></i>Postal Code
                                    </label>
                                    <input asp-for="PostalCode" class="form-control form-control-lg"
                                           placeholder="Postal code (optional)" />
                                    <span asp-validation-for="PostalCode" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="form-check mb-4">
                                <input asp-for="IsDefault" class="form-check-input" id="isDefaultCheck" />
                                <label class="form-check-label" for="isDefaultCheck">
                                    Set as my default delivery address
                                </label>
                            </div>

                            <div class="d-flex gap-3">
                                <button type="submit" class="btn btn-primary btn-lg flex-grow-1">
                                    <i class="bi bi-check-lg me-2"></i>Save Address
                                </button>
                                <a asp-action="Profile" class="btn btn-outline-secondary btn-lg">
                                    <i class="bi bi-x-lg me-2"></i>Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>
    .card {
        border-radius: 1rem;
    }

    .form-control:focus {
        border-color: #d47f31;
        box-shadow: 0 0 0 0.2rem rgba(212, 127, 49, 0.25);
    }

    .btn-primary {
        background-color: #d47f31;
        border-color: #d47f31;
    }

    .btn-primary:hover {
        background-color: #b86d26;
        border-color: #b86d26;
    }
</style>