@model WebActionResults.ViewModels.VerifyEmailViewModel
@{
    ViewData["Title"] = "Xác thực tài khoản";
    var method = ViewBag.ChosenMethod as string;
}

<div class="container py-5 my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 bg-white p-4">
                <div class="card-body py-3">
                    
                    @if (string.IsNullOrEmpty(method))
                    {
                        <div class="text-center mb-4">
                            <i class="bi bi-person-check text-dark" style="font-size: 3rem;"></i>
                            <h4 class="fw-bold text-uppercase mt-2" style="letter-spacing: 0.1rem;">Chọn cách xác thực</h4>
                            <p class="text-muted small">Tài khoản <span class="text-dark fw-bold">@Model.Email</span> cần được kích hoạt để sử dụng.</p>
                        </div>

                        <div class="d-grid gap-3">
                            <form asp-action="SendVerificationMethod" method="post">
                                <input type="hidden" name="email" value="@Model.Email" />
                                <input type="hidden" name="targetMethod" value="OTP" />
                                <button type="submit" class="btn btn-outline-dark w-100 py-3 text-start px-4 rounded-3 d-flex align-items-center justify-content-between option-btn">
                                    <div>
                                        <strong class="d-block text-uppercase small" style="letter-spacing: 0.05rem;">Cách 1: Nhận mã số OTP</strong>
                                        <span class="text-muted style-desc" style="font-size: 0.8rem;">Hệ thống gửi mã 6 chữ số để bạn tự nhập thủ công</span>
                                    </div>
                                    <i class="bi bi-hash fs-4"></i>
                                </button>
                            </form>

                            <form asp-action="SendVerificationMethod" method="post">
                                <input type="hidden" name="email" value="@Model.Email" />
                                <input type="hidden" name="targetMethod" value="Link" />
                                <button type="submit" class="btn btn-outline-dark w-100 py-3 text-start px-4 rounded-3 d-flex align-items-center justify-content-between option-btn">
                                    <div>
                                        <strong class="d-block text-uppercase small" style="letter-spacing: 0.05rem;">Cách 2: Nhận Link xác nhận nhanh</strong>
                                        <span class="text-muted style-desc" style="font-size: 0.8rem;">Gửi nút bấm tự động qua email, nhấp phát ăn ngay</span>
                                    </div>
                                    <i class="bi bi-link-45deg fs-4"></i>
                                </button>
                            </form>
                        </div>
                    }
                    else if (method == "OTP")
                    {
                        <div class="text-center mb-4">
                            <i class="bi bi-shield-lock-fill text-dark" style="font-size: 3rem;"></i>
                            <h4 class="fw-bold text-uppercase mt-2">Nhập mã OTP 6 Số</h4>
                            <p class="text-muted small">Vui lòng kiểm tra email và nhập chuỗi số bảo mật vào ô dưới đây:</p>
                        </div>

                        <form asp-action="VerifyEmail" method="post">
                            <input type="hidden" asp-for="Email" />
                            <div class="mb-4">
                                <input asp-for="Token" type="text" maxlength="6" 
                                       class="form-control form-control-lg text-center fw-bold shadow-sm" 
                                       style="font-size: 2.2rem; letter-spacing: 0.8rem; color: #111;" 
                                       placeholder="------" required 
                                       oninput="this.value = this.value.replace(/[^0-9]/g, '');" />
                            </div>
                            <button type="submit" class="btn btn-dark w-100 py-2.5 fw-bold text-uppercase small mb-3">Xác thực mã</button>
                        </form>

                        <div class="text-center pt-2 border-top">
                            <form asp-action="SendVerificationMethod" method="post">
                                <input type="hidden" name="email" value="@Model.Email" />
                                <input type="hidden" name="targetMethod" value="OTP" />
                                @if (ViewBag.RemainingResends > 0) {
                                    <button type="submit" class="btn btn-link text-decoration-none text-muted small p-0">Gửi lại mã số OTP (@ViewBag.RemainingResends lần còn lại)</button>
                                } else {
                                    <span class="text-danger small fw-bold"><i class="bi bi-exclamation-circle-fill me-1"></i>Hết lượt gửi lại.</span>
                                }
                            </form>
                            <a asp-action="VerifyEmail" asp-route-email="@Model.Email" class="d-block small text-dark mt-2 text-decoration-none fw-bold">← Đổi phương thức khác</a>
                        </div>
                    }
                    else if (method == "Link")
                    {
                        <div class="text-center py-4">
                            <div class="mb-3 d-inline-flex align-items-center justify-content-center bg-light rounded-circle" style="width: 80px; height: 80px;">
                                <i class="bi bi-envelope-check text-success" style="font-size: 2.5rem;"></i>
                            </div>
                            <h4 class="fw-bold text-uppercase">Kiểm tra Hộp thư đi</h4>
                            <p class="text-muted px-2 small lh-lg">Một liên kết xác thực an toàn duy nhất đã được gửi tới hòm thư của bạn. Vui lòng nhấp vào nút bên trong email để hoàn tất kích hoạt.</p>
                            
                            <div class="p-3 bg-light rounded-3 text-start my-4 mx-auto style-box" style="max-width: 400px; border-left: 3px solid #111;">
                                <span class="small d-block text-muted">Không thấy email? Hãy kiểm tra thêm các mục:</span>
                                <span class="small fw-bold text-dark d-block mt-1">• Thư rác (Spam) hoặc Danh mục Quảng cáo.</span>
                            </div>

                            <form asp-action="SendVerificationMethod" method="post" class="mb-3">
                                <input type="hidden" name="email" value="@Model.Email" />
                                <input type="hidden" name="targetMethod" value="Link" />
                                @if (ViewBag.RemainingResends > 0) {
                                    <button type="submit" class="btn btn-outline-dark btn-sm px-3 py-2 text-uppercase fw-bold" style="font-size:0.75rem;">Gửi lại liên kết mới (@ViewBag.RemainingResends)</button>
                                } else {
                                    <span class="text-danger small fw-bold d-block"><i class="bi bi-exclamation-circle-fill me-1"></i>Hết lượt gửi lại liên kết.</span>
                                }
                            </form>
                            <a asp-action="VerifyEmail" asp-route-email="@Model.Email" class="small text-dark text-decoration-none fw-bold d-block mt-3">← Đổi phương thức khác</a>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .option-btn:hover { background-color: #f8f9fa; border-color: #111; }
    .option-btn:hover .style-desc { color: #111 !important; }
    .style-box { font-size: 0.85rem; }
</style>